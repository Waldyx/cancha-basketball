---
// /calculadora — página standalone de coste por partido.
// Buscador con autocompletado sobre el catálogo completo (200+ con retros).
// Comparte el mismo modelo de cálculo que el bloque embebido en la ficha.
//
// Copia a web/src/pages/calculadora.astro
// Enlázala desde el nav: <a href="/calculadora">Calculadora</a>

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
import { zapatillas } from "../data/zapatillas";
import { findMejorPrecio } from "../lib/scoring";

// Indexar todo el catálogo para el datalist + lookup en cliente
const index = zapatillas.map((z) => ({
  slug: z.slug,
  marca: z.marca,
  modelo: z.modelo,
  dura: z.puntuaciones.durabilidad_outdoor,
  precio: (findMejorPrecio(z.links_compra)?.precio_actual) ?? z.precio_msrp_eur,
  cat: z.categoria_principal,
  retro: z.tags.includes("retro"),
}));

// Por defecto: la primera no-retro con precio verificado
const def = index.find((z) => !z.retro) ?? index[0];
---

<Base
  title="Calculadora de coste por partido | CANCHA.ZAPA"
  description="¿Cuánto te cuesta de verdad una zapatilla de baloncesto? Calcula el coste por partido según tu uso real. Sin BS."
>
  <main class="app">
    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/zapatillas">Catálogo</a>
          <a href="/quiz">Quiz</a>
          <a href="/rankings">Rankings</a>
          <a href="/calculadora" class="active" aria-current="page">Calculadora</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    {/* HERO */}
    <section class="doc-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Calculadora · Sin BS</p>
        <h1 class="doc-h1">
          Coste<br/>
          <span class="accent">por partido</span>
        </h1>
        <p class="doc-lede">
          Una zapa de 200€ que dura 3 años sale más barata que una de 80€ que revientas
          en 4 meses. Calcula lo que de verdad te cuesta según tu uso real.
        </p>
      </div>
    </section>

    {/* CALCULADORA */}
    <section class="cost-main">
      <div class="shell">
        <div class="cost-grid">
          {/* Controles */}
          <div class="cost-controls">
            <div class="cc-block">
              <label class="cc-label">Tu zapa <strong style="font-size:11px;color:#71717a">{index.length} en catálogo</strong></label>
              <input
                id="cost-search"
                class="cc-search"
                list="cz-shoe-list"
                placeholder="Busca marca o modelo…"
                value={`${def.marca} ${def.modelo}`}
                autocomplete="off"
              />
              <datalist id="cz-shoe-list">
                {index.map((s) => (
                  <option value={`${s.marca} ${s.modelo}`}>{Math.round(s.precio)}€ · {s.cat}{s.retro ? " · retro" : ""}</option>
                ))}
              </datalist>
            </div>

            <div class="cc-block">
              <label class="cc-label">Partidos / semana <strong id="out-semana">3</strong></label>
              <input type="range" min="1" max="7" step="1" value="3" class="cc-range" id="in-semana" />
            </div>

            <div class="cc-block">
              <label class="cc-label">Juego en exterior <strong id="out-outdoor">30%</strong></label>
              <input type="range" min="0" max="100" step="10" value="30" class="cc-range" id="in-outdoor" />
              <p class="cc-hint">El asfalto desgasta ~2,5× más rápido que el parquet.</p>
            </div>
          </div>

          {/* Resultado */}
          <div class="cost-result" id="cost-result">
            <div class="cr-retro hidden" id="cr-retro">
              <span class="cb-bell cb-bell-retro" aria-hidden="true">◈</span>
              <p class="cz-eyebrow" style="color:#facc15">★ Retro · Coleccionismo</p>
              <p class="cr-retro-body">
                Esta es un modelo <strong>retro</strong>. La mayoría se compran para vitrina,
                no para jugar — el coste por partido no aplica igual.
              </p>
            </div>
            <div id="cr-calc">
              <span class="cr-cost" id="out-coste">—</span>
              <span class="cr-cost-unit">por partido</span>
              <span class="cr-verdict" id="out-veredicto">—</span>
              <div class="cr-stats">
                <div><strong id="out-partidos">—</strong><span>partidos de vida</span></div>
                <div><strong id="out-vida">—</strong><span>meses a tu ritmo</span></div>
                <div><strong id="out-precio">—</strong><span>precio actual</span></div>
              </div>
              <div class="cr-gauge">
                <div class="cr-gauge-head">
                  <span>Desgaste estimado a 6 meses</span>
                  <strong id="out-desgaste">—</strong>
                </div>
                <div class="cr-gauge-bar"><div class="cr-gauge-fill" id="out-desgaste-bar"></div></div>
              </div>
              <a href="#" id="cr-cta" class="home-btn primary" style="margin-top:18px">Ver review de la zapa →</a>
            </div>
          </div>
        </div>

        <p class="cost-disclaimer">
          ⚠ Estimación basada en el score de durabilidad de cada zapa y tu uso declarado.
          El desgaste real depende de superficie, técnica y cuidado. No es una garantía,
          es una guía honesta para decidir.
        </p>
      </div>
    </section>

  </main>

  <script define:vars={{ index, defSlug: def.slug }}>
    const byLabel = new Map(index.map((z) => [`${z.marca} ${z.modelo}`, z]));
    let current = index.find((z) => z.slug === defSlug) ?? index[0];

    const $ = (id) => document.getElementById(id);
    const search = $("cost-search");

    function recompute() {
      const semana = Number($("in-semana").value);
      const outdoor = Number($("in-outdoor").value);
      $("out-semana").textContent = semana;
      $("out-outdoor").textContent = outdoor + "%";

      const retroBox = $("cr-retro");
      retroBox.classList.toggle("hidden", !current.retro);

      const vidaBaseIndoor = current.dura * 35;
      const outdoorFrac = outdoor / 100;
      const desgasteMedio = (1 - outdoorFrac) * 1 + outdoorFrac * 2.5;
      const partidos = Math.round(vidaBaseIndoor / desgasteMedio);
      const meses = semana > 0 ? partidos / (semana * 4.33) : 0;
      const coste = partidos > 0 ? current.precio / partidos : 0;
      const partidos6m = semana * 4.33 * 6;
      const desgaste6m = Math.min(100, Math.round((partidos6m / partidos) * 100));

      const verdict = coste < 0.5 ? ["Chollo. Se amortiza sola.", "#4ade80"]
        : coste < 1.2 ? ["Compra sensata.", "#f97316"]
        : coste < 2.5 ? ["Cara por partido.", "#facc15"]
        : ["Solo si la exprimes.", "#ef4444"];
      const gColor = desgaste6m < 50 ? "#4ade80" : desgaste6m < 85 ? "#facc15" : "#ef4444";

      $("out-coste").textContent = coste.toFixed(2) + "€";
      $("out-veredicto").textContent = verdict[0];
      $("out-veredicto").style.color = verdict[1];
      $("out-partidos").textContent = partidos;
      $("out-vida").textContent = meses.toFixed(0) + "m";
      $("out-precio").textContent = Math.round(current.precio) + "€";
      $("out-desgaste").textContent = desgaste6m + "%";
      $("out-desgaste").style.color = gColor;
      $("out-desgaste-bar").style.width = desgaste6m + "%";
      $("out-desgaste-bar").style.background = gColor;
      $("cr-cta").href = `/zapatilla/${current.slug}`;
    }

    search.addEventListener("change", () => {
      const match = byLabel.get(search.value);
      if (match) { current = match; recompute(); }
    });
    $("in-semana").addEventListener("input", recompute);
    $("in-outdoor").addEventListener("input", recompute);

    // Deep-link ?slug=
    const urlSlug = new URLSearchParams(location.search).get("slug");
    if (urlSlug) {
      const m = index.find((z) => z.slug === urlSlug);
      if (m) { current = m; search.value = `${m.marca} ${m.modelo}`; }
    }
    recompute();
  </script>

  <style>.hidden { display: none !important; }</style>
</Base>
