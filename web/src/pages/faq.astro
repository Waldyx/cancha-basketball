---
// /faq — rediseñado coherente con el resto
import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";

const faqs = [
  {
    q: "¿Qué zapatillas de baloncesto son mejores para pívots?",
    a: "Para pívots se recomiendan zapatillas con alta amortiguación (cushion 8+), altura mid o high para soporte de tobillo, y buena estabilidad lateral. Opciones top: Nike LeBron 22, Nike LeBron Witness 9, New Balance Fresh Foam BB v3. Lo prioritario es el cushion y el soporte lateral para los contactos en la pintura.",
  },
  {
    q: "¿Cuál es la mejor zapatilla de baloncesto para exterior (outdoor)?",
    a: "Para outdoor necesitas una suela de goma robusta con score de durabilidad outdoor 7+. Asequibles: Adidas Cross Em Up Select, Nike Precision 8, Decathlon Tarmak Voltzy 500. Premium: Nike KD 17, Jordan Luka 3.",
  },
  {
    q: "¿Qué zapatillas de baloncesto son buenas para menos de 80€?",
    a: "Sub-80€ con excelentes opciones: Decathlon Tarmak Voltzy 500 (~€50), Adidas Ownthegame 2.0 (~€55), Nike Precision 8 (~€70), Adidas Cross Em Up Select (~€60), Puma MB.03 (~€75). No necesitas gastar más para jugar bien.",
  },
  {
    q: "¿Debo elegir zapatillas low, mid o high?",
    a: "Depende de tu posición y de si tienes problemas de tobillo. Low: guards explosivos que priorizan velocidad (Anta KAI 1 Speed, Nike GT Cut 3). Mid: la opción más versátil. High: pívots o jugadores con historial de esguinces (Nike LeBron 22). Con lesiones de tobillo previas, evita las low.",
  },
  {
    q: "¿Cuánto debo gastar en zapatillas de baloncesto?",
    a: "Recreativo: 50–80€. Federado amateur: 80–130€. Jugadores exigentes: 130–200€. El precio no siempre correlaciona con rendimiento — la Decathlon Voltzy 500 (€50) supera en outdoor a zapas de €150.",
  },
  {
    q: "¿Diferencia entre zapatillas indoor y outdoor?",
    a: "Las indoor tienen suelas de goma más blanda (mejor tracción en parqué, menos durable en asfalto). Las outdoor llevan goma más gruesa pero pueden resbalar en interior. Las \"todo terreno\" como la Nike Precision 8 funcionan bien en ambas a menor coste.",
  },
  {
    q: "¿Las zapatillas de baloncesto sirven para el día a día?",
    a: "Técnicamente sí, pero no es lo ideal. Las suelas de goma indoor se desgastan rápido en asfalto, y perderás rendimiento en cancha. Si juegas regularmente, reserva tus zapas para el entrenamiento.",
  },
  {
    q: "¿Qué zapatilla protege mejor las rodillas?",
    a: "Para proteger las rodillas necesitas máxima amortiguación. Score de cushion 8+: Nike LeBron 22 (Air Max + Zoom), Nike LeBron Witness 9, New Balance Fresh Foam BB v3. Evita cushion menor de 6 si tienes problemas de rodilla.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---

<Base
  title="Preguntas frecuentes sobre zapatillas de baloncesto | CANCHA.ZAPA"
  description="Resolvemos las dudas más comunes sobre cómo elegir zapatillas de baloncesto: presupuesto, posición, indoor vs outdoor y más."
  jsonLd={jsonLd}
>
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/quiz">Quiz</a>
                  <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <section class="doc-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Preguntas frecuentes</p>
        <h1 class="doc-h1">
          Todo lo que<br/>
          <span class="accent">necesitas</span><br/>
          saber
        </h1>
        <p class="doc-lede">
          Las dudas más habituales antes de comprar zapatillas de baloncesto.
          Sin rollos, respuestas directas.
        </p>
      </div>
    </section>

    <article class="doc-article">
      <div class="shell shell-narrow">
        <div class="faq-list">
          {faqs.map(({ q, a }, i) => (
            <details class="faq-item">
              <summary>
                <span class="faq-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="faq-q">{q}</span>
                <span class="faq-toggle">
                  <span class="plus">+</span>
                  <span class="minus">−</span>
                </span>
              </summary>
              <div class="faq-a">{a}</div>
            </details>
          ))}
        </div>

        <aside class="doc-cta-box">
          <div>
            <p class="doc-cta-title">¿No encuentras tu respuesta?</p>
            <p class="doc-cta-sub">Usa el quiz para encontrar tu zapatilla perfecta. 60 segundos.</p>
          </div>
          <a href="/quiz" class="home-btn primary">Hacer el quiz →</a>
        </aside>
      </div>
    </article>

  </main>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Base>
