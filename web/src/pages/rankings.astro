---
// /rankings — rankings rediseñado
// Drop-in replacement for web/src/pages/rankings.astro

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
import { zapatillas } from "../data/zapatillas";
import { findMejorPrecio } from "../lib/scoring";

const CAT_LABELS: Record<string, string> = {
  "cushion-focused": "Cushion", "responsive": "Reactiva",
  "balanced": "Equilibrada", "traction-king": "Tracción",
};
const CAT_ACCENT: Record<string, string> = {
  "cushion-focused": "#38bdf8", "responsive": "#facc15",
  "balanced": "#d4d4d8", "traction-king": "#fb923c",
};

const scoreOf = (z: typeof zapatillas[0]): number => {
  const v = Object.values(z.puntuaciones);
  return Math.round((v.reduce((a, b) => a + b, 0) / v.length) * 10) / 10;
};

// 7 ranking categories. The page renders all 7, hidden by JS toggle.
const RANKINGS = [
  { id: "global",    label: "Mejor global",    key: null,                    blurb: "Score medio más alto: las que hacen todo bien." },
  { id: "traccion",  label: "Mejor tracción",  key: "traccion" as const,     blurb: "El grip que necesitas en pista exterior." },
  { id: "cushion",   label: "Más cushion",     key: "amortiguacion" as const,blurb: "Para rodillas, tobillos y jugadores >85kg." },
  { id: "respuesta", label: "Más reactivas",   key: "respuesta" as const,    blurb: "Court feel premium. Para guardias rápidos." },
  { id: "outdoor",   label: "Outdoor",         key: "durabilidad_outdoor" as const, blurb: "Aguantan asfalto sin gastarse." },
  { id: "ligera",    label: "Más ligeras",     key: "peso_score" as const,   blurb: "Menos de 350g. Vuelas." },
];

function sortBy(key: keyof typeof zapatillas[0]["puntuaciones"] | null) {
  const arr = [...zapatillas];
  if (key) return arr.sort((a, b) => b.puntuaciones[key] - a.puntuaciones[key]);
  return arr.sort((a, b) => scoreOf(b) - scoreOf(a));
}
---

<Base title="Top 10 Mejores Zapatillas de Baloncesto 2026 | Rankings CANCHA.ZAPA"
      description="Rankings de las mejores zapatillas de baloncesto: mejor tracción, más cushion, más reactivas, para exterior y más ligeras. Actualizado 2026.">
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo">CANCHA<span class="dot">.</span>ZAPA</a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a>
          <a href="/rankings" class="active">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    {/* Hero — title changes per active ranking */}
    <section class="rk-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Rankings · Top 10</p>
        <h1 class="rk-h1">Las mejores<br/><span class="rk-h1-cat" id="rk-title">mejor global</span></h1>
        <p class="rk-blurb" id="rk-blurb">{RANKINGS[0].blurb}</p>
      </div>
    </section>

    {/* Tabs */}
    <nav class="rk-tabs">
      <div class="shell rk-tabs-inner">
        {RANKINGS.map((r, i) => (
          <button class={`rk-tab ${i === 0 ? "is-active" : ""}`} data-rk={r.id}>{r.label}</button>
        ))}
      </div>
    </nav>

    {/* Rankings — one block per category, hidden except active */}
    {RANKINGS.map((r, i) => {
      const sorted = sortBy(r.key);
      const [first, second, third, ...rest] = sorted.slice(0, 10);
      return (
        <div class={`rk-panel ${i === 0 ? "" : "hidden"}`} data-rk-panel={r.id} data-blurb={r.blurb} data-label={r.label}>
          <section class="rk-podium">
            <div class="shell">
              <div class="rk-podium-grid">
                {[second, first, third].map((z, idx) => {
                  if (!z) return null;
                  const rank = idx === 1 ? 1 : idx === 0 ? 2 : 3;
                  const isFirst = rank === 1;
                  const cat = CAT_ACCENT[z.categoria_principal];
                  const sc = scoreOf(z);
                  const metric = r.key ? z.puntuaciones[r.key] : sc;
                  const mp = findMejorPrecio(z.links_compra);
                  return (
                    <article class={`rk-pod ${isFirst ? "primary" : ""}`} style={`--cat:${cat}`}>
                      <div class="rk-pod-rank">
                        <span class="rkpr-num">{rank}</span>
                        {isFirst && <span class="rkpr-crown">★ Nº 1</span>}
                      </div>
                      <div class="rk-pod-photo">
                        <img src={z.imagen_principal} alt={`${z.marca} ${z.modelo}`} onerror="this.style.display='none'" />
                      </div>
                      <div class="rk-pod-body">
                        <p class="rk-pod-cat">{CAT_LABELS[z.categoria_principal]}</p>
                        <p class="rk-pod-marca">{z.marca}</p>
                        <h2 class="rk-pod-modelo">{z.modelo}</h2>
                        <div class="rk-pod-metric">
                          <span class="rkpm-num">{metric}<small>/10</small></span>
                          <span class="rkpm-lab">{r.label.replace(/^(Mejor |Más )/,"")}</span>
                        </div>
                        <div class="rk-pod-foot">
                          <span class="rk-pod-price">{Math.round(mp?.precio_actual ?? z.precio_msrp_eur)}€</span>
                          <a href={`/zapatilla/${z.slug}`} class="rk-pod-cta">Ver →</a>
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          </section>

          <section class="rk-list">
            <div class="shell">
              <div class="rk-list-head">
                <span>#</span>
                <span>Zapatilla</span>
                <span class="hide-sm">Categoría</span>
                <span>{r.key ? r.label.replace(/^(Mejor |Más )/,"") : "Score"}</span>
                <span>Precio</span>
                <span></span>
              </div>
              {rest.map((z, i) => {
                const cat = CAT_ACCENT[z.categoria_principal];
                const sc = scoreOf(z);
                const metric = r.key ? z.puntuaciones[r.key] : sc;
                const mp = findMejorPrecio(z.links_compra);
                return (
                  <a href={`/zapatilla/${z.slug}`} class="rk-row" style={`--cat:${cat}`}>
                    <span class="rk-row-rank">#{i + 4}</span>
                    <span class="rk-row-shoe">
                      <span class="rk-row-thumb">
                        <img src={z.imagen_principal} alt="" onerror="this.style.display='none'" />
                      </span>
                      <span class="rk-row-name">
                        <span class="rkrn-marca">{z.marca}</span>
                        <span class="rkrn-modelo">{z.modelo}</span>
                      </span>
                    </span>
                    <span class="rk-row-cat hide-sm" style={`color:${cat}`}>{CAT_LABELS[z.categoria_principal]}</span>
                    <span class="rk-row-metric">{metric}<small>/10</small></span>
                    <span class="rk-row-price">{Math.round(mp?.precio_actual ?? z.precio_msrp_eur)}€</span>
                    <span class="rk-row-arrow">→</span>
                  </a>
                );
              })}
            </div>
          </section>
        </div>
      );
    })}

  </main>

  <script>
    const $tabs = document.querySelectorAll<HTMLButtonElement>(".rk-tab");
    const $panels = document.querySelectorAll<HTMLElement>("[data-rk-panel]");
    const $title = document.getElementById("rk-title")!;
    const $blurb = document.getElementById("rk-blurb")!;

    $tabs.forEach(tab => {
      tab.addEventListener("click", () => {
        const id = tab.dataset.rk!;
        $tabs.forEach(t => t.classList.toggle("is-active", t === tab));
        $panels.forEach(p => p.classList.toggle("hidden", p.dataset.rkPanel !== id));
        const panel = document.querySelector<HTMLElement>(`[data-rk-panel="${id}"]`)!;
        $title.textContent = panel.dataset.label!.toLowerCase();
        $blurb.textContent = panel.dataset.blurb!;
      });
    });
  </script>

  <style>.hidden { display: none !important; }</style>
</Base>
