---
import Base from "../layouts/Base.astro";
import { zapatillas } from "../data/zapatillas";

// Top 8 por amortiguación
const topCushion = [...zapatillas]
  .sort((a, b) => b.puntuaciones.amortiguacion - a.puntuaciones.amortiguacion)
  .slice(0, 8);

// Top 8 por respuesta / court feel
const topResponsive = [...zapatillas]
  .sort((a, b) => b.puntuaciones.respuesta - a.puntuaciones.respuesta)
  .slice(0, 8);

// Top 8 por durabilidad outdoor
const topOutdoor = [...zapatillas]
  .sort((a, b) => b.puntuaciones.durabilidad_outdoor - a.puntuaciones.durabilidad_outdoor)
  .slice(0, 8);

// Mejores sub-80€ (ordenadas por precio ascendente)
const topBudget = [...zapatillas]
  .filter((z) => z.precio_msrp_eur <= 80)
  .sort((a, b) => a.precio_msrp_eur - b.precio_msrp_eur)
  .slice(0, 8);

// JSON-LD ItemList para top amortiguación
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Top zapatillas de baloncesto por amortiguación",
  description:
    "Las 8 zapatillas de baloncesto con mayor puntuación en amortiguación según Cancha.",
  numberOfItems: topCushion.length,
  itemListElement: topCushion.map((z, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: `${z.marca} ${z.modelo}`,
    url: `https://web-puce-chi-60.vercel.app/zapatilla/${z.slug}`,
  })),
};
---

<Base
  title="Rankings · Cancha"
  description="Los mejores rankings de zapatillas de baloncesto: top amortiguación, respuesta, outdoor y las mejores opciones por menos de 80€."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://cancha.shoes/"},
        {"@type": "ListItem", "position": 2, "name": "Rankings", "item": "https://cancha.shoes/rankings"}
      ]
    })}
  />

  <main class="min-h-screen text-white">
    <!-- Header -->
    <header
      class="px-6 py-5 border-b border-zinc-800/60 bg-[#0c0c0c]/80 backdrop-blur-sm sticky top-0 z-50"
    >
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="text-2xl font-black tracking-tighter">
          CANCHA<span class="text-orange-500">.</span>
        </a>
        <nav
          class="hidden sm:flex gap-6 text-xs font-bold text-zinc-400 uppercase tracking-widest"
        >
          <a href="/zapatillas" class="hover:text-orange-500 transition-colors"
            >Catálogo</a
          >
          <a href="/metodologia" class="hover:text-orange-500 transition-colors"
            >Método</a
          >
          <a href="/financiacion" class="hover:text-orange-500 transition-colors"
            >$ Financiación</a
          >
          <a href="/faq" class="hover:text-orange-500 transition-colors">FAQ</a>
        </nav>
      </div>
    </header>

    <!-- Hero -->
    <section class="px-6 pt-16 pb-10 border-b border-zinc-800/40">
      <div class="max-w-6xl mx-auto">
        <p class="text-xs font-black uppercase tracking-widest text-orange-500 mb-4">
          ★ Rankings
        </p>
        <h1
          class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.95] mb-4"
        >
          Las mejores<br />
          <span class="text-orange-500">zapatillas</span><br />
          por categoría
        </h1>
        <p class="text-zinc-400 text-lg max-w-xl leading-relaxed">
          Rankings calculados a partir de puntuaciones objetivas. Sin opinión
          de marca, sin afiliados que distorsionen el orden.
        </p>
      </div>
    </section>

    <!-- Rankings -->
    <div class="px-6 py-16">
      <div class="max-w-6xl mx-auto space-y-20">

        <!-- 1. Top Amortiguación -->
        <section>
          <div class="flex items-baseline gap-3 mb-8">
            <span class="text-3xl">🛡️</span>
            <div>
              <h2
                class="text-2xl md:text-3xl font-black uppercase tracking-tighter"
              >
                Top <span class="text-orange-500">amortiguación</span>
              </h2>
              <p class="text-zinc-500 text-sm mt-1">
                Máxima protección de impactos. Ideal para pivots y jugadores con problemas de rodillas.
              </p>
            </div>
          </div>

          <ol class="space-y-3">
            {
              topCushion.map((z, i) => (
                <li class="group">
                  <a
                    href={`/zapatilla/${z.slug}`}
                    class="flex items-center gap-4 bg-zinc-900 border border-zinc-800 hover:border-orange-500/50 transition-colors p-4"
                  >
                    <!-- Rank -->
                    <span
                      class={`text-2xl font-black tracking-tighter w-8 shrink-0 ${i === 0 ? "text-orange-500" : i === 1 ? "text-zinc-300" : i === 2 ? "text-yellow-600" : "text-zinc-600"}`}
                    >
                      {i + 1}
                    </span>

                    <!-- Imagen -->
                    <img
                      src={z.imagen_principal}
                      alt={`${z.marca} ${z.modelo}`}
                      width="48"
                      height="48"
                      class="w-12 h-12 object-contain shrink-0"
                      loading="lazy"
                    />

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">
                        {z.marca}
                      </p>
                      <p class="font-black tracking-tight truncate">{z.modelo}</p>
                    </div>

                    <!-- Score badge -->
                    <div class="shrink-0 text-right">
                      <span class="inline-block bg-orange-500 text-black text-xs font-black px-2 py-1 tracking-widest">
                        {z.puntuaciones.amortiguacion}/10
                      </span>
                    </div>

                    <!-- CTA -->
                    <span class="text-zinc-600 group-hover:text-orange-500 transition-colors font-black text-sm shrink-0">
                      Ver →
                    </span>
                  </a>
                </li>
              ))
            }
          </ol>
        </section>

        <!-- 2. Top Respuesta -->
        <section>
          <div class="flex items-baseline gap-3 mb-8">
            <span class="text-3xl">⚡</span>
            <div>
              <h2
                class="text-2xl md:text-3xl font-black uppercase tracking-tighter"
              >
                Top <span class="text-orange-500">respuesta</span>
              </h2>
              <p class="text-zinc-500 text-sm mt-1">
                Máximo court feel y reactividad. Para bases y escoltas explosivos.
              </p>
            </div>
          </div>

          <ol class="space-y-3">
            {
              topResponsive.map((z, i) => (
                <li class="group">
                  <a
                    href={`/zapatilla/${z.slug}`}
                    class="flex items-center gap-4 bg-zinc-900 border border-zinc-800 hover:border-orange-500/50 transition-colors p-4"
                  >
                    <span
                      class={`text-2xl font-black tracking-tighter w-8 shrink-0 ${i === 0 ? "text-orange-500" : i === 1 ? "text-zinc-300" : i === 2 ? "text-yellow-600" : "text-zinc-600"}`}
                    >
                      {i + 1}
                    </span>
                    <img
                      src={z.imagen_principal}
                      alt={`${z.marca} ${z.modelo}`}
                      width="48"
                      height="48"
                      class="w-12 h-12 object-contain shrink-0"
                      loading="lazy"
                    />
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">
                        {z.marca}
                      </p>
                      <p class="font-black tracking-tight truncate">{z.modelo}</p>
                    </div>
                    <div class="shrink-0 text-right">
                      <span class="inline-block bg-orange-500 text-black text-xs font-black px-2 py-1 tracking-widest">
                        {z.puntuaciones.respuesta}/10
                      </span>
                    </div>
                    <span class="text-zinc-600 group-hover:text-orange-500 transition-colors font-black text-sm shrink-0">
                      Ver →
                    </span>
                  </a>
                </li>
              ))
            }
          </ol>
        </section>

        <!-- 3. Top Outdoor -->
        <section>
          <div class="flex items-baseline gap-3 mb-8">
            <span class="text-3xl">🏀</span>
            <div>
              <h2
                class="text-2xl md:text-3xl font-black uppercase tracking-tighter"
              >
                Top <span class="text-orange-500">outdoor</span>
              </h2>
              <p class="text-zinc-500 text-sm mt-1">
                Mayor durabilidad en asfalto y pistas exteriores. Para los que juegan en la calle.
              </p>
            </div>
          </div>

          <ol class="space-y-3">
            {
              topOutdoor.map((z, i) => (
                <li class="group">
                  <a
                    href={`/zapatilla/${z.slug}`}
                    class="flex items-center gap-4 bg-zinc-900 border border-zinc-800 hover:border-orange-500/50 transition-colors p-4"
                  >
                    <span
                      class={`text-2xl font-black tracking-tighter w-8 shrink-0 ${i === 0 ? "text-orange-500" : i === 1 ? "text-zinc-300" : i === 2 ? "text-yellow-600" : "text-zinc-600"}`}
                    >
                      {i + 1}
                    </span>
                    <img
                      src={z.imagen_principal}
                      alt={`${z.marca} ${z.modelo}`}
                      width="48"
                      height="48"
                      class="w-12 h-12 object-contain shrink-0"
                      loading="lazy"
                    />
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">
                        {z.marca}
                      </p>
                      <p class="font-black tracking-tight truncate">{z.modelo}</p>
                    </div>
                    <div class="shrink-0 text-right">
                      <span class="inline-block bg-orange-500 text-black text-xs font-black px-2 py-1 tracking-widest">
                        {z.puntuaciones.durabilidad_outdoor}/10
                      </span>
                    </div>
                    <span class="text-zinc-600 group-hover:text-orange-500 transition-colors font-black text-sm shrink-0">
                      Ver →
                    </span>
                  </a>
                </li>
              ))
            }
          </ol>
        </section>

        <!-- 4. Mejores sub-80€ -->
        <section>
          <div class="flex items-baseline gap-3 mb-8">
            <span class="text-3xl">💰</span>
            <div>
              <h2
                class="text-2xl md:text-3xl font-black uppercase tracking-tighter"
              >
                Mejores <span class="text-orange-500">sub-80€</span>
              </h2>
              <p class="text-zinc-500 text-sm mt-1">
                {topBudget.length > 0
                  ? `Las ${topBudget.length} opciones más asequibles del catálogo, ordenadas por precio.`
                  : "De momento no hay zapatillas por debajo de 80€ en el catálogo."}
              </p>
            </div>
          </div>

          {topBudget.length > 0 ? (
            <ol class="space-y-3">
              {topBudget.map((z, i) => (
                <li class="group">
                  <a
                    href={`/zapatilla/${z.slug}`}
                    class="flex items-center gap-4 bg-zinc-900 border border-zinc-800 hover:border-orange-500/50 transition-colors p-4"
                  >
                    <span
                      class={`text-2xl font-black tracking-tighter w-8 shrink-0 ${i === 0 ? "text-orange-500" : i === 1 ? "text-zinc-300" : i === 2 ? "text-yellow-600" : "text-zinc-600"}`}
                    >
                      {i + 1}
                    </span>
                    <img
                      src={z.imagen_principal}
                      alt={`${z.marca} ${z.modelo}`}
                      width="48"
                      height="48"
                      class="w-12 h-12 object-contain shrink-0"
                      loading="lazy"
                    />
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">
                        {z.marca}
                      </p>
                      <p class="font-black tracking-tight truncate">{z.modelo}</p>
                    </div>
                    <div class="shrink-0 text-right">
                      <span class="inline-block bg-green-600 text-white text-xs font-black px-2 py-1 tracking-widest">
                        {z.precio_msrp_eur}€
                      </span>
                    </div>
                    <span class="text-zinc-600 group-hover:text-orange-500 transition-colors font-black text-sm shrink-0">
                      Ver →
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          ) : (
            <div class="bg-zinc-900 border border-zinc-800 p-8 text-center">
              <p class="text-zinc-500 text-sm">
                El catálogo crece continuamente. Vuelve pronto.
              </p>
            </div>
          )}
        </section>

      </div>
    </div>

    <!-- Footer -->
    <footer class="px-6 py-10 bg-black border-t-4 border-orange-500 mt-16">
      <div
        class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4"
      >
        <p class="text-2xl font-black tracking-tighter">
          CANCHA<span class="text-orange-500">.</span>
        </p>
        <nav
          class="flex gap-6 text-xs font-bold text-zinc-400 uppercase tracking-widest flex-wrap justify-center"
        >
          <a href="/zapatillas" class="hover:text-orange-500 transition-colors"
            >Catálogo</a
          >
          <a href="/quiz" class="hover:text-orange-500 transition-colors"
            >Quiz</a
          >
          <a href="/metodologia" class="hover:text-orange-500 transition-colors"
            >Metodología</a
          >
          <a href="/financiacion" class="hover:text-orange-500 transition-colors"
            >Financiación</a
          >
          <a href="/faq" class="hover:text-orange-500 transition-colors">FAQ</a>
        </nav>
        <p
          class="text-xs text-zinc-600 uppercase tracking-widest text-center"
        >
          Proyecto independiente · Sin sesgo de afiliado
        </p>
      </div>
    </footer>
  </main>
</Base>
