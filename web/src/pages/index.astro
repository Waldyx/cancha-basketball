---
import Base from "../layouts/Base.astro";
import { zapatillas } from "../data/zapatillas";
import { findMejorPrecio } from "../lib/scoring";

// Zapas destacadas hardcoded
const slugsDestacadas = ["nike-lebron-22", "anta-kai-1-speed", "adidas-ae-4"];
const zapasDestacadas = slugsDestacadas
  .map((s) => zapatillas.find((z) => z.slug === s))
  .filter(Boolean) as (typeof zapatillas)[0][];

// Top 3 por score global — priorizando zapas con precio verificado en España
function scoreGlobal(z: (typeof zapatillas)[0]): number {
  const vals = Object.values(z.puntuaciones);
  return vals.reduce((a, b) => a + b, 0) / vals.length;
}

// Separar zapas con precio en tienda española verificado vs solo editorial
const conPrecioLive = zapatillas.filter((z) => {
  const mejor = findMejorPrecio(z.links_compra);
  return mejor !== undefined;
});
const sinPrecioLive = zapatillas.filter((z) => {
  const mejor = findMejorPrecio(z.links_compra);
  return mejor === undefined;
});

// Top 3: primero las que tienen precio verificado, luego el resto por score
const ranked = [
  ...conPrecioLive.sort((a, b) => scoreGlobal(b) - scoreGlobal(a)),
  ...sinPrecioLive.sort((a, b) => scoreGlobal(b) - scoreGlobal(a)),
];
const top3 = ranked.slice(0, 3);
