---
// / — Home rediseñada
// Drop-in replacement for web/src/pages/index.astro

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
import { zapatillas } from "../data/zapatillas";
import { findMejorPrecio } from "../lib/scoring";
import { getAllArticles } from "../lib/articles";

function scoreOf(z: typeof zapatillas[0]): number {
  const v = Object.values(z.puntuaciones);
  return Math.round((v.reduce((a, b) => a + b, 0) / v.length) * 10) / 10;
}

// EDITOR'S PICK — la nº1 con verified discount, fallback a la mejor score global
const conDescuento = zapatillas
  .map(z => {
    const mp = findMejorPrecio(z.links_compra);
    return { z, mp, score: scoreOf(z) };
  })
  .filter(x => x.mp && x.mp.precio_actual < x.z.precio_msrp_eur);

const editorPick = (conDescuento.length > 0
  ? conDescuento.sort((a, b) => b.score - a.score)[0]
  : { z: zapatillas[0], mp: findMejorPrecio(zapatillas[0].links_compra), score: scoreOf(zapatillas[0]) });

// Top 3 — score con preferencia por precio verificado
const conPrecio = zapatillas.filter(z => findMejorPrecio(z.links_compra)).sort((a, b) => scoreOf(b) - scoreOf(a));
const sinPrecio = zapatillas.filter(z => !findMejorPrecio(z.links_compra)).sort((a, b) => scoreOf(b) - scoreOf(a));
const top3 = [...conPrecio, ...sinPrecio].slice(0, 3);
const trendingHero = [...conPrecio, ...sinPrecio].slice(0, 5);

const marcas = [...new Set(zapatillas.map(z => z.marca))];

const CAT_LABELS: Record<string, string> = {
  "cushion-focused": "Cushion", "responsive": "Reactiva",
  "balanced": "Equilibrada", "traction-king": "Tracción",
};
const CAT_ACCENT: Record<string, string> = {
  "cushion-focused": "#38bdf8", "responsive": "#facc15",
  "balanced": "#d4d4d8", "traction-king": "#fb923c",
};

const today = new Date().toLocaleDateString("es-ES", { day: "2-digit", month: "short" }).toUpperCase();
const recentArticles = getAllArticles().slice(0, 3);
const BLOG_CAT_COLOR: Record<string, string> = { "Guías": "#f97316", "Comparativas": "#facc15", "Análisis": "#38bdf8" };

const pickAhorro = editorPick.mp && editorPick.mp.precio_actual < editorPick.z.precio_msrp_eur
  ? editorPick.z.precio_msrp_eur - editorPick.mp.precio_actual : 0;
---

<Base title="CANCHA.ZAPA — Tu zapatilla de baloncesto, sin BS"
      description="Quiz gratuito y comparador honesto de zapatillas de baloncesto. 5 recomendaciones a medida, precios verificados en tiendas españolas.">
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a> <a href="/comparar">Comparar</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
                  <a href="/balones">Accesorios</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    {/* HERO */}
    <section class="home-hero">
      <div class="home-hero-bg" aria-hidden="true">
        <img src="/bg-court.svg" alt="" />
      </div>
      <div class="shell home-hero-inner">
        <div class="home-hero-grid">
          <div class="home-hero-left">
<h1 class="home-h1">
              Tu zapa<br/>
              <span class="accent italic">perfecta</span><br/>
              está aquí
            </h1>
            <p class="home-lede">
              Cuéntanos cómo juegas. Te decimos las <strong>5 zapatillas</strong> que mejor encajan contigo
              y dónde están al mejor precio. <span class="muted italic">Sin sesgo. Sin BS.</span>
            </p>
            <div class="home-cta-row">
              <a href="/quiz" class="home-btn primary">→ Empezar el quiz</a>
              <a href="/zapatillas" class="home-btn ghost">Catálogo</a>
              <a href="/rankings" class="home-btn ghost">Rankings</a>
              <a href="/comparar" class="home-btn ghost">Comparar</a>
            </div>
            <p class="home-cta-foot">Gratis · sin registro · 100% honestos</p>
          </div>

          <div class="home-hero-media" aria-hidden="true">
            <video src="/hero-cancha.mp4" poster="/hero-cancha-poster.jpg"
                   autoplay muted loop playsinline preload="metadata"
                   onerror="this.closest('.home-hero-media').style.display='none'"></video>
          </div>

          <aside class="home-hero-panel">
            <div class="panel-header">
              <span class="dot-pulse"></span>
              <span>RADAR EN VIVO</span>
            </div>
            <div class="panel-grid">
              <div class="stat"><div class="v">{zapatillas.length}</div><div class="k">zapas</div></div>
              <div class="stat"><div class="v">{marcas.length}</div><div class="k">marcas</div></div>
              <div class="stat"><div class="v">15<small>+</small></div><div class="k">tiendas</div></div>
              <div class="stat"><div class="v">100<small>%</small></div><div class="k">honesto</div></div>
            </div>
            <div class="panel-ticker">
              <div class="ticker-label">★ Trending hoy</div>
              {trendingHero.map(z => (
                <div class="ticker-row">
                  <span class="t-rank">{scoreOf(z)}</span>
                  <span class="t-name"><strong>{z.marca}</strong> {z.modelo}</span>
                  <span class="t-price">{Math.round(findMejorPrecio(z.links_compra)?.precio_actual ?? z.precio_msrp_eur)}€</span>
                </div>
              ))}
              <a href="/rankings" class="panel-ranklink">Ver rankings completos →</a>
            </div>
          </aside>
        </div>

        <div class="hero-match" style="margin-top:36px">
          <span><span class="dot-orange"></span>Precios re-verificados {today}</span>
          <span class="sep">·</span>
          <span>Sin sesgo de afiliado</span>
          <span class="sep">·</span>
          <span>{zapatillas.length} zapatillas</span>
        </div>
      </div>
    </section>

    {/* EDITOR'S PICK — full-width like the catalog */}
    <section class="home-pick-section">
      <div class="shell">
        <article class="cz-pick" style={`--cat:${CAT_ACCENT[editorPick.z.categoria_principal]}`}>
          <div class="pick-photo">
            <span class="pick-watermark">★ PICK</span>
            <img src={editorPick.z.imagen_principal} alt={`${editorPick.z.marca} ${editorPick.z.modelo}`}
                 onerror="this.style.display='none'" />
          </div>
          <div class="pick-body">
            <div class="pick-eyebrow">
              <span class="pick-tag">★ Pick del editor</span>
              <span class="pick-cat">{CAT_LABELS[editorPick.z.categoria_principal]}</span>
              {editorPick.z.año_lanzamiento >= 2025 && <span class="pick-new">Nueva {editorPick.z.año_lanzamiento}</span>}
            </div>
            <h2 class="pick-title">
              <span class="pick-marca">{editorPick.z.marca}</span>
              <span class="pick-modelo">{editorPick.z.modelo}</span>
            </h2>
            <p class="pick-verdict">{editorPick.z.veredicto}</p>
            <div class="pick-stats">
              <div class="ps"><div class="psv">{editorPick.score.toFixed(1)}<small>/10</small></div><div class="psk">Score global</div></div>
              <div class="ps"><div class="psv">{editorPick.z.peso_real_g}<small>g</small></div><div class="psk">Peso (US 9)</div></div>
              <div class="ps"><div class="psv">{editorPick.z.puntuaciones.traccion}<small>/10</small></div><div class="psk">Tracción</div></div>
              <div class="ps"><div class="psv">{editorPick.z.puntuaciones.amortiguacion}<small>/10</small></div><div class="psk">Cushion</div></div>
            </div>
            <div class="pick-foot">
              <div class="pick-price">
                <div class="pp-now">{Math.round(editorPick.mp?.precio_actual ?? editorPick.z.precio_msrp_eur)}€</div>
                {pickAhorro > 0 && (
                  <div class="pp-meta">
                    <span class="msrp">msrp {editorPick.z.precio_msrp_eur}€</span>
                    <span class="save">−{Math.round(pickAhorro)}€</span>
                  </div>
                )}
                <div class="pp-tienda"><span class="dot"></span>{editorPick.mp ? "Verificado" : "Editorial"}</div>
              </div>
              <div class="pick-actions">
                <a class="pick-btn primary" href={`/zapatilla/${editorPick.z.slug}`}>Ver review →</a>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    {/* CÓMO FUNCIONA */}
    <section class="home-how">
      <div class="shell">
        <div class="home-section-head">
          <span class="home-rule"></span>
          <h2 class="home-h2">Cómo<span class="dot">.</span>funciona</h2>
          <span class="home-rule"></span>
        </div>

        <div class="home-how-grid">
          {[
            { n: "01", lab: "Tu juego", body: "Posición, peso, estilo, presupuesto, dolencias. <strong>10 preguntas</strong> en menos de un minuto.", icon: "🏀", col: "#f97316" },
            { n: "02", lab: "Tu match", body: "Las <strong>5 zapas</strong> con mayor compatibilidad técnica, con explicación de por qué encajan contigo.", icon: "⚡", col: "#facc15" },
            { n: "03", lab: "Tu precio", body: "Comparador lado a lado y <strong>mejor precio actual</strong> entre tiendas. Tú decides dónde comprar.", icon: "€", col: "#f97316" },
          ].map(s => (
            <article class="home-how-card" style={`--col:${s.col}`}>
              <div class="hhc-head">
                <span class="hhc-glyph">{s.icon}</span>
                <span class="hhc-num">{s.n}</span>
              </div>
              <h3 class="hhc-title">{s.lab}</h3>
              <p class="hhc-body" set:html={s.body}></p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* SHORTCUTS por posición */}
    <section class="home-shortcuts">
      <div class="shell">
        <p class="cz-eyebrow">★ Por dónde quieres empezar</p>
        <h2 class="home-h2-sm">Filtra por tu posición</h2>
        <div class="home-shortcut-grid">
          {[
            { posicion: "base",     cat: "responsive",      label: "Base",     desc: "Reactivas, ligeras" },
            { posicion: "alero",    cat: "balanced",        label: "Alero",    desc: "Equilibradas, versátiles" },
            { posicion: "pivot",    cat: "cushion-focused", label: "Pívot",    desc: "Cushion + soporte" },
            { posicion: "exterior", cat: "traction-king",   label: "Outdoor",  desc: "Durables, tracción" },
          ].map(({ posicion, cat, label, desc }) => (
            <a href={posicion === "exterior" ? "/zapatillas?cancha=exterior" : `/zapatillas?posicion=${posicion}`}
               class="home-shortcut" style={`--cat:${CAT_ACCENT[cat]}`}>
              <span class="hsc-cat">{CAT_LABELS[cat]}</span>
              <span class="hsc-label">{label}</span>
              <span class="hsc-desc">{desc}</span>
              <span class="hsc-arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* TOP 3 BBDD */}
    <section class="home-top3">
      <div class="shell">
        <p class="cz-eyebrow">★ Precio verificado · Mejor valoradas</p>
        <h2 class="home-h2-sm">
          El <span class="accent">top 3</span> de la base de datos
        </h2>
        <p class="home-sub">
          Las zapatillas con mayor puntuación técnica agregada.
          Para una recomendación personalizada, <a href="/quiz">usa el quiz →</a>
        </p>

        <div class="home-top3-grid">
          {top3.map((z, i) => {
            const mejor = findMejorPrecio(z.links_compra);
            const precio = mejor?.precio_actual ?? z.precio_msrp_eur;
            const score = scoreOf(z);
            const cat = CAT_ACCENT[z.categoria_principal];
            return (
              <a href={`/zapatilla/${z.slug}`} class="home-t3-card" style={`--cat:${cat}`}>
                <div class="ht3-photo">
                  <span class="ht3-rank">#{i + 1}</span>
                  <span class="ht3-score">{score}</span>
                  <img src={z.imagen_principal} alt={`${z.marca} ${z.modelo}`} loading="eager"
                       onerror="this.style.display='none'" />
                </div>
                <div class="ht3-body">
                  <p class="ht3-marca">{z.marca}</p>
                  <h3 class="ht3-modelo">{z.modelo}</h3>
                  <div class="ht3-foot">
                    <span class="ht3-price">{Math.round(precio)}€</span>
                    <span class="ht3-arrow">Ver →</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <div class="home-top3-cta">
          <a href="/zapatillas" class="home-btn ghost">Ver las {zapatillas.length} zapatillas →</a>
        </div>
      </div>
    </section>

    {/* BLOG RECIENTE */}
    <section class="home-top3">
      <div class="shell">
        <p class="cz-eyebrow">★ Guías y análisis · Blog</p>
        <h2 class="home-h2-sm">
          Lo más <span class="accent">reciente</span>
        </h2>
        <div class="home-top3-grid">
          {recentArticles.map(art => (
              <a href={`/blog/${art.slug}`} class="home-t3-card home-t3-article" style="--cat:#f97316">
                <div class="ht3-body">
                  <div class="ht3-tags">
                    <span class="ht3-cat" style={`background:${BLOG_CAT_COLOR[art.categoria] ?? "#f97316"}`}>{art.categoria}</span>
                    <span class="ht3-min">{art.readMinutes} min</span>
                  </div>
                  <h3 class="ht3-modelo" style="font-size:18px;line-height:1.2">{art.title}</h3>
                  <p class="ht3-desc">{art.description}</p>
                  <div class="ht3-foot">
                    <span class="ht3-date">{art.fechaLabel}</span>
                    <span class="ht3-arrow">Leer →</span>
                  </div>
                </div>
              </a>
          ))}
        </div>
        <div class="home-top3-cta">
          <a href="/blog" class="home-btn ghost">Ver todos los artículos →</a>
        </div>
      </div>
    </section>

    {/* MANIFIESTO */}
    <section class="home-manifest">
      <div class="shell">
        <div class="hm-card">
          <p class="cz-eyebrow">★ Manifiesto</p>
          <h3 class="hm-h3">
            No te vendemos.
            <span class="muted">Te ayudamos a elegir.</span>
          </h3>
          <p class="hm-body">
            La mayoría de webs de zapatillas te empujan al modelo que más comisión paga.
            Nosotros no. El ranking sale del quiz, no del cheque de la marca.
            Si la zapa que mejor te va está en una tienda que no nos paga, la mostramos arriba igualmente.
          </p>
          <a href="/financiacion" class="hm-link">Lee cómo nos financiamos →</a>
        </div>
      </div>
    </section>

    {/* GUÍAS POR PERFIL */}
    <section style="padding:48px 0 64px;border-top:1px solid #27272a">
      <div class="shell">
        <p class="cz-eyebrow" style="margin-bottom:16px">★ Guías por perfil</p>
        <h2 class="home-h2-sm" style="margin-bottom:28px">
          Encuentra tu <span class="accent">zapatilla</span>
        </h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px">
          {[
            { href: "/mejor-zapatilla-base", label: "Para bases", icon: "⚡" },
            { href: "/mejor-zapatilla-escolta", label: "Para escoltas", icon: "🏀" },
            { href: "/mejor-zapatilla-alero", label: "Para aleros", icon: "🔄" },
            { href: "/mejor-zapatilla-ala-pivot", label: "Para ala-pívots", icon: "🏋️" },
            { href: "/mejor-zapatilla-pivot", label: "Para pívots", icon: "💪" },
            { href: "/zapatillas-outdoor", label: "Para exterior", icon: "☀️" },
            { href: "/zapatillas-baloncesto-baratas", label: "Económicas", icon: "💰" },
            { href: "/zapatillas-baloncesto-para-rodillas", label: "Rodillas sensibles", icon: "🦵" },
            { href: "/zapatillas-baloncesto-para-tobillos", label: "Soporte tobillo", icon: "🩼" },
            { href: "/zapatillas-baloncesto-pie-ancho", label: "Pie ancho", icon: "👟" },
            { href: "/zapatillas-baloncesto-mujer", label: "Para mujer", icon: "⭐" },
            { href: "/zapatillas-baloncesto-junior", label: "Para junior", icon: "🌱" },
            { href: "/mejores-zapatillas-baloncesto-2025", label: "Top 2025-2026", icon: "🏆" },
          ].map(({ href, label, icon }) => (
            <a href={href} style="display:flex;align-items:center;gap:10px;background:var(--cz-surface);border:1px solid var(--cz-border);padding:12px 16px;text-decoration:none;transition:border-color .15s;font-size:13px;font-weight:700;color:var(--cz-text-soft);font-family:'Barlow Condensed',sans-serif;text-transform:uppercase;letter-spacing:-.01em" class="guide-link">
              <span>{icon}</span>
              <span>{label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <style>
    .guide-link:hover { border-color: #f97316 !important; color: #f97316 !important; }
  </style>
</Base>
