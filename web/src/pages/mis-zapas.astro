---
// /mis-zapas — favoritos persistidos
//
// Lee de localStorage la clave "cz.favs" (set de slugs que el catálogo escribe).
// Permite quitar favoritos, comparar 3 a la vez, exportar como JSON.

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
import { zapatillas } from "../data/zapatillas";
import { findMejorPrecio } from "../lib/scoring";

const CAT_LABELS: Record<string, string> = {
  "cushion-focused": "Cushion", "responsive": "Reactiva",
  "balanced": "Equilibrada", "traction-king": "Tracción",
};
const CAT_ACCENT: Record<string, string> = {
  "cushion-focused": "#38bdf8", "responsive": "#facc15",
  "balanced": "#d4d4d8", "traction-king": "#fb923c",
};

// Render todas las cards y dejar que JS oculte las que no son favoritas
const ordenadas = [...zapatillas].sort((a, b) => a.marca.localeCompare(b.marca));
---

<Base
  title="Mis zapas guardadas · CANCHA.ZAPA"
  description="Tus zapatillas de baloncesto favoritas, guardadas para volver a verlas."
>
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/balones">Accesorios</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas" class="active" aria-current="page">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <section class="doc-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Tus favoritas</p>
        <h1 class="doc-h1">
          Mis<br/>
          <span class="accent">zapas</span><br/>
          guardadas
        </h1>
        <p class="doc-lede" id="mz-lede">
          Las que has marcado con ♥ en el catálogo. Se guardan en este navegador —
          no necesitas cuenta.
        </p>
      </div>
    </section>

    {/* Empty state */}
    <section id="mz-empty" class="rs-empty hidden">
      <div class="shell">
        <p class="cz-eyebrow">★ Sin favoritas todavía</p>
        <h2 class="rs-empty-h1">
          Aún no has<br/>
          <span class="muted">guardado nada.</span>
        </h2>
        <p class="rs-empty-lede">
          Cuando estés en una ficha o en el catálogo, pulsa el corazón ♡ para añadirla
          aquí. También puedes empezar por el quiz.
        </p>
        <div class="err-cta">
          <a href="/quiz" class="home-btn primary">→ Hacer el quiz</a>
          <a href="/zapatillas" class="home-btn ghost">Ver catálogo</a>
        </div>
      </div>
    </section>

    {/* Tabs + Toolbar — visible cuando hay favoritas */}
    <div id="mz-toolbar" class="cz-actionbar shell hidden" style="flex-wrap:wrap;gap:10px">
      {/* Tabs */}
      <div class="mz-tabs">
        <button id="tab-quiero" class="mz-tab active" type="button">
          ♥ Lo quiero <span class="mz-tab-count" id="count-quiero">0</span>
        </button>
        <button id="tab-tengo" class="mz-tab" type="button">
          ✓ Lo tengo <span class="mz-tab-count" id="count-tengo">0</span>
        </button>
      </div>
      {/* Actions */}
      <div class="right" style="margin-left:auto">
        <button id="mz-compare" class="home-btn ghost" type="button" disabled>
          ⇄ Comparar (selecciona 2–3)
        </button>
        <button id="mz-export" class="home-btn ghost" type="button">
          ↓ Exportar
        </button>
        <button id="mz-clear" class="home-btn ghost" type="button">
          ✗ Vaciar todo
        </button>
      </div>
    </div>

    {/* Grid de favoritas */}
    <section class="shell" style="padding:24px 24px 60px">
      <div class="cz-grid cols-3" id="mz-grid">
        {ordenadas.map(z => {
          const mejor = findMejorPrecio(z.links_compra);
          const precio = mejor?.precio_actual ?? z.precio_msrp_eur;
          const cat = CAT_ACCENT[z.categoria_principal];
          const score = Math.round((Object.values(z.puntuaciones).reduce((a,b)=>a+b,0)/8)*10)/10;
          const scClass = score >= 8 ? "hi" : score >= 6.5 ? "mid" : "lo";
          return (
            <article
              class="cz-card hidden mz-card"
              data-slug={z.slug}
              style={`--cat:${cat}`}
            >
              <div class="photo">
                <span class="cat-badge">{CAT_LABELS[z.categoria_principal]}</span>
                <span class={`cz-score-pill ${scClass} score-pill`}>{score}</span>
                <span class="mz-state-badge hidden" data-slug={z.slug}></span>
                <img src={z.imagen_principal} alt={`${z.marca} ${z.modelo}`} loading="lazy"
                     onerror="this.style.display='none'" />
                <span class="cat-stripe"></span>
              </div>
              <div class="body">
                <div>
                  <p class="marca">{z.marca}</p>
                  <h3 class="modelo">{z.modelo}</h3>
                </div>
                <div class="cz-specs">
                  <div class="spec"><span class="v">{z.peso_real_g}<small>g</small></span><span class="k">Peso</span></div>
                  <div class="spec"><span class="v">{z.altura}</span><span class="k">Altura</span></div>
                  <div class="spec"><span class="v">{z.drop_mm}<small>mm</small></span><span class="k">Drop</span></div>
                  <div class="spec"><span class="v">{z.horma}</span><span class="k">Horma</span></div>
                </div>
                <div class="foot">
                  <div>
                    <span class="price-meta"><span class="dot"></span>Verificado</span>
                    <span class="price">{Math.round(precio)}€</span>
                  </div>
                  <div class="actions">
                    <label class="mz-check" title="Seleccionar para comparar">
                      <input type="checkbox" class="mz-pick" data-slug={z.slug} />
                      <span>⇄</span>
                    </label>
                    <button class="icon-btn mz-remove" data-slug={z.slug} title="Quitar de favoritas" type="button">
                      ✗
                    </button>
                    <a class="icon-btn" href={`/zapatilla/${z.slug}`} title="Ver ficha">→</a>
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>

  </main>

  <script>
    const QUIERO_KEY = "cz.quiero";
    const TENGO_KEY  = "cz.tengo";
    const LEGACY_KEY = "cz.favs";

    function loadSet(key: string): Set<string> {
      try { return new Set(JSON.parse(localStorage.getItem(key) || "[]")); }
      catch { return new Set(); }
    }
    function saveSet(key: string, s: Set<string>) {
      localStorage.setItem(key, JSON.stringify([...s]));
    }

    // Migración one-time desde cz.favs → cz.quiero
    (function migrate() {
      const leg = localStorage.getItem(LEGACY_KEY);
      if (!leg) return;
      try {
        const old: string[] = JSON.parse(leg);
        const q = loadSet(QUIERO_KEY);
        old.forEach(s => q.add(s));
        saveSet(QUIERO_KEY, q);
        localStorage.removeItem(LEGACY_KEY);
      } catch { localStorage.removeItem(LEGACY_KEY); }
    })();

    let quiero = loadSet(QUIERO_KEY);
    let tengo  = loadSet(TENGO_KEY);
    const picks: Set<string> = new Set();
    let activeTab: "quiero" | "tengo" = "quiero";

    const $empty   = document.getElementById("mz-empty")!;
    const $toolbar = document.getElementById("mz-toolbar")!;
    const $compare = document.getElementById("mz-compare") as HTMLButtonElement;
    const $cards   = document.querySelectorAll<HTMLElement>(".mz-card");
    const $cntQ    = document.getElementById("count-quiero")!;
    const $cntT    = document.getElementById("count-tengo")!;
    const $tabQ    = document.getElementById("tab-quiero")!;
    const $tabT    = document.getElementById("tab-tengo")!;

    function render() {
      quiero = loadSet(QUIERO_KEY);
      tengo  = loadSet(TENGO_KEY);
      const total = quiero.size + tengo.size;
      $cntQ.textContent = String(quiero.size);
      $cntT.textContent = String(tengo.size);
      $empty.classList.toggle("hidden", total > 0);
      $toolbar.classList.toggle("hidden", total === 0);

      $cards.forEach((c) => {
        const slug = c.dataset.slug!;
        const inQ = quiero.has(slug);
        const inT = tengo.has(slug);
        const show = activeTab === "quiero" ? inQ : inT;
        c.classList.toggle("hidden", !show);

        // State badge
        const badge = c.querySelector<HTMLElement>(".mz-state-badge");
        if (badge) {
          if (inT) {
            badge.textContent = "✓ Lo tengo";
            badge.style.cssText = "background:#16532430;color:#22c55e;border:1px solid #22c55e40";
            badge.classList.remove("hidden");
          } else if (inQ) {
            badge.textContent = "♥ Lo quiero";
            badge.style.cssText = "background:#7c2d1230;color:#f97316;border:1px solid #f9731640";
            badge.classList.remove("hidden");
          } else {
            badge.classList.add("hidden");
          }
        }
      });
    }

    function updateCompareBtn() {
      const n = picks.size;
      $compare.disabled = n < 2 || n > 3;
      if (n === 0) $compare.textContent = "⇄ Comparar (selecciona 2–3)";
      else if (n === 1) $compare.textContent = `⇄ Selecciona 1 más`;
      else $compare.textContent = `⇄ Comparar ${n} →`;
    }

    // Tabs
    function setTab(tab: "quiero" | "tengo") {
      activeTab = tab;
      $tabQ.classList.toggle("active", tab === "quiero");
      $tabT.classList.toggle("active", tab === "tengo");
      picks.clear();
      document.querySelectorAll<HTMLInputElement>(".mz-pick").forEach(cb => { cb.checked = false; });
      updateCompareBtn();
      render();
    }
    $tabQ.addEventListener("click", () => setTab("quiero"));
    $tabT.addEventListener("click", () => setTab("tengo"));

    // Checkboxes para comparar
    document.querySelectorAll<HTMLInputElement>(".mz-pick").forEach((cb) => {
      cb.addEventListener("change", () => {
        const slug = cb.dataset.slug!;
        if (cb.checked) {
          if (picks.size >= 3) { cb.checked = false; return; }
          picks.add(slug);
        } else {
          picks.delete(slug);
        }
        updateCompareBtn();
      });
    });

    // Quitar de la lista
    document.querySelectorAll<HTMLButtonElement>(".mz-remove").forEach((btn) => {
      btn.addEventListener("click", () => {
        const slug = btn.dataset.slug!;
        const q = loadSet(QUIERO_KEY);
        const t = loadSet(TENGO_KEY);
        q.delete(slug); t.delete(slug);
        saveSet(QUIERO_KEY, q); saveSet(TENGO_KEY, t);
        picks.delete(slug);
        render();
        updateCompareBtn();
      });
    });

    $compare.addEventListener("click", () => {
      if (picks.size < 2) return;
      location.href = `/comparar?slugs=${[...picks].join(",")}`;
    });

    document.getElementById("mz-export")!.addEventListener("click", () => {
      const data = JSON.stringify({ quiero: [...loadSet(QUIERO_KEY)], tengo: [...loadSet(TENGO_KEY)] }, null, 2);
      const blob = new Blob([data], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url; a.download = `mis-zapas-${new Date().toISOString().slice(0,10)}.json`;
      a.click(); URL.revokeObjectURL(url);
    });

    document.getElementById("mz-clear")!.addEventListener("click", () => {
      if (!confirm("¿Vaciar toda la lista? No se puede deshacer.")) return;
      saveSet(QUIERO_KEY, new Set());
      saveSet(TENGO_KEY, new Set());
      picks.clear();
      render();
      updateCompareBtn();
    });

    render();
    updateCompareBtn();
  </script>

  <style>
    .hidden { display: none !important; }
    /* Tabs */
    .mz-tabs { display: flex; gap: 6px; }
    .mz-tab {
      padding: 7px 14px; border: 1px solid #3f3f46; background: transparent;
      color: #71717a; font-size: 11px; font-weight: 900; text-transform: uppercase;
      letter-spacing: 0.1em; cursor: pointer; transition: all .15s;
    }
    .mz-tab.active[id="tab-quiero"] { color: #f97316; border-color: #f97316; background: rgba(249,115,22,0.08); }
    .mz-tab.active[id="tab-tengo"]  { color: #22c55e; border-color: #22c55e; background: rgba(34,197,94,0.08); }
    .mz-tab-count {
      display: inline-block; margin-left: 5px; background: #27272a;
      color: #a1a1aa; padding: 1px 6px; font-size: 10px; border-radius: 999px;
    }
    /* State badge sobre la foto */
    .mz-state-badge {
      position: absolute; bottom: 10px; left: 10px; z-index: 3;
      font-size: 9px; font-weight: 900; text-transform: uppercase;
      letter-spacing: 0.12em; padding: 3px 7px; backdrop-filter: blur(4px);
    }
    /* Checkbox comparar */
    .mz-check {
      width: 30px; height: 30px; border: 1px solid #27272a;
      background: transparent; color: #71717a;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 13px; cursor: pointer; user-select: none;
      transition: all 0.12s;
    }
    .mz-check input { display: none; }
    .mz-check:has(input:checked) {
      background: #f97316; color: #0c0c0c; border-color: #f97316;
    }
    .mz-card .mz-remove:hover { color: #ef4444; border-color: #ef4444; }
  </style>
</Base>
