---
// /404 — Not Found, rediseñado
import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";

const popular = [
  { label: "Nike LeBron 22",     slug: "nike-lebron-22" },
  { label: "Anta KAI 1 Speed",   slug: "anta-kai-1-speed" },
  { label: "Nike GT Cut 3",      slug: "nike-gt-cut-3" },
  { label: "Adidas AE 1",        slug: "adidas-ae-1" },
  { label: "New Balance BB v3",  slug: "nb-fresh-foam-bb-v3" },
];
---

<Base
  title="404 — Página no encontrada · CANCHA.ZAPA"
  description="Esta página no existe. Pero sí existen las zapatillas perfectas para ti."
>
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
                  <a href="/balones">Accesorios</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <section class="err-hero">
      <div class="shell err-hero-inner">
        <div class="err-num" aria-hidden="true">
          4<span class="err-dot">0</span>4
        </div>
        <p class="cz-eyebrow">★ Sin matches con esa URL</p>
        <h1 class="err-h1">
          Página<br/>
          <span class="muted">no encontrada</span>
        </h1>
        <p class="err-lede">
          Esta URL no existe. Pero sí existen las zapatillas perfectas para tu juego —
          y las tenemos todas catalogadas.
        </p>

        <div class="err-cta">
          <a href="/quiz" class="home-btn primary">→ Hacer el quiz</a>
          <a href="/zapatillas" class="home-btn ghost">Ver catálogo</a>
        </div>

        <form action="/zapatillas" method="get" class="err-search">
          <input type="search" name="q" placeholder="Buscar zapatilla…" />
          <button type="submit">Buscar →</button>
        </form>

        <div class="err-popular">
          <p class="cz-eyebrow" style="font-size:9px">★ Zapas populares</p>
          <div class="err-popular-row">
            {popular.map(p => (
              <a href={`/zapatilla/${p.slug}`} class="err-pop-chip">{p.label}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

  </main>
</Base>
