---
// /zapatilla/[slug] — detalle rediseñado
// Drop-in replacement for web/src/pages/zapatilla/[slug].astro

import Base from "../../layouts/Base.astro";
import "../../styles/cancha-redesign.css";
import { zapatillas } from "../../data/zapatillas";
import { findMejorPrecio, COMISIONES_TIENDA } from "../../lib/scoring";
import PriceAlert from "../../components/PriceAlert.astro";
import { ARTICLES } from "../../lib/articles";

export async function getStaticPaths() {
  return zapatillas.map((z) => ({ params: { slug: z.slug }, props: { zapatilla: z } }));
}
const { zapatilla: z } = Astro.props;

const LABELS_TIENDA: Record<string, string> = {
  amazon_es: "Amazon", decathlon: "Decathlon", nike_es: "Nike", adidas_es: "Adidas",
  puma_es: "Puma", ua_es: "Under Armour", nb_es: "New Balance", reebok_es: "Reebok",
  footlocker_es: "Foot Locker", jd_sports_es: "JD Sports", zalando_es: "Zalando",
  sprinter_es: "Sprinter", basket_world: "Basket World", aliexpress: "AliExpress",
};
const LABELS_FUENTE: Record<string, string> = {
  weartesters: "WearTesters", "hoops-geek": "TheHoopsGeek",
  "runrepeat-lab": "RunRepeat Lab", schwollo: "Schwollo",
  "evaluacion-propia": "Evaluación propia",
};
const CAT_LABELS: Record<string, string> = {
  "cushion-focused": "Cushion", "responsive": "Reactiva",
  "balanced": "Equilibrada", "traction-king": "Tracción",
};
const CAT_ACCENT: Record<string, string> = {
  "cushion-focused": "#38bdf8", "responsive": "#facc15",
  "balanced": "#d4d4d8", "traction-king": "#fb923c",
};
const ATR_LABELS: Record<string, string> = {
  traccion: "Tracción", amortiguacion: "Amortiguación",
  respuesta: "Respuesta", soporte_lateral: "Soporte lateral",
  estabilidad: "Estabilidad", peso_score: "Ligereza",
  durabilidad_outdoor: "Durabilidad outdoor", ventilacion: "Ventilación",
};

const mejorPrecio = findMejorPrecio(z.links_compra);
const scoreVals = Object.values(z.puntuaciones);
const score = Math.round((scoreVals.reduce((a, b) => a + b, 0) / scoreVals.length) * 10) / 10;
const cat = CAT_ACCENT[z.categoria_principal];
const ahorro = mejorPrecio && mejorPrecio.precio_actual < z.precio_msrp_eur
  ? z.precio_msrp_eur - mejorPrecio.precio_actual : 0;
const ahorroPct = ahorro > 0 ? Math.round((ahorro / z.precio_msrp_eur) * 100) : 0;

// Build SVG radar points for the score
const RADAR_KEYS = ["traccion", "amortiguacion", "respuesta", "soporte_lateral", "estabilidad", "peso_score", "durabilidad_outdoor", "ventilacion"] as const;
const radarSize = 110;
const radarPts = RADAR_KEYS.map((k, i) => {
  const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
  const v = z.puntuaciones[k as keyof typeof z.puntuaciones];
  const r = (v / 10) * (radarSize / 2 - 6);
  return [radarSize/2 + Math.cos(a) * r, radarSize/2 + Math.sin(a) * r];
});
const radarPath = radarPts.map(p => p.join(",")).join(" ");

const relacionadas = zapatillas
  .filter(o => o.slug !== z.slug && o.categoria_principal === z.categoria_principal)
  .sort((a, b) => Object.values(b.puntuaciones).reduce((s, v) => s + v, 0) - Object.values(a.puntuaciones).reduce((s, v) => s + v, 0))
  .slice(0, 3);

// Blog articles mentioning this shoe
const articulosRelacionados = ARTICLES
  .filter((a) => a.relatedShoes.includes(z.slug))
  .slice(0, 4);

const PRECIO_TIE = 0.5;
const linksOrdenados = [...z.links_compra]
  .filter(l => l.disponible)
  .sort((a, b) => {
    const diff = a.precio_actual - b.precio_actual;
    if (Math.abs(diff) > PRECIO_TIE) return diff; // precio claramente distinto
    // Empate (±0,50€) → priorizar mayor comisión
    return (COMISIONES_TIENDA[b.tienda] ?? 0) - (COMISIONES_TIENDA[a.tienda] ?? 0);
  });

// ── Upsell: Combina con → calcetines y plantillas ──────────────────
const CALCETINES_UPSELL = [
  { id: "nike-cushioned",      emoji: "🧦", nombre: "Nike Elite Cushioned Crew",      precio: "~15€", nota: "Amortiguación extra en talón y antepié",            url: "https://www.amazon.es/s?k=nike+elite+cushioned+basketball+crew&tag=canchazapa-21",                                                                                             tienda: "Amazon"    },
  { id: "nike-light",          emoji: "🧦", nombre: "Nike Elite Lightweight Crew",     precio: "~13€", nota: "Perfil fino para máximo court feel",                 url: "https://www.amazon.es/s?k=nike+elite+lightweight+crew+calcetines+baloncesto&tag=canchazapa-21",                                                                           tienda: "Amazon"    },
  { id: "adidas-crew",         emoji: "🧦", nombre: "Adidas Cushioned Crew 3-Pack",    precio: "~12€", nota: "Cushion Adidas — perfecto con zapas de la marca",   url: "https://www.amazon.es/s?k=adidas+cushioned+crew+calcetines+baloncesto+pack&tag=canchazapa-21",                                                                            tienda: "Amazon"    },
  { id: "ua-playmaker",        emoji: "🧦", nombre: "Under Armour Playmaker Mid Crew", precio: "~12€", nota: "Cañero medio con soporte real de tobillo",           url: "https://www.amazon.es/s?k=under+armour+playmaker+mid+crew+calcetines&tag=canchazapa-21",                                                                                  tienda: "Amazon"    },
  { id: "stance-nba",          emoji: "🧦", nombre: "Stance NBA Performance Crew",     precio: "~16€", nota: "La opción premium oficial de la NBA",                url: "https://www.amazon.es/s?k=stance+nba+performance+crew+calcetines&tag=canchazapa-21",                                                                                          tienda: "Amazon"    },
  { id: "decathlon-calcetines",emoji: "🧦", nombre: "Kiprun Calcetines Baloncesto",    precio: "~6€",  nota: "La opción económica — buena relación calidad/precio",url: "https://www.awin1.com/cread.php?awinmid=105405&awinaffid=2908587&ued=https%3A%2F%2Fwww.decathlon.es%2Fsearch%3FNtt%3Dcalcetines%2Bbaloncesto",                           tienda: "Decathlon" },
];
const PLANTILLAS_UPSELL = [
  { id: "superfeet-green",     emoji: "🦶", nombre: "Superfeet Green Premium",          precio: "~38€", nota: "Soporte de arco máximo — pronación y pie plano",    url: "https://www.amazon.es/s?k=superfeet+green+plantillas+deporte&tag=canchazapa-21",                                                                                           tienda: "Amazon"    },
  { id: "sofsole-athlete",     emoji: "🦶", nombre: "Sof Sole Athlete Full Length",     precio: "~18€", nota: "Cushion extra para zapatillas básicas o retros",     url: "https://www.amazon.es/s?k=sof+sole+athlete+full+length+plantillas&tag=canchazapa-21",                                                                                     tienda: "Amazon"    },
  { id: "bauerfeind",          emoji: "🦶", nombre: "Bauerfeind Sports Basketball",     precio: "~45€", nota: "Soporte médico para tobillo y rodilla sensibles",    url: "https://www.amazon.es/s?k=bauerfeind+sports+plantillas+baloncesto&tag=canchazapa-21",                                                                                       tienda: "Amazon"    },
  { id: "currex",              emoji: "🦶", nombre: "Currex SupportST",                 precio: "~40€", nota: "Arco dinámico — estabilidad sin perder reactividad", url: "https://www.amazon.es/s?k=currex+supportst+plantillas+deporte&tag=canchazapa-21",                                                                                             tienda: "Amazon"    },
  { id: "decathlon-plantillas",emoji: "🦶", nombre: "Kalenji Plantillas Deporte",       precio: "~8€",  nota: "Recambio económico — más grip y amortiguación base", url: "https://www.awin1.com/cread.php?awinmid=105405&awinaffid=2908587&ued=https%3A%2F%2Fwww.decathlon.es%2Fsearch%3FNtt%3Dplantillas%2Bdeporte",                           tienda: "Decathlon" },
];
// Selección automática por perfil de la zapatilla
// Decathlon para zapas baratas (<80€) o marca Decathlon — comisión 6% vs 3% Amazon
const _cIdx = (z.marca === "Decathlon" || z.precio_msrp_eur < 80) ? 5
  : z.marca === "Adidas" ? 2
  : (z.puntuaciones.respuesta >= 9 || z.categoria_principal === "responsive") ? 1
  : (z.altura === "high" || z.puntuaciones.soporte_lateral >= 8.5) ? 3
  : 0;
const _pIdx = (z.marca === "Decathlon" || (z.precio_msrp_eur < 80 && (z.es_retro || z.puntuaciones.amortiguacion <= 6))) ? 4
  : (z.es_retro || z.puntuaciones.amortiguacion <= 6) ? 1
  : (z.ideal_para.lesiones_compatibles?.includes("tobillos")) ? 2
  : 0; // default: Superfeet Green
const combinaCon = [CALCETINES_UPSELL[_cIdx], PLANTILLAS_UPSELL[_pIdx]];

// Helper: cuánto hace que se verificó este precio
function verifiedAgo(fecha: string | undefined): { label: string; color: string; fresh: boolean } {
  if (!fecha) return { label: "Sin verificar", color: "#52525b", fresh: false };
  const d = new Date(fecha);
  const days = Math.floor((Date.now() - d.getTime()) / 86400000);
  if (days <= 1) return { label: "Verificado hoy", color: "#4ade80", fresh: true };
  if (days <= 3) return { label: `Verificado hace ${days}d`, color: "#4ade80", fresh: true };
  if (days <= 7) return { label: `Verificado hace ${days}d`, color: "#facc15", fresh: true };
  if (days <= 30) return { label: `Verificado hace ${days}d`, color: "#fb923c", fresh: false };
  return { label: "Precio editorial", color: "#52525b", fresh: false };
}

// JSON-LD Product schema
const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${z.marca} ${z.modelo}`,
  "brand": { "@type": "Brand", "name": z.marca },
  "description": z.resumen,
  "image": z.imagen_principal,
  "url": `https://canchazapa.com/zapatilla/${z.slug}`,
  "sku": z.slug,
  ...(mejorPrecio ? {
    "offers": {
      "@type": "Offer",
      "price": mejorPrecio.precio_actual,
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "url": mejorPrecio.url,
      "priceValidUntil": `${new Date().getFullYear() + 1}-12-31`,
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": "0",
          "currency": "EUR"
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "addressCountry": "ES"
        },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": {
            "@type": "QuantitativeValue",
            "minValue": 0,
            "maxValue": 1,
            "unitCode": "DAY"
          },
          "transitTime": {
            "@type": "QuantitativeValue",
            "minValue": 1,
            "maxValue": 5,
            "unitCode": "DAY"
          }
        }
      },
      "hasMerchantReturnPolicy": {
        "@type": "MerchantReturnPolicy",
        "applicableCountry": "ES",
        "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
        "merchantReturnDays": 30,
        "returnMethod": "https://schema.org/ReturnByMail",
        "returnFees": "https://schema.org/FreeReturn"
      }
    }
  } : {}),
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": score,
    "bestRating": 10,
    "worstRating": 1,
    "ratingCount": z.fuentes.length || 1
  }
};
---

<Base
  title={`${z.marca} ${z.modelo} (${z.año_lanzamiento}) · Análisis y mejor precio | CANCHA.ZAPA`}
  description={`${z.marca} ${z.modelo}: análisis técnico honesto, puntuaciones en 8 atributos y mejor precio en tiendas españolas. ${z.resumen.slice(0, 80)}...`}
  ogType="article"
  ogImage={`/og/${z.slug}.svg`}
  jsonLd={productJsonLd}
>
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo">CANCHA<span class="dot">.</span>ZAPA</a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas" class="active">Catálogo</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <nav class="cz-breadcrumbs">
      <div class="shell">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href="/zapatillas">Catálogo</a>
        <span>/</span>
        <span class="current">{z.marca} {z.modelo}</span>
      </div>
    </nav>

    {/* RETRO BANNER */}
    {z.es_retro && (
      <div style="background:#1c1007;border-bottom:1px solid #b45309;padding:10px 0">
        <div class="shell" style="display:flex;align-items:center;gap:12px;font-size:13px;color:#fde68a">
          <span style="font-size:20px">🏅</span>
          <span><strong>Zapatilla histórica</strong> — Las puntuaciones reflejan rendimiento técnico con tecnología de su época, no valor de colección. No aparece en el quiz de recomendación.</span>
        </div>
      </div>
    )}

    {/* HERO */}
    <section class="cz-detail-hero" style={`--cat:${cat}`}>
      <div class="shell">
        <div class="dh-grid">
          {/* Photo */}
          <div class="dh-photo">
            <div class="dh-photo-frame">
              {/* Badges izquierda: categoría + retro/nueva juntos */}
              <div class="dh-badges-left">
                <span class="dh-cat-badge">{CAT_LABELS[z.categoria_principal]}</span>
                {z.es_retro
                  ? <span class="dh-cat-badge" style="background:#451a03;color:#fef3c7;border-color:#92400e">🏅 Retro · {z.año_lanzamiento}</span>
                  : z.año_lanzamiento >= 2026 && <span class="dh-cat-badge" style="background:#1a1a00;color:#fbbf24;border-color:#854d0e">★ {z.año_lanzamiento}</span>
                }
              </div>
              {/* Corazón favorito — esquina superior derecha */}
              <button
                id="fav-btn"
                data-slug={z.slug}
                type="button"
                class="dh-fav-btn"
                title="Guardar en Mis Zapas"
                aria-label="Guardar en Mis Zapas"
              >
                <span id="fav-icon">♡</span>
              </button>
              {z.imagen_principal && !z.imagen_principal.includes('placeholder') && (
                <img src={z.imagen_principal} alt={`${z.marca} ${z.modelo}`}
                     onerror="this.style.display='none'" />
              )}
              <div class="dh-marca-watermark">{z.marca}</div>
            </div>
          </div>

          {/* Info */}
          <div class="dh-info">
            <div class="dh-eyebrow">
              <span class="dhe-pill">★ {z.año_lanzamiento}</span>
              <span class="dhe-cat" style={`color:${cat}`}>{CAT_LABELS[z.categoria_principal]}</span>
              {z.signature_player && <span class="dhe-tag">Signature {z.signature_player}</span>}
              {z.tags.slice(0, 2).map(t => <span class="dhe-tag">#{t}</span>)}
            </div>
            <p class="dh-marca">{z.marca}</p>
            <h1 class="dh-modelo">{z.modelo}</h1>

            <div class="dh-score-row">
              <div class="dh-score-num">{score}<small>/10</small></div>
              <div class="dh-score-radar">
                <svg viewBox={`0 0 ${radarSize} ${radarSize}`} width="92" height="92" aria-hidden="true">
                  {[0.33,0.66,1].map(f => (
                    <polygon
                      points={RADAR_KEYS.map((_, i) => {
                        const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
                        const r = f * (radarSize / 2 - 6);
                        return `${radarSize/2 + Math.cos(a)*r},${radarSize/2 + Math.sin(a)*r}`;
                      }).join(" ")}
                      fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"
                    />
                  ))}
                  <polygon points={radarPath} fill="#f97316" fill-opacity="0.18" stroke="#f97316" stroke-width="1.5" />
                </svg>
              </div>
              <div class="dh-score-meta">
                <div class="dhsm-lab">Score CANCHA</div>
                <div class="dhsm-sub">Media de 8 atributos · {z.fuentes.length || 1} {z.fuentes.length === 1 ? "fuente" : "fuentes"}</div>
                <div class="dhsm-fuentes">
                  {z.fuentes.map(f => <span class="dhf">{LABELS_FUENTE[f.tipo] || f.tipo}</span>)}
                </div>
              </div>
            </div>

            <p class="dh-resumen" set:html={z.resumen} />

            <div class="dh-specs">
              <div class="dhs"><div class="v">{z.peso_real_g}<small>g</small></div><div class="k">Peso (US 9)</div></div>
              <div class="dhs"><div class="v">{z.altura}</div><div class="k">Altura</div></div>
              <div class="dhs"><div class="v">{z.drop_mm}<small>mm</small></div><div class="k">Drop</div></div>
              <div class="dhs"><div class="v" style="text-transform:capitalize">{z.horma}</div><div class="k">Horma</div></div>
            </div>

            {mejorPrecio && (
              <div class="dh-buy">
                <div class="dh-buy-price">
                  <div class="dhbp-row">
                    <span class="dhbp-now">{Math.round(mejorPrecio.precio_actual)}€</span>
                    {ahorro > 0 && (
                      <>
                        <span class="dhbp-msrp">msrp {z.precio_msrp_eur}€</span>
                        <span class="dhbp-save">−{ahorroPct}%</span>
                      </>
                    )}
                  </div>
                  <div class="dhbp-meta">
                    <span class="dhbp-dot"></span>
                    Verificado · mejor precio en <strong>{LABELS_TIENDA[mejorPrecio.tienda] || mejorPrecio.tienda}</strong>
                  </div>
                </div>
                <a href={mejorPrecio.url} target="_blank" rel={mejorPrecio.tiene_afiliado ? "noopener noreferrer sponsored" : "noopener noreferrer"} class="dh-buy-btn aff-btn" data-tienda={LABELS_TIENDA[mejorPrecio.tienda]||mejorPrecio.tienda} data-zapa={z.slug}>
                  Ver en {LABELS_TIENDA[mejorPrecio.tienda] || mejorPrecio.tienda} →
                </a>
              </div>
            )}

          </div>
        </div>
      </div>
    </section>

    {/* SCORE BREAKDOWN */}
    <section class="cz-detail-scores">
      <div class="shell">
        <div class="section-head">
          <p class="cz-eyebrow">★ Análisis técnico</p>
          <h2>8 atributos<br/><span class="muted">en detalle</span></h2>
        </div>
        <div class="score-grid">
          {Object.entries(z.puntuaciones).map(([k, v]) => {
            const pct = (v / 10) * 100;
            const col = v >= 8 ? "#f97316" : v >= 6 ? "#facc15" : "#71717a";
            return (
              <div class="score-bar-row">
                <div class="sbr-head">
                  <span class="sbr-lab">{ATR_LABELS[k] || k}</span>
                  <span class="sbr-val" style={`color:${col}`}>{v}<small>/10</small></span>
                </div>
                <div class="sbr-track">
                  <div class="sbr-fill" style={`width:${pct}%;background:${col}`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* VERDICT */}
    <section class="cz-detail-verdict">
      <div class="shell">
        <div class="vd-grid">
          <div>
            <p class="cz-eyebrow" style="color:#4ade80">✓ Lo que sí</p>
            <ul class="vd-list pros">
              {z.pros.map(p => <li><span class="bull">+</span>{p}</li>)}
            </ul>
          </div>
          <div>
            <p class="cz-eyebrow" style="color:#ef4444">✗ Lo que no</p>
            <ul class="vd-list contras">
              {z.contras.map(c => <li><span class="bull">−</span>{c}</li>)}
            </ul>
          </div>
        </div>
        <div class="vd-verdict">
          <p class="cz-eyebrow">★ Veredicto CANCHA</p>
          <p class="vd-text">{z.veredicto}</p>
          <div class="vd-quote-attr">
            <span class="vd-line"></span>
            <span>Sin sesgo editorial · Sin patrocinios · Links de afiliado etiquetados</span>
          </div>
        </div>
      </div>
    </section>

    {/* PARA QUIÉN */}
    <section class="cz-detail-para">
      <div class="shell">
        <div class="section-head">
          <p class="cz-eyebrow">★ Para quién</p>
          <h2>¿Encaja con tu juego?</h2>
        </div>
        <div class="para-grid">
          <div class="para-col yes">
            <div class="pc-head">✓ Tu zapa si…</div>
            <ul>
              <li>Juegas de <strong>{z.ideal_para.posiciones.join(", ")}</strong></li>
              <li>Tu estilo es <strong>{z.ideal_para.estilos.join(" o ")}</strong></li>
              <li>Pesas entre <strong>{z.ideal_para.peso_jugador_kg[0]}–{z.ideal_para.peso_jugador_kg[1]} kg</strong></li>
              {z.ideal_para.lesiones_compatibles && z.ideal_para.lesiones_compatibles.length > 0 && (
                <li>Compatible con <strong>{z.ideal_para.lesiones_compatibles.join(", ")}</strong></li>
              )}
            </ul>
          </div>
          {((z.no_recomendada_para.posiciones?.length ?? 0) + (z.no_recomendada_para.estilos?.length ?? 0) + (z.no_recomendada_para.lesiones?.length ?? 0)) > 0 && (
            <div class="para-col no">
              <div class="pc-head">✗ Mira otra si…</div>
              <ul>
                {z.no_recomendada_para.posiciones?.length && <li>Juegas de <strong>{z.no_recomendada_para.posiciones.join(", ")}</strong></li>}
                {z.no_recomendada_para.estilos?.length && <li>Tu estilo es <strong>{z.no_recomendada_para.estilos.join(", ")}</strong></li>}
                {z.no_recomendada_para.lesiones?.length && <li>Tienes problemas de <strong>{z.no_recomendada_para.lesiones.join(", ")}</strong></li>}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>

    {/* AFILIADOS — 3 botones principales */}
    {(() => {
      const sprinter = z.links_compra.find(l => l.tienda === "sprinter_es" && l.disponible);
      const footlocker = z.links_compra.find(l => l.tienda === "footlocker_es" && l.disponible);
      const amazon = z.links_compra.find(l => l.tienda === "amazon_es" && l.disponible);
      const tiendas = [
        sprinter   && { label: "Sprinter",    url: sprinter.url,    precio: sprinter.precio_actual,    afiliado: sprinter.tiene_afiliado },
        footlocker && { label: "Foot Locker", url: footlocker.url,  precio: footlocker.precio_actual,  afiliado: footlocker.tiene_afiliado },
        amazon     && { label: "Amazon",      url: amazon.url,      precio: amazon.precio_actual,      afiliado: amazon.tiene_afiliado },
      ].filter(Boolean);
      if (!tiendas.length) return null;
      return (
        <section style="padding:40px 0;border-top:1px solid rgba(63,63,70,0.3)">
          <div class="shell">
            <p class="cz-eyebrow" style="margin-bottom:20px">★ Comprar ahora</p>
            <div style="display:flex;flex-wrap:wrap;gap:12px">
              {tiendas.map((t: any) => (
                <a href={t.url} target="_blank"
                   rel={t.afiliado ? "noopener noreferrer sponsored" : "noopener noreferrer"}
                   class="aff-btn"
                   data-tienda={t.label}
                   data-zapa={z.slug}
                   style="display:flex;align-items:center;gap:12px;padding:14px 24px;background:#18181b;border:1px solid rgba(249,115,22,0.4);color:#fff;text-decoration:none;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:16px;text-transform:uppercase;letter-spacing:.1em">
                  <span>{t.label}</span>
                  <span style="color:#f97316;font-size:18px">→</span>
                  <span style="margin-left:auto;color:#f97316;font-weight:900">{t.precio}€</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      );
    })()}

    {/* COMBINA CON → */}
    <section class="dh-combina-section">
      <div class="shell">
        <p class="cz-eyebrow" style="margin-bottom:14px">🧦 Combina con →</p>
        <div class="dh-combina-grid">
          {combinaCon.map(item => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="dh-combina-item aff-btn"
              data-tienda="Amazon"
              data-zapa={z.slug}
            >
              <span class="dci-emoji">{item.emoji}</span>
              <div class="dci-body">
                <strong class="dci-name">{item.nombre}</strong>
                <span class="dci-nota">{item.nota}</span>
              </div>
              <span class="dci-price">{item.precio}<span class="dci-arrow"> →</span></span>
            </a>
          ))}
        </div>
        <p class="dh-combina-disc">
          Enlaces afiliados ({combinaCon.map(i => i.tienda).join(" · ")}) · Si compras, CANCHA.ZAPA recibe una pequeña comisión sin coste extra para ti ·
          <a href="/blog/mejores-calcetines-baloncesto" style="color:#f97316;text-decoration:underline">Guía calcetines</a> ·
          <a href="/blog/mejores-plantillas-baloncesto" style="color:#f97316;text-decoration:underline">Guía plantillas</a>
        </p>
      </div>
    </section>

    {/* PRECIOS */}
    {linksOrdenados.length > 0 && (
      <section class="cz-detail-price-history" style="background:rgba(15,15,15,0.5)">
        <div class="shell">
          <div class="section-head">
            <p class="cz-eyebrow">★ Precios verificados</p>
            <h2>En {linksOrdenados.length} tienda{linksOrdenados.length > 1 ? "s" : ""}</h2>
          </div>
          <div style="border:1px solid rgba(63,63,70,0.4)">
            {linksOrdenados.map((link, idx) => {
              const diffPct = link.precio_actual < z.precio_msrp_eur ? Math.round((1 - link.precio_actual / z.precio_msrp_eur) * 100) : 0;
              const verif = verifiedAgo(link.ultima_verificacion);
              return (
                <div style={`display:flex;align-items:center;justify-content:space-between;gap:16px;padding:16px 20px;flex-wrap:wrap;${idx === 0 ? "background:rgba(249,115,22,0.05)" : ""}${idx > 0 ? "border-top:1px solid rgba(63,63,70,0.3)" : ""}`}>
                  <div style="display:flex;align-items:center;gap:12px">
                    {idx === 0 && <span style="padding:4px 8px;background:#facc15;color:#0c0c0c;font-size:9px;font-weight:900;text-transform:uppercase;letter-spacing:.18em">Mejor</span>}
                    <div>
                      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;text-transform:uppercase;font-size:18px;margin:0;line-height:1">{LABELS_TIENDA[link.tienda] || link.tienda}</p>
                      <p style="font-size:10px;text-transform:uppercase;letter-spacing:.15em;font-weight:700;margin:4px 0 0">
                        <span style="color:#52525b">{link.tiene_afiliado ? "★ Afiliado" : "Sin afiliación"} · </span>
                        <span style={`color:${verif.color}`}>{verif.fresh && "●"} {verif.label}</span>
                      </p>
                    </div>
                  </div>
                  <div style="display:flex;align-items:center;gap:16px;margin-left:auto">
                    <div style="text-align:right">
                      <p style={`font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;margin:0;line-height:1;color:${idx === 0 ? "#f97316" : "#fff"}`}>
                        {link.precio_actual}€
                      </p>
                      {diffPct > 0 && <p style="font-size:10px;color:#4ade80;font-weight:900;letter-spacing:.06em;margin:2px 0 0">-{diffPct}% vs MSRP</p>}
                    </div>
                    <a href={link.url} target="_blank" rel={link.tiene_afiliado ? "noopener noreferrer sponsored" : "noopener noreferrer"}
                       class="aff-btn" data-tienda={LABELS_TIENDA[link.tienda]||link.tienda} data-zapa={z.slug}
                       style="padding:10px 16px;background:#f97316;color:#0c0c0c;font-weight:900;text-transform:uppercase;letter-spacing:.14em;font-size:11px;box-shadow:3px 3px 0 0 #facc15">
                      Ver →
                    </a>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {/* ALERTA DE PRECIO */}
    {linksOrdenados.length > 0 && (
      <div class="shell" style="padding:0 24px 32px">
        <PriceAlert
          slug={z.slug}
          marca={z.marca}
          modelo={z.modelo}
          precioActual={mejorPrecio?.precio_actual ?? z.precio_msrp_eur}
        />
      </div>
    )}

    {/* RELATED */}
    {relacionadas.length > 0 && (
      <section class="cz-detail-related">
        <div class="shell">
          <div class="section-head">
            <p class="cz-eyebrow">★ Misma categoría</p>
            <h2>También te puede interesar</h2>
          </div>
          <div class="related-grid">
            {relacionadas.map(r => {
              const rsc = Math.round((Object.values(r.puntuaciones).reduce((a,b)=>a+b,0)/8)*10)/10;
              const rmp = findMejorPrecio(r.links_compra);
              return (
                <a href={`/zapatilla/${r.slug}`} class="rel-card">
                  <div class="rc-photo">
                    <span class="rc-score">{rsc}</span>
                    <img src={r.imagen_principal} alt="" onerror="this.style.display='none'" />
                  </div>
                  <div class="rc-body">
                    <p class="rc-marca">{r.marca}</p>
                    <h3 class="rc-modelo">{r.modelo}</h3>
                    <p class="rc-price">{Math.round(rmp?.precio_actual ?? r.precio_msrp_eur)}€</p>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {/* Blog articles mentioning this shoe */}
    {articulosRelacionados.length > 0 && (
      <section style="padding:40px 0;border-top:1px solid #27272a">
        <div class="shell">
          <p class="cz-eyebrow" style="margin-bottom:16px">★ Del blog</p>
          <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:22px;text-transform:uppercase;letter-spacing:-.02em;color:#fff;margin:0 0 20px">Artículos sobre esta zapatilla</h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px">
            {articulosRelacionados.map((art) => (
              <a href={`/blog/${art.slug}`} style="display:block;background:#141414;border:1px solid #27272a;padding:16px;text-decoration:none;transition:border-color .15s" class="art-ref-card">
                <span style="display:block;font-size:9px;font-weight:900;text-transform:uppercase;letter-spacing:.12em;color:#f97316;margin-bottom:6px">{art.categoria}</span>
                <span style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:15px;text-transform:uppercase;letter-spacing:-.01em;color:#e4e4e7;line-height:1.2;margin-bottom:6px">{art.title}</span>
                <span style="display:block;font-size:11px;color:#52525b">{art.readMinutes} min de lectura</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Sticky buy bar */}
    {mejorPrecio && (
      <div class="sticky-buy" id="sticky-buy">
        <div class="shell sticky-inner">
          <div class="sb-shoe">
            <img src={z.imagen_principal} alt="" onerror="this.style.display='none'" />
            <div>
              <p class="sb-marca">{z.marca}</p>
              <h3 class="sb-modelo">{z.modelo}</h3>
            </div>
          </div>
          <div class="sb-price">
            <span class="sbp-now">{Math.round(mejorPrecio.precio_actual)}€</span>
            {ahorro > 0 && <span class="sbp-msrp">msrp {z.precio_msrp_eur}€</span>}
          </div>
          <a href={mejorPrecio.url} target="_blank" rel="noopener noreferrer" class="sb-btn">
            Ver en {LABELS_TIENDA[mejorPrecio.tienda] || mejorPrecio.tienda} →
          </a>
        </div>
      </div>
    )}
  </main>

  <style>
    .art-ref-card:hover { border-color: #f97316 !important; }
  </style>
  <script>
    const sb = document.getElementById("sticky-buy");
    if (sb) {
      window.addEventListener("scroll", () => sb.classList.toggle("visible", window.scrollY > 700));
    }
    // Favoritos — 3 estados: none → quiero → tengo → none
    const QUIERO_KEY = "cz.quiero";
    const TENGO_KEY  = "cz.tengo";
    const LEGACY_KEY = "cz.favs";
    function loadSet(key: string): Set<string> {
      try { return new Set(JSON.parse(localStorage.getItem(key) || "[]")); }
      catch { return new Set(); }
    }
    function saveSet(key: string, s: Set<string>) {
      localStorage.setItem(key, JSON.stringify([...s]));
    }
    // Migración one-time desde cz.favs → cz.quiero
    (function migrate() {
      const leg = localStorage.getItem(LEGACY_KEY);
      if (!leg) return;
      try {
        const old: string[] = JSON.parse(leg);
        const q = loadSet(QUIERO_KEY);
        old.forEach(s => q.add(s));
        saveSet(QUIERO_KEY, q);
        localStorage.removeItem(LEGACY_KEY);
      } catch { localStorage.removeItem(LEGACY_KEY); }
    })();
    function getFavState(slug: string): "none" | "quiero" | "tengo" {
      if (loadSet(TENGO_KEY).has(slug)) return "tengo";
      if (loadSet(QUIERO_KEY).has(slug)) return "quiero";
      return "none";
    }
    function updateFavBtn(slug: string) {
      const btn = document.getElementById("fav-btn") as HTMLElement | null;
      const icon = document.getElementById("fav-icon");
      if (!btn || !icon) return;
      const state = getFavState(slug);
      btn.classList.remove("is-fav", "is-quiero", "is-tengo");
      if (state === "tengo") {
        icon.textContent = "✓";
        btn.title = "La tengo · pulsa para quitar";
        btn.classList.add("is-tengo");
      } else if (state === "quiero") {
        icon.textContent = "♥";
        btn.title = "La quiero · pulsa para marcar como tengo";
        btn.classList.add("is-quiero");
      } else {
        icon.textContent = "♡";
        btn.title = "Añadir a Mis Zapas";
      }
    }
    const favBtn = document.getElementById("fav-btn");
    if (favBtn) {
      const slug = (favBtn as HTMLElement).dataset.slug || "";
      updateFavBtn(slug);
      favBtn.addEventListener("click", () => {
        const state = getFavState(slug);
        const q = loadSet(QUIERO_KEY);
        const t = loadSet(TENGO_KEY);
        if (state === "none") {
          q.add(slug); saveSet(QUIERO_KEY, q);
          if ((window as any).plausible) (window as any).plausible("Favorite Added", { props: { zapa: slug, tipo: "quiero" } });
        } else if (state === "quiero") {
          q.delete(slug); t.add(slug);
          saveSet(QUIERO_KEY, q); saveSet(TENGO_KEY, t);
        } else {
          t.delete(slug); saveSet(TENGO_KEY, t);
        }
        updateFavBtn(slug);
      });
    }

    // Affiliate click tracking (Plausible)
    document.querySelectorAll(".aff-btn").forEach(el => {
      el.addEventListener("click", () => {
        const tienda = (el as HTMLElement).dataset.tienda || "";
        const zapa = (el as HTMLElement).dataset.zapa || "";
        if ((window as any).plausible) {
          (window as any).plausible("Affiliate Click", { props: { tienda, zapa } });
        }
      });
    });
  </script>
</Base>
