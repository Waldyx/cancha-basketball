---
import Base from "../../layouts/Base.astro";
import { zapatillas } from "../../data/zapatillas";
import { findMejorPrecio } from "../../lib/scoring";
import type { Puntuaciones } from "../../lib/types";

// Pre-genera una página por zapatilla en build time
export async function getStaticPaths() {
  return zapatillas.map((z) => ({
    params: { slug: z.slug },
    props: { zapatilla: z },
  }));
}

const { zapatilla: z } = Astro.props;

const LABELS_TIENDA: Record<string, string> = {
  amazon_es: "Amazon",
  decathlon: "Decathlon",
  nike_es: "Nike",
  adidas_es: "Adidas",
  puma_es: "Puma",
  ua_es: "Under Armour",
  nb_es: "New Balance",
  footlocker_es: "Foot Locker",
  jd_sports_es: "JD Sports",
  zalando_es: "Zalando",
  sprinter_es: "Sprinter",
  reebok_es: "Reebok",
  basket_world: "Basket World",
  aliexpress: "AliExpress",
  kickscrew: "KicksCrew",
  idealo: "Idealo",
};

const LABELS_FUENTE: Record<string, string> = {
  weartesters: "WearTesters",
  "hoops-geek": "TheHoopsGeek",
  "runrepeat-lab": "RunRepeat Lab",
  schwollo: "Schwollo",
  "evaluacion-propia": "Evaluación propia",
};

const ATRIBUTOS: { key: keyof Puntuaciones; label: string }[] = [
  { key: "traccion", label: "Tracción" },
  { key: "amortiguacion", label: "Amortiguación" },
  { key: "respuesta", label: "Respuesta" },
  { key: "soporte_lateral", label: "Soporte lateral" },
  { key: "estabilidad", label: "Estabilidad" },
  { key: "peso_score", label: "Ligereza" },
  { key: "durabilidad_outdoor", label: "Durabilidad outdoor" },
  { key: "ventilacion", label: "Ventilación" },
];

const mejorPrecio = findMejorPrecio(z.links_compra);
const linksOrdenados = [...z.links_compra]
  .filter((l) => l.disponible)
  .sort((a, b) => a.precio_actual - b.precio_actual);

const titulo = `${z.marca} ${z.modelo} · Review y mejor precio`;

// Zapas relacionadas: misma categoría, excluir la actual, top 3 por score medio
function scoreZapa(zap: typeof z): number {
  const vals = Object.values(zap.puntuaciones);
  return vals.reduce((a, b) => a + b, 0) / vals.length;
}
const relacionadas = zapatillas
  .filter(
    (zap) =>
      zap.slug !== z.slug && zap.categoria_principal === z.categoria_principal
  )
  .sort((a, b) => scoreZapa(b) - scoreZapa(a))
  .slice(0, 3);
const descripcion = z.resumen.slice(0, 155);

// Rating agregado: media de los 8 atributos (para schema.org)
const valoresPuntuaciones = Object.values(z.puntuaciones);
const ratingMedio =
  valoresPuntuaciones.reduce((sum, v) => sum + v, 0) /
  valoresPuntuaciones.length;

// JSON-LD: Product + BreadcrumbList combinados con @graph
const jsonLd = {
  "@context": "https://schema.org/",
  "@graph": [
  {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", position: 1, name: "Inicio", item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "Catálogo", item: new URL("/zapatillas", Astro.site).toString() },
    { "@type": "ListItem", position: 3, name: `${z.marca} ${z.modelo}`, item: new URL(`/zapatilla/${z.slug}`, Astro.site).toString() },
  ],
  },
  {
  "@type": "Product",
  name: `${z.marca} ${z.modelo}`,
  image: z.imagen_principal,
  description: z.resumen,
  brand: {
    "@type": "Brand",
    name: z.marca,
  },
  category: "Sports & Outdoors / Basketball Shoes",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: ratingMedio.toFixed(1),
    bestRating: "10",
    ratingCount: z.fuentes.length || 1,
  },
  offers: linksOrdenados.map((link) => ({
    "@type": "Offer",
    url: link.url,
    priceCurrency: "EUR",
    price: link.precio_actual,
    availability: link.disponible
      ? "https://schema.org/InStock"
      : "https://schema.org/OutOfStock",
    seller: {
      "@type": "Organization",
      name: LABELS_TIENDA[link.tienda] || link.tienda,
    },
  })),
  review: {
    "@type": "Review",
    reviewBody: z.veredicto,
    author: {
      "@type": "Organization",
      name: "Cancha",
    },
    reviewRating: {
      "@type": "Rating",
      ratingValue: ratingMedio.toFixed(1),
      bestRating: "10",
      worstRating: "1",
    },
  },
  },
  ],
};
---

<Base
  title={titulo}
  description={descripcion}
  ogType="article"
  ogImage={z.imagen_principal}
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-zinc-950 text-white">
    <!-- Header -->
    <header class="px-6 py-5 border-b border-zinc-800/60 bg-[#0c0c0c]/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="text-2xl font-black tracking-tighter">
          CANCHA<span class="text-orange-500">.</span>
        </a>
        <nav class="hidden sm:flex gap-6 text-xs font-bold text-zinc-400 uppercase tracking-widest">
          <a href="/zapatillas" class="hover:text-orange-500 transition-colors">Catálogo</a>
          <a href="/metodologia" class="hover:text-orange-500 transition-colors">Método</a>
          <a href="/financiacion" class="hover:text-orange-500 transition-colors">$ Financiación</a>
        </nav>
      </div>
    </header>

    <!-- Breadcrumbs -->
    <nav
      class="px-6 py-4 border-b border-zinc-900 text-xs uppercase tracking-widest text-zinc-600"
    >
      <div class="max-w-6xl mx-auto flex items-center gap-2 flex-wrap">
        <a href="/" class="hover:text-orange-500 transition-colors">Inicio</a>
        <span>/</span>
        <a href="/zapatillas" class="hover:text-orange-500 transition-colors"
          >Catálogo</a
        >
        <span>/</span>
        <span class="text-zinc-400">{z.marca} {z.modelo}</span>
      </div>
    </nav>

    <!-- HERO -->
    <section class="px-6 py-12">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10">
        <!-- Galería de imágenes -->
        <div class="flex flex-col gap-3">
          <!-- Imagen principal -->
          <div class="relative overflow-hidden bg-gradient-to-b from-zinc-800 to-zinc-900 border border-zinc-700">
            <img
              id="gallery-main"
              src={z.imagen_principal}
              alt={`${z.marca} ${z.modelo}`}
              class="w-full aspect-[4/3] object-contain p-6 transition-opacity duration-200"
              loading="eager"
              fetchpriority="high"
              onerror="this.onerror=null;this.src='/placeholder-shoe.svg'"
            />
            <div class="absolute top-4 left-4 flex flex-wrap gap-2 max-w-[80%]">
              {
                z.tags.slice(0, 3).map((t) => (
                  <span class="px-2 py-1 bg-zinc-950/80 border border-zinc-700 text-[10px] font-bold uppercase tracking-widest text-zinc-300">
                    {t}
                  </span>
                ))
              }
            </div>
            {z.imagenes.length > 0 && (
              <button
                id="gallery-prev"
                aria-label="Imagen anterior"
                class="absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 bg-zinc-950/80 border border-zinc-700 hover:border-orange-500 text-white flex items-center justify-center transition-colors"
              >‹</button>
              <button
                id="gallery-next"
                aria-label="Imagen siguiente"
                class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 bg-zinc-950/80 border border-zinc-700 hover:border-orange-500 text-white flex items-center justify-center transition-colors"
              >›</button>
            )}
          </div>

          {/* Thumbnails — solo si hay imágenes adicionales */}
          {z.imagenes.length > 0 && (
            <div id="gallery-thumbs" class="flex gap-2 overflow-x-auto pb-1">
              {/* Miniatura principal */}
              <button
                data-gallery-src={z.imagen_principal}
                class="gallery-thumb flex-shrink-0 w-20 aspect-[4/3] border-2 border-orange-500 overflow-hidden"
              >
                <img
                  src={z.imagen_principal}
                  alt={`${z.marca} ${z.modelo} — vista 1`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  onerror="this.onerror=null;this.src='/placeholder-shoe.svg'"
                />
              </button>
              {/* Miniaturas adicionales */}
              {z.imagenes.map((src, i) => (
                <button
                  data-gallery-src={src}
                  class="gallery-thumb flex-shrink-0 w-20 aspect-[4/3] border-2 border-zinc-700 hover:border-orange-500 overflow-hidden transition-colors"
                >
                  <img
                    src={src}
                    alt={`${z.marca} ${z.modelo} — vista ${i + 2}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    onerror="this.onerror=null;this.src='/placeholder-shoe.svg'"
                  />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Info -->
        <div class="flex flex-col gap-5">
          <div>
            <p
              class="text-xs font-black uppercase tracking-widest text-orange-500 mb-2"
            >
              ★ {z.año_lanzamiento}
              {z.signature_player && ` · Signature de ${z.signature_player}`}
            </p>
            <p class="text-sm font-bold uppercase tracking-widest text-zinc-500">
              {z.marca}
            </p>
            <h1
              class="text-4xl md:text-6xl font-black uppercase tracking-tighter leading-none mt-1"
            >
              {z.modelo}
            </h1>
          </div>

          <!-- Score global -->
          <div class="flex items-center gap-4">
            <div class="flex items-baseline gap-2">
              <span class="text-5xl font-black text-orange-500">
                {Math.round(ratingMedio * 10) / 10}
              </span>
              <span class="text-zinc-600 font-bold">/10</span>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">Score global</p>
              <p class="text-[10px] text-zinc-600 uppercase tracking-widest">Media de 8 atributos</p>
            </div>
          </div>

          <p class="text-zinc-300 leading-relaxed">{z.resumen}</p>

          <!-- Datos físicos -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mt-2">
            {[
              { label: "Peso", value: `${z.peso_real_g} g`, sub: "US 9" },
              { label: "Altura", value: z.altura, sub: "" },
              { label: "Horma", value: z.horma, sub: "" },
              { label: "Drop", value: `${z.drop_mm} mm`, sub: "" },
            ].map(s => (
              <div class="bg-zinc-900/60 border border-zinc-800 border-t-2 border-t-orange-500/40 p-3 flex flex-col gap-1">
                <p class="text-[9px] font-bold uppercase tracking-widest text-zinc-500">{s.label}{s.sub && <span class="text-zinc-700 ml-1">({s.sub})</span>}</p>
                <p class="text-lg font-black capitalize leading-none">{s.value}</p>
              </div>
            ))}
          </div>

          <!-- Tecnología -->
          {
            z.tecnologia_clave.length > 0 && (
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">
                  Tecnología clave
                </p>
                <div class="flex flex-wrap gap-2">
                  {z.tecnologia_clave.map((t) => (
                    <span class="px-3 py-1 bg-zinc-900 border border-zinc-800 text-xs font-bold uppercase tracking-wider text-zinc-300">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            )
          }

          <!-- CTA mejor precio -->
          {
            mejorPrecio && (
              <div class="bg-zinc-900 border-2 border-orange-500 p-5 mt-4">
                <p class="text-xs font-bold uppercase tracking-widest text-orange-500 mb-2">
                  Mejor precio actual
                </p>
                <div class="flex items-end justify-between gap-4 flex-wrap">
                  <div>
                    <div class="flex items-baseline gap-3">
                      <p class="text-4xl font-black text-white">
                        {mejorPrecio.precio_actual}€
                      </p>
                      {mejorPrecio.precio_actual < z.precio_msrp_eur && (
                        <>
                          <span class="text-sm line-through text-zinc-600">
                            {z.precio_msrp_eur}€
                          </span>
                          <span class="text-sm font-black text-green-400">
                            -{Math.round((1 - mejorPrecio.precio_actual / z.precio_msrp_eur) * 100)}%
                          </span>
                        </>
                      )}
                    </div>
                    <p class="text-xs text-zinc-500 uppercase tracking-wider mt-1">
                      en {LABELS_TIENDA[mejorPrecio.tienda] || mejorPrecio.tienda}
                    </p>
                  </div>
                  <a
                    href={mejorPrecio.url}
                    target="_blank"
                    rel="noopener noreferrer sponsored"
                    class="px-6 py-4 bg-orange-500 hover:bg-orange-400 text-zinc-950 font-black uppercase tracking-wider text-sm transition-all shadow-[4px_4px_0_0_rgb(250,204,21)] hover:shadow-[6px_6px_0_0_rgb(250,204,21)]"
                  >
                    Ver en {LABELS_TIENDA[mejorPrecio.tienda] || mejorPrecio.tienda} →
                  </a>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- ESPECIFICACIONES -->
    <section class="px-6 py-12 border-b border-zinc-800">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tighter mb-6">Especificaciones</h2>
        <dl class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
          <div class="bg-zinc-800/50 rounded-lg p-3">
            <dt class="text-zinc-500 text-xs uppercase tracking-wide">Altura</dt>
            <dd class="text-white font-medium capitalize mt-0.5">{z.altura}</dd>
          </div>
          <div class="bg-zinc-800/50 rounded-lg p-3">
            <dt class="text-zinc-500 text-xs uppercase tracking-wide">Horma</dt>
            <dd class="text-white font-medium capitalize mt-0.5">{z.horma}</dd>
          </div>
          <div class="bg-zinc-800/50 rounded-lg p-3">
            <dt class="text-zinc-500 text-xs uppercase tracking-wide">Drop</dt>
            <dd class="text-white font-medium mt-0.5">{z.drop_mm} mm</dd>
          </div>
          <div class="bg-zinc-800/50 rounded-lg p-3">
            <dt class="text-zinc-500 text-xs uppercase tracking-wide">Lanzamiento</dt>
            <dd class="text-white font-medium mt-0.5">{z.año_lanzamiento}</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- PUNTUACIONES -->
    <section class="px-6 py-16 bg-zinc-900 border-y border-zinc-800">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-4 mb-10">
          <div class="h-1 flex-1 bg-orange-500"></div>
          <h2
            class="text-3xl md:text-4xl font-black uppercase tracking-tighter"
          >
            Análisis técnico
          </h2>
          <div class="h-1 flex-1 bg-orange-500"></div>
        </div>

        <div class="grid sm:grid-cols-2 gap-x-10 gap-y-6">
          {
            ATRIBUTOS.map(({ key, label }) => {
              const valor = z.puntuaciones[key];
              const pct = (valor / 10) * 100;
              const color = valor >= 8 ? "bg-orange-500" : valor >= 6 ? "bg-yellow-400" : "bg-zinc-500";
              const textColor = valor >= 8 ? "text-orange-500" : valor >= 6 ? "text-yellow-400" : "text-zinc-400";
              return (
                <div class="group">
                  <div class="flex items-center justify-between mb-2">
                    <p class="text-[11px] font-semibold uppercase tracking-widest text-zinc-500 group-hover:text-zinc-300 transition-colors">
                      {label}
                    </p>
                    <p class={`text-xl font-black tabular-nums ${textColor}`}>
                      {valor}<span class="text-zinc-700 text-xs font-bold">/10</span>
                    </p>
                  </div>
                  <div class="h-1.5 bg-zinc-800 rounded-full overflow-hidden">
                    <div class={`h-full rounded-full ${color} transition-all duration-700`} style={`width: ${pct}%;`} />
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- VEREDICTO: pros + contras + veredicto -->
    <section class="px-6 py-16">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-10 mb-12">
          <!-- Pros -->
          <div>
            <p
              class="text-xs font-black uppercase tracking-widest text-orange-500 mb-4"
            >
              ✓ Lo que sí
            </p>
            <ul class="flex flex-col gap-3">
              {
                z.pros.map((p) => (
                  <li class="flex gap-3 text-zinc-300">
                    <span class="text-orange-500 font-black mt-1">+</span>
                    <span>{p}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Contras -->
          <div>
            <p
              class="text-xs font-black uppercase tracking-widest text-zinc-500 mb-4"
            >
              ✗ Lo que no
            </p>
            <ul class="flex flex-col gap-3">
              {
                z.contras.map((c) => (
                  <li class="flex gap-3 text-zinc-300">
                    <span class="text-zinc-500 font-black mt-1">−</span>
                    <span>{c}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Veredicto destacado -->
        <div class="bg-zinc-900 border-l-4 border-orange-500 p-6 md:p-8">
          <p
            class="text-xs font-black uppercase tracking-widest text-orange-500 mb-3"
          >
            ★ Veredicto
          </p>
          <p class="text-lg md:text-xl text-white leading-relaxed">
            {z.veredicto}
          </p>
        </div>
      </div>
    </section>

    <!-- PARA QUIÉN -->
    <section class="px-6 py-16 bg-zinc-900 border-y border-zinc-800">
      <div class="max-w-6xl mx-auto">
        <h2
          class="text-3xl md:text-4xl font-black uppercase tracking-tighter mb-10"
        >
          ¿Para quién?
        </h2>
        <div class="grid md:grid-cols-2 gap-10">
          <div>
            <p
              class="text-xs font-black uppercase tracking-widest text-orange-500 mb-3"
            >
              ✓ Recomendada si...
            </p>
            <ul class="space-y-2 text-zinc-300">
              <li>
                <span class="text-zinc-500">·</span> Juegas de:
                <span class="font-bold capitalize">
                  {z.ideal_para.posiciones.join(", ")}
                </span>
              </li>
              <li>
                <span class="text-zinc-500">·</span> Pesas entre
                <span class="font-bold">
                  {z.ideal_para.peso_jugador_kg[0]}-{z.ideal_para.peso_jugador_kg[1]} kg
                </span>
              </li>
              <li>
                <span class="text-zinc-500">·</span> Tu estilo:
                <span class="font-bold capitalize">
                  {z.ideal_para.estilos.join(", ")}
                </span>
              </li>
              {
                z.ideal_para.lesiones_compatibles &&
                  z.ideal_para.lesiones_compatibles.length > 0 && (
                    <li>
                      <span class="text-zinc-500">·</span> Compatible con:{" "}
                      <span class="font-bold capitalize">
                        {z.ideal_para.lesiones_compatibles.join(", ")}
                      </span>
                    </li>
                  )
              }
            </ul>
          </div>
          {
            (
              (z.no_recomendada_para.posiciones?.length ?? 0) +
              (z.no_recomendada_para.estilos?.length ?? 0) +
              (z.no_recomendada_para.lesiones?.length ?? 0)
            ) > 0 && (
              <div>
                <p
                  class="text-xs font-black uppercase tracking-widest text-zinc-500 mb-3"
                >
                  ✗ No recomendada si...
                </p>
                <ul class="space-y-2 text-zinc-300">
                  {
                    z.no_recomendada_para.posiciones &&
                      z.no_recomendada_para.posiciones.length > 0 && (
                        <li>
                          <span class="text-zinc-500">·</span> Juegas de:{" "}
                          <span class="font-bold capitalize">
                            {z.no_recomendada_para.posiciones.join(", ")}
                          </span>
                        </li>
                      )
                  }
                  {
                    z.no_recomendada_para.estilos &&
                      z.no_recomendada_para.estilos.length > 0 && (
                        <li>
                          <span class="text-zinc-500">·</span> Tu estilo:{" "}
                          <span class="font-bold capitalize">
                            {z.no_recomendada_para.estilos.join(", ")}
                          </span>
                        </li>
                      )
                  }
                  {
                    z.no_recomendada_para.lesiones &&
                      z.no_recomendada_para.lesiones.length > 0 && (
                        <li>
                          <span class="text-zinc-500">·</span> Tienes problemas de:{" "}
                          <span class="font-bold capitalize">
                            {z.no_recomendada_para.lesiones.join(", ")}
                          </span>
                        </li>
                      )
                  }
                </ul>
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- PRECIOS EN TODAS LAS TIENDAS -->
    <section class="px-6 py-16">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
          <h2
            class="text-3xl md:text-4xl font-black uppercase tracking-tighter"
          >
            Precios
          </h2>
          <p class="text-xs uppercase tracking-widest text-zinc-500">
            Actualizado:
            <span class="text-zinc-300">{z.ultima_actualizacion}</span>
          </p>
        </div>

        <div class="border-2 border-zinc-800">
          {
            linksOrdenados.length === 0 && (
              <p class="p-6 text-zinc-500 text-center">
                Sin precios disponibles en este momento.
              </p>
            )
          }
          {
            linksOrdenados.map((link, idx) => {
              const diffPct = idx === 0 && link.precio_actual < z.precio_msrp_eur
                ? Math.round((1 - link.precio_actual / z.precio_msrp_eur) * 100)
                : 0;
              return (
                <div
                  class={`flex items-center justify-between gap-4 p-5 flex-wrap ${idx > 0 ? "border-t border-zinc-800" : ""} ${idx === 0 ? "bg-zinc-900" : ""}`}
                >
                  <div class="flex items-center gap-3 min-w-0">
                    {idx === 0 && (
                      <span class="shrink-0 px-2 py-1 bg-yellow-400 text-zinc-950 text-[10px] font-black uppercase tracking-widest">
                        Mejor
                      </span>
                    )}
