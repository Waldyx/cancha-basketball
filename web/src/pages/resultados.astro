---
// /resultados — pantalla de resultados del quiz, rediseñada
// Drop-in replacement for web/src/pages/resultados.astro
//
// La lógica de cliente (lee sessionStorage, llama a recomendar(), renderiza
// 5 cards) se mantiene; solo cambia chrome + estética.

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
---

<Base
  title="Tus 5 zapatillas · CANCHA.ZAPA"
  description="Las 5 zapatillas de baloncesto que mejor encajan con tu perfil."
>
  <main class="app">
    <div class="cz-courtbg"><img src="/bg-court.svg" alt="" /><div></div></div>

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/zapatillas">Catálogo</a>
          <a href="/quiz">Quiz</a>
          <a href="/rankings">Rankings</a>
          <a href="/metodologia">Método</a>
          <a href="/faq">FAQ</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <noscript>
      <div class="rs-noscript">
        <p class="cz-eyebrow">⚠ JavaScript requerido</p>
        <p>Esta página necesita JavaScript para mostrar tus resultados. Actívalo y recarga.</p>
        <a href="/quiz" class="rs-btn primary">← Ir al quiz</a>
      </div>
    </noscript>

    {/* Estado: sin respuestas (no ha hecho el quiz) */}
    <section id="estado-sin-respuestas" class="rs-empty hidden">
      <div class="shell">
        <p class="cz-eyebrow">★ Falta el quiz</p>
        <h1 class="rs-empty-h1">
          Primero el quiz,<br/>
          <span class="muted">luego los resultados.</span>
        </h1>
        <p class="rs-empty-lede">
          Necesitamos saber cómo juegas para recomendarte algo que valga la pena.
          Son 10 preguntas, menos de un minuto.
        </p>
        <a href="/quiz" class="rs-btn primary">→ Empezar el quiz</a>
      </div>
    </section>

    {/* Estado: con resultados */}
    <section id="estado-resultados" class="hidden">
      {/* HERO */}
      <div class="rs-hero">
        <div class="shell">
          <div class="rs-hero-grid">
            <div class="rs-hero-left">
              <p class="cz-eyebrow">★ Tus resultados</p>
              <h1 class="rs-h1">
                Tus<br/>
                <span class="accent">5 zapas</span>
                <span class="italic">a medida</span>
              </h1>
              <p class="rs-lede">
                Ordenadas por compatibilidad técnica con tu perfil.
                Las 5 son buenas opciones — elige la que más te entre por la vista.
              </p>
            </div>

            <aside class="rs-profile-panel">
              <div class="panel-header">
                <span class="dot-pulse"></span>
                <span>TU PERFIL</span>
              </div>
              <div id="resumen-perfil" class="rs-chips"></div>
              <div class="rs-profile-foot">
                <a href="/quiz" class="rs-foot-link">↻ Rehacer quiz</a>
                <span class="sep">·</span>
                <a href="/metodologia" class="rs-foot-link">¿Cómo se calcula?</a>
              </div>
            </aside>
          </div>
        </div>
      </div>

      {/* Recomendaciones (5 cards) */}
      <div class="rs-list-wrap">
        <div class="shell">
          <div id="recomendaciones" class="rs-list"></div>

          {/* Sin matches */}
          <div id="estado-vacio" class="cz-empty hidden">
            <div class="icon">🏀</div>
            <h3>Sin matches con tu perfil</h3>
            <p>Tus criterios son muy específicos. Prueba a relajar el presupuesto o las lesiones.</p>
            <a href="/quiz"><button>↻ Rehacer quiz</button></a>
          </div>
        </div>
      </div>

      {/* Acciones finales */}
      <div class="rs-actions-bar">
        <div class="shell rs-actions">
          <a id="cta-comparar-top3" href="#" class="rs-btn primary hidden">
            ⇄ Comparar las 3 primeras →
          </a>
          <a href="/quiz" class="rs-btn ghost">↻ Rehacer quiz</a>
          <a href="/zapatillas" class="rs-btn ghost">Ver catálogo completo</a>
          <button id="btn-compartir" type="button" class="rs-btn ghost">🔗 Compartir</button>
        </div>
      </div>
    </section>

    <footer style="background:#000;border-top:4px solid #f97316;padding:32px 0;margin-top:40px">
      <div class="shell" style="display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;align-items:center">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/zapatillas">Catálogo</a>
          <a href="/quiz">Quiz</a>
          <a href="/rankings">Rankings</a>
          <a href="/metodologia">Metodología</a>
        </nav>
        <p style="font-size:10px;color:#52525b;text-transform:uppercase;letter-spacing:.15em;font-weight:700;margin:0">
          Proyecto independiente · Sin sesgo de afiliado
        </p>
      </div>
    </footer>
  </main>

  <script>
    import { recomendar } from "../lib/scoring";
    import { zapatillas } from "../data/zapatillas";
    import type { RespuestasQuiz, Recomendacion } from "../lib/types";

    const STORAGE_KEY = "cancha-quiz-respuestas";

    // ── Labels ─────────────────────────────────────────────────
    const LABELS_PERFIL: Record<string, string> = {
      hombre: "Hombre", mujer: "Mujer", junior: "Junior",
    };
    const LABELS_POSICION: Record<string, string> = {
      base: "Base", escolta: "Escolta", alero: "Alero",
      "ala-pivot": "Ala-pívot", pivot: "Pívot",
    };
    const LABELS_PESO: Record<string, string> = {
      "menos-70": "< 70 kg", "70-85": "70-85 kg",
      "85-100": "85-100 kg", "mas-100": "+100 kg",
    };
    const LABELS_ESTILO: Record<string, string> = {
      explosivo: "Explosivo", equilibrado: "Equilibrado",
      potente: "Potente", tirador: "Tirador",
    };
    const LABELS_CANCHA: Record<string, string> = {
      interior: "Interior", exterior: "Exterior", mixto: "Mixto",
    };
    const LABELS_LESION: Record<string, string> = {
      rodillas: "Rodillas", tobillos: "Tobillos", fascia: "Fascia",
    };
    const LABELS_PRIORIDAD: Record<string, string> = {
      proteccion: "Protección", reactividad: "Reactividad",
      "soporte-tobillo": "Soporte tobillo", durabilidad: "Durabilidad",
      precio: "Mejor precio",
    };
    const LABELS_TIENDA: Record<string, string> = {
      amazon_es: "Amazon", decathlon: "Decathlon", nike_es: "Nike",
      adidas_es: "Adidas", puma_es: "Puma", footlocker_es: "Foot Locker",
      jd_sports_es: "JD Sports", zalando_es: "Zalando", sprinter_es: "Sprinter",
      reebok_es: "Reebok", basket_world: "Basket World", aliexpress: "AliExpress",
      kickscrew: "KicksCrew", ua_es: "Under Armour", nb_es: "New Balance",
    };

    // ── Helpers ────────────────────────────────────────────────
    function escapeHtml(s: string): string {
      const div = document.createElement("div");
      div.textContent = s;
      return div.innerHTML;
    }

    function renderResumen(r: RespuestasQuiz): string {
      const chips: { k: string; v: string }[] = [];
      if (r.perfil) chips.push({ k: "Perfil",   v: LABELS_PERFIL[r.perfil] ?? r.perfil });
      chips.push({ k: "Posición",  v: LABELS_POSICION[r.posicion] });
      chips.push({ k: "Peso",      v: LABELS_PESO[r.peso] });
      chips.push({ k: "Estilo",    v: LABELS_ESTILO[r.estilo] });
      chips.push({ k: "Cancha",    v: LABELS_CANCHA[r.cancha] });
      chips.push({ k: "Prioridad", v: LABELS_PRIORIDAD[r.prioridad] });
      if (r.lesiones.length > 0) {
        chips.push({ k: "Lesiones", v: r.lesiones.map(l => LABELS_LESION[l]).join(" · ") });
      }
      chips.push({
        k: "Presupuesto",
        v: r.presupuesto_max_eur !== null ? `≤ ${r.presupuesto_max_eur}€` : "Sin tope",
      });
      return chips
        .map(c => `<div class="rs-chip"><span class="k">${c.k}</span><span class="v">${escapeHtml(c.v)}</span></div>`)
        .join("");
    }

    function matchClass(pct: number): string {
      if (pct >= 80) return "hi";
      if (pct >= 65) return "mid";
      return "lo";
    }

    // ── Radar SVG ──────────────────────────────────────────────
    const RADAR_KEYS = ["traccion", "amortiguacion", "respuesta", "soporte_lateral", "estabilidad", "peso_score", "durabilidad_outdoor", "ventilacion"];
    function radarSvg(z: any, color = "#f97316"): string {
      const SIZE = 80;
      const center = SIZE / 2, R = SIZE / 2 - 4;
      const pts = RADAR_KEYS.map((k, i) => {
        const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
        const r = (z.puntuaciones[k] / 10) * R;
        return [center + Math.cos(a)*r, center + Math.sin(a)*r];
      });
      const path = pts.map(p => p.join(",")).join(" ");
      const rings = [0.33, 0.66, 1].map(f =>
        RADAR_KEYS.map((_, i) => {
          const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
          const r = f * R;
          return `${center + Math.cos(a)*r},${center + Math.sin(a)*r}`;
        }).join(" ")
      );
      return `
        <svg viewBox="0 0 ${SIZE} ${SIZE}" width="${SIZE}" height="${SIZE}" aria-hidden="true">
          ${rings.map(r => `<polygon points="${r}" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>`).join("")}
          <polygon points="${path}" fill="${color}" fill-opacity="0.18" stroke="${color}" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>`;
    }

    // ── Card render ────────────────────────────────────────────
    function renderCard(rec: Recomendacion, rank: number): string {
      const z = rec.zapatilla;
      const matchCls = matchClass(rec.match_pct);
      const mejorPrecio = rec.mejor_precio;
      const precioActual = mejorPrecio?.precio_actual ?? z.precio_msrp_eur;
      const tiendaNombre = mejorPrecio ? LABELS_TIENDA[mejorPrecio.tienda] || mejorPrecio.tienda : "";
      const ahorro = mejorPrecio && mejorPrecio.precio_actual < z.precio_msrp_eur
        ? Math.round((1 - mejorPrecio.precio_actual / z.precio_msrp_eur) * 100) : 0;

      const razonesHtml = rec.razones
        .slice(0, 3)
        .map(r => `<li><span class="bull">✓</span><span>${escapeHtml(r)}</span></li>`)
        .join("");

      const fichaHref = `/zapatilla/${escapeHtml(z.slug)}`;
      const ctaHref = mejorPrecio?.url ?? fichaHref;
      const ctaLabel = mejorPrecio ? `Ver en ${tiendaNombre} →` : `Ver ficha →`;
      const isPrimary = rank === 1;

      return `
        <article class="rs-card ${isPrimary ? "primary" : ""}">
          <div class="rs-card-rank">
            <span class="rsr-num">#${rank}</span>
            ${isPrimary ? `<span class="rsr-crown">★ TU MATCH</span>` : ""}
          </div>

          <a href="${fichaHref}" class="rs-card-photo">
            <img src="${escapeHtml(z.imagen_principal)}" alt="${escapeHtml(z.marca + " " + z.modelo)}"
                 loading="lazy" onerror="this.style.display='none'" />
          </a>

          <div class="rs-card-body">
            <div class="rs-card-head">
              <div>
                <p class="rs-card-marca">${escapeHtml(z.marca)}</p>
                <h2 class="rs-card-modelo"><a href="${fichaHref}">${escapeHtml(z.modelo)}</a></h2>
              </div>
              <div class="rs-card-match ${matchCls}">
                <span class="rsm-num">${rec.match_pct}<small>%</small></span>
                <span class="rsm-lab">match</span>
              </div>
            </div>

            <div class="rs-card-radar">${radarSvg(z)}</div>

            <div class="rs-card-reasons">
              <p class="cz-eyebrow" style="font-size:9px">★ Por qué te encaja</p>
              <ul>${razonesHtml}</ul>
            </div>

            <div class="rs-card-foot">
              <div class="rs-card-price">
                ${mejorPrecio
                  ? `<span class="rs-verif"><span class="dot"></span>Verificado</span>`
                  : `<span class="rs-edit">editorial</span>`}
                <div class="rs-price-row">
                  <span class="rs-price-now">${Math.round(precioActual)}€</span>
                  ${ahorro > 0 ? `
                    <span class="rs-price-msrp">msrp ${z.precio_msrp_eur}€</span>
                    <span class="rs-price-save">−${ahorro}%</span>
                  ` : ""}
                </div>
                ${tiendaNombre ? `<p class="rs-tienda">en ${escapeHtml(tiendaNombre)}</p>` : ""}
              </div>
              <a href="${escapeHtml(ctaHref)}"
                 ${mejorPrecio ? 'target="_blank" rel="noopener noreferrer sponsored"' : ""}
                 class="rs-cta">${escapeHtml(ctaLabel)}</a>
            </div>
          </div>
        </article>
      `;
    }

    // ── Init ───────────────────────────────────────────────────
    const raw = sessionStorage.getItem(STORAGE_KEY);

    if (!raw) {
      document.getElementById("estado-sin-respuestas")!.classList.remove("hidden");
    } else {
      try {
        const respuestas = JSON.parse(raw) as RespuestasQuiz;
        const recomendaciones = recomendar(respuestas, zapatillas, 5);

        document.getElementById("estado-resultados")!.classList.remove("hidden");
        document.getElementById("resumen-perfil")!.innerHTML = renderResumen(respuestas);

        const $list = document.getElementById("recomendaciones")!;
        const $empty = document.getElementById("estado-vacio")!;

        if (recomendaciones.length === 0) {
          $list.classList.add("hidden");
          $empty.classList.remove("hidden");
        } else {
          $list.innerHTML = recomendaciones.map((rec, idx) => renderCard(rec, idx + 1)).join("");

          if (recomendaciones.length >= 2) {
            const topIds = recomendaciones.slice(0, 3).map(r => r.zapatilla.slug).join(",");
            const $cta = document.getElementById("cta-comparar-top3") as HTMLAnchorElement;
            $cta.href = `/comparar?slugs=${topIds}`;
            $cta.classList.remove("hidden");
          }
        }
      } catch (err) {
        console.error("Error parseando respuestas:", err);
        document.getElementById("estado-sin-respuestas")!.classList.remove("hidden");
      }
    }

    // Share button
    const $share = document.getElementById("btn-compartir");
    if ($share) {
      $share.addEventListener("click", () => {
        const url = window.location.href;
        if (navigator.share) {
          navigator.share({ title: "Mis 5 zapas · CANCHA.ZAPA", url });
        } else {
          navigator.clipboard.writeText(url).then(() => {
            $share.textContent = "✓ Enlace copiado";
            setTimeout(() => { $share.textContent = "🔗 Compartir"; }, 2000);
          });
        }
      });
    }
  </script>

  <style>.hidden { display: none !important; }</style>
</Base>
