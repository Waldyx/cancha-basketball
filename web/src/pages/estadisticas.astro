    .st-form-row .st-field { flex: 1 1 120px; }
    .st-form-stats {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(105px, 1fr));
      gap: 10px; margin-bottom: 14px;
    }
    .st-btn {
      background: #f97316; color: #0c0c0c; border: none; cursor: pointer;
      font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; font-size: 12px;
      padding: 12px 18px; border-radius: 0;
