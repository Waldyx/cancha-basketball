---
// /estadisticas — MVP "agente de estadísticas" de baloncesto.
// 100% cliente: los partidos se guardan en localStorage (cz.stats.v1), sin cuentas ni backend.
// Calcula métricas avanzadas (TS%, eFG%, VAL estilo FIBA) y genera análisis automático por reglas.

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
---

<Base
  title="Tus estadísticas de baloncesto · Agente analista | CANCHA.ZAPA"
  description="Registra tus partidos y deja que el agente analice tu juego: TS%, eFG%, valoración, tendencias y consejos concretos. Gratis, sin cuentas, todo en tu navegador."
>
  <main class="app">
    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a>
          <a href="/comparar">Comparar</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/calculadora">Calculadora</a>
          <a href="/estadisticas" class="active" aria-current="page">Stats</a>
          <a href="/balones">Accesorios</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    {/* HERO */}
    <section class="doc-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Stats · Beta</p>
        <h1 class="doc-h1">
          Tus stats,<br/>
          <span class="accent">analizadas</span>
        </h1>
        <p class="doc-lede">
          Apunta tu línea de cada partido y el agente hace el resto: TS%, eFG%, valoración,
          tendencia y consejos concretos para mejorar. Sin cuentas, sin humo — todo se guarda
          en tu navegador.
        </p>
      </div>
    </section>

    <section class="st-main">
      <div class="shell">

        {/* PERFIL + FORMULARIO + RESUMEN */}
        <div class="st-grid">
          <div class="st-col">
            <div class="st-panel">
              <h2 class="st-h2">Tu perfil</h2>
              <div class="st-profile">
                <div class="st-field">
                  <label for="p-nombre">Nombre</label>
                  <input id="p-nombre" type="text" placeholder="Tu nombre" maxlength="30" />
                </div>
                <div class="st-field">
                  <label for="p-pos">Posición</label>
                  <select id="p-pos">
                    <option value="base">Base</option>
                    <option value="escolta">Escolta</option>
                    <option value="alero" selected>Alero</option>
                    <option value="ala-pivot">Ala-pívot</option>
                    <option value="pivot">Pívot</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="st-panel">
              <h2 class="st-h2">Registrar partido</h2>

              <div class="st-import">
                <label for="feb-q">¿Jugaste federado? Importa tu línea del acta oficial (FEB)</label>
                <div class="st-import-row">
                  <input id="feb-q" type="text" placeholder="URL o ID del partido en baloncestoenvivo.feb.es" autocomplete="off" />
                  <button type="button" id="feb-buscar" class="st-btn">Importar</button>
                </div>
                <p id="feb-error" class="st-error hidden"></p>
                <div id="feb-result" class="hidden"></div>
              </div>

              <details class="st-import st-import-paste">
                <summary>¿Cataluña u otra liga? Pega tu acta y la leo</summary>
                <p class="st-paste-help">
                  Abre tu partido en la app o web de tu federación (p. ej. Bàsquet Català),
                  selecciona la tabla de estadísticas de tu equipo y <strong>pégala aquí tal cual</strong>.
                  Detecto las columnas por su cabecera (Punts, T2, T3, TL, Reb, As…) en catalán o castellano.
                </p>
                <textarea id="paste-in" class="st-paste-area" rows="6" placeholder="Dorsal  Jugador  Min  Punts  T2  T3  TL  Reb  As  BR  Tap  PP  Faltes&#10;7  COGNOM, Nom  24  15  4/7  1/3  4/4  6  3  2  0  2  3  …"></textarea>
                <button type="button" id="paste-parse" class="st-btn">Leer acta pegada</button>
                <p id="paste-error" class="st-error hidden"></p>
                <div id="paste-result" class="hidden"></div>
              </details>

              <form id="st-form" novalidate>
                <div class="st-form-row">
                  <div class="st-field">
                    <label for="f-fecha">Fecha</label>
                    <input id="f-fecha" type="date" required />
                  </div>
                  <div class="st-field st-grow">
                    <label for="f-rival">Rival</label>
                    <input id="f-rival" type="text" placeholder="CB Ejemplo" maxlength="40" />
                  </div>
                  <div class="st-field">
                    <label for="f-res">Resultado</label>
                    <select id="f-res">
                      <option value="">—</option>
                      <option value="V">Victoria</option>
                      <option value="D">Derrota</option>
                    </select>
                  </div>
                  <div class="st-field">
                    <label for="f-min">Minutos</label>
                    <input id="f-min" type="number" min="0" max="48" value="20" />
                  </div>
                </div>

                <div class="st-form-stats">
                  <div class="st-field"><label for="f-t2c">T2 metidos</label><input id="f-t2c" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-t2i">T2 intentados</label><input id="f-t2i" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-t3c">T3 metidos</label><input id="f-t3c" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-t3i">T3 intentados</label><input id="f-t3i" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-tlc">TL metidos</label><input id="f-tlc" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-tli">TL intentados</label><input id="f-tli" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-ro">Reb. ofensivos</label><input id="f-ro" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-rd">Reb. defensivos</label><input id="f-rd" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-ast">Asistencias</label><input id="f-ast" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-rob">Robos</label><input id="f-rob" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-tap">Tapones</label><input id="f-tap" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-per">Pérdidas</label><input id="f-per" type="number" min="0" value="0" /></div>
                  <div class="st-field"><label for="f-fal">Faltas</label><input id="f-fal" type="number" min="0" max="6" value="0" /></div>
                </div>

                <p id="st-form-error" class="st-error hidden"></p>
                <button type="submit" class="st-btn">＋ Guardar partido</button>
              </form>
            </div>
          </div>

          <div class="st-col">
            <div class="st-panel">
              <h2 class="st-h2">Temporada <span id="st-pj" class="st-h2-tag">0 partidos</span></h2>
              <div class="st-tiles" id="st-tiles">
                <div class="st-tile"><strong id="t-pts">—</strong><span>puntos / partido</span></div>
                <div class="st-tile"><strong id="t-reb">—</strong><span>rebotes / partido</span></div>
                <div class="st-tile"><strong id="t-ast">—</strong><span>asistencias / partido</span></div>
                <div class="st-tile"><strong id="t-val">—</strong><span>valoración media</span></div>
                <div class="st-tile"><strong id="t-ts">—</strong><span>TS% temporada</span></div>
                <div class="st-tile"><strong id="t-efg">—</strong><span>eFG% temporada</span></div>
              </div>
              <p class="st-note">
                <strong>TS%</strong> = eficiencia real de anotación (tiros de campo + libres).
                <strong>eFG%</strong> = % de tiro ajustado al valor del triple.
                <strong>VAL</strong> = valoración estilo FIBA (aporte total − errores).
              </p>
              <button type="button" id="share-card" class="st-btn st-share-btn" disabled>📸 Compartir mi temporada</button>
              <canvas id="card-canvas" width="1080" height="1080" class="hidden"></canvas>
            </div>

            <div class="st-panel">
              <div class="st-chart-head">
                <h2 class="st-h2">Evolución</h2>
                <div class="st-metric-tabs" role="tablist" aria-label="Métrica del gráfico">
                  <button class="st-mtab active" data-metric="pts" role="tab" aria-selected="true">Puntos</button>
                  <button class="st-mtab" data-metric="val" role="tab" aria-selected="false">Valoración</button>
                  <button class="st-mtab" data-metric="ts" role="tab" aria-selected="false">TS%</button>
                </div>
              </div>
              <div class="st-chart-wrap" id="st-chart-wrap">
                <svg id="st-chart" viewBox="0 0 720 260" preserveAspectRatio="none" role="img" aria-label="Evolución por partido"></svg>
                <div id="st-tooltip" class="st-tooltip hidden"></div>
                <p id="st-chart-empty" class="st-empty">Registra al menos 2 partidos para ver tu evolución.</p>
              </div>
            </div>
          </div>
        </div>

        {/* AGENTE */}
        <div class="st-panel st-agent">
          <h2 class="st-h2">🤖 El agente dice</h2>
          <div id="st-insights" class="st-insights"></div>

          <div class="st-coach">
            <h3 class="st-coach-title">Pregúntale a tu agente</h3>
            <div id="coach-log" class="st-coach-log"></div>
            <div id="coach-suggest" class="st-coach-suggest"></div>
            <form id="coach-form" class="st-coach-form" autocomplete="off">
              <input id="coach-in" class="st-coach-in" placeholder="¿En qué debo mejorar? ¿Cuál fue mi mejor partido?" maxlength="300" />
              <button type="submit" id="coach-send" class="st-btn">Preguntar</button>
            </form>
            <p class="st-coach-note">Al preguntar, las estadísticas de tu temporada se envían al modelo de IA para analizarlas. No se guardan en ningún sitio.</p>
          </div>
        </div>

        {/* DESGLOSE Y RÉCORDS */}
        <div class="st-panel st-splits" id="st-splits-panel">
          <h2 class="st-h2">Rachas y récords</h2>
          <div id="st-splits"></div>
        </div>

        {/* OBJETIVOS */}
        <div class="st-panel st-metas">
          <h2 class="st-h2">Mis objetivos</h2>
          <div class="st-meta-add">
            <select id="meta-tipo" aria-label="Métrica del objetivo"></select>
            <input id="meta-target" type="number" step="0.1" min="0" aria-label="Valor objetivo" />
            <button type="button" id="meta-add" class="st-btn">＋ Añadir objetivo</button>
          </div>
          <div id="st-metas-list"></div>
          <p id="st-metas-empty" class="st-note">Fíjate un objetivo (p. ej. tiros libres al 75%) y te muestro tu progreso partido a partido.</p>
        </div>

        {/* HISTORIAL */}
        <div class="st-panel">
          <h2 class="st-h2">Historial</h2>
          <div class="st-table-wrap">
            <table class="st-table" id="st-table">
              <thead>
                <tr>
                  <th>Fecha</th><th>Rival</th><th>Res</th><th>Min</th><th>PTS</th>
                  <th>T2</th><th>T3</th><th>TL</th><th>REB</th><th>AST</th>
                  <th>ROB</th><th>TAP</th><th>PÉR</th><th>FAL</th><th>TS%</th><th>VAL</th><th></th>
                </tr>
              </thead>
              <tbody id="st-tbody"></tbody>
            </table>
          </div>
          <p id="st-table-empty" class="st-empty">Todavía no hay partidos registrados. <button type="button" id="st-demo" class="st-linkbtn">Ver un ejemplo →</button></p>
        </div>

        {/* DATOS */}
        <div class="st-panel st-data">
          <h2 class="st-h2">Tus datos</h2>
          <p class="st-note">
            Todo vive en tu navegador (localStorage). Si cambias de dispositivo o limpias
            el navegador, se pierde — exporta una copia de vez en cuando.
          </p>
          <div class="st-data-btns">
            <button id="st-export" class="st-btn st-btn-ghost">⬇ Exportar JSON</button>
            <label class="st-btn st-btn-ghost" for="st-import-file" style="cursor:pointer">⬆ Importar JSON
              <input id="st-import-file" type="file" accept="application/json" class="hidden" />
            </label>
            <button id="st-reset" class="st-btn st-btn-danger">✕ Borrar todo</button>
          </div>
        </div>

      </div>
    </section>
  </main>

  <script>
    // ───────────────────────── datos ─────────────────────────
    const LS_KEY = "cz.stats.v1";
    const load = () => {
      const def = () => ({ perfil: { nombre: "", posicion: "alero" }, partidos: [], metas: [] });
      try {
        const raw = localStorage.getItem(LS_KEY);
        if (!raw) return def();
        const d = JSON.parse(raw);
        return {
          perfil: d.perfil && typeof d.perfil === "object" ? d.perfil : { nombre: "", posicion: "alero" },
          partidos: Array.isArray(d.partidos) ? d.partidos : [],
          metas: Array.isArray(d.metas) ? d.metas : [],
        };
      } catch { return def(); }
    };
    const save = () => localStorage.setItem(LS_KEY, JSON.stringify(state));
    let state = load();

    // ─────────────────────── métricas ────────────────────────
    const calcGame = (g) => {
      const pts = 2 * g.t2c + 3 * g.t3c + g.tlc;
      const fgm = g.t2c + g.t3c, fga = g.t2i + g.t3i;
      const tsa = fga + 0.44 * g.tli; // posesiones de tiro reales
      const ts = tsa > 0 ? (pts / (2 * tsa)) * 100 : null;
      const efg = fga > 0 ? ((fgm + 0.5 * g.t3c) / fga) * 100 : null;
      const reb = g.ro + g.rd;
      const val = pts + reb + g.ast + g.rob + g.tap - (fga - fgm) - (g.tli - g.tlc) - g.per - g.fal;
      return { pts, reb, ts, efg, val };
    };

    const calcSeason = (games) => {
      const n = games.length;
      if (!n) return null;
      const sum = (f) => games.reduce((a, g) => a + f(g), 0);
      const pts = sum((g) => 2 * g.t2c + 3 * g.t3c + g.tlc);
      const fgm = sum((g) => g.t2c + g.t3c), fga = sum((g) => g.t2i + g.t3i);
      const tlc = sum((g) => g.tlc), tli = sum((g) => g.tli);
      const t3c = sum((g) => g.t3c), t3i = sum((g) => g.t3i);
      const tsa = fga + 0.44 * tli;
      return {
        n, pts,
        ppg: pts / n,
        rpg: sum((g) => g.ro + g.rd) / n,
        apg: sum((g) => g.ast) / n,
        spg: sum((g) => g.rob) / n,
        fpg: sum((g) => g.fal) / n,
        perTot: sum((g) => g.per),
        astTot: sum((g) => g.ast),
        ts: tsa > 0 ? (pts / (2 * tsa)) * 100 : null,
        efg: fga > 0 ? ((fgm + 0.5 * t3c) / fga) * 100 : null,
        tlPct: tli > 0 ? (tlc / tli) * 100 : null,
        tliPg: tli / n,
        t3Pct: t3i > 0 ? (t3c / t3i) * 100 : null,
        t3iTot: t3i, tliTot: tli,
        valAvg: games.reduce((a, g) => a + calcGame(g).val, 0) / n,
      };
    };

    // Desglose: récords, victorias vs derrotas, y medias por rival.
    const computeSplits = (games) => {
      if (!games.length) return null;
      const wc = games.map((g, i) => ({ g, d: calcGame(g), i }));
      const argmax = (fn) => wc.reduce((b, x) => (fn(x) > fn(b) ? x : b), wc[0]);
      const records = {
        pts: argmax((x) => x.d.pts),
        reb: argmax((x) => x.d.reb),
        ast: argmax((x) => x.g.ast),
        val: argmax((x) => x.d.val),
      };
      const byRes = (res) => {
        const arr = wc.filter((x) => x.g.res === res);
        if (!arr.length) return null;
        return {
          n: arr.length,
          ppg: arr.reduce((a, x) => a + x.d.pts, 0) / arr.length,
          valAvg: arr.reduce((a, x) => a + x.d.val, 0) / arr.length,
        };
      };
      const rivalMap = {};
      wc.forEach((x) => { const k = (x.g.rival || "—").trim() || "—"; (rivalMap[k] ||= []).push(x); });
      const byRival = Object.entries(rivalMap).map(([rival, arr]) => {
        const n = arr.length;
        const v = arr.filter((x) => x.g.res === "V").length;
        const d = arr.filter((x) => x.g.res === "D").length;
        return {
          rival, n, balance: `${v}-${d}`,
          ppg: arr.reduce((a, x) => a + x.d.pts, 0) / n,
          apg: arr.reduce((a, x) => a + x.g.ast, 0) / n,
          valAvg: arr.reduce((a, x) => a + x.d.val, 0) / n,
        };
      }).sort((a, b) => b.n - a.n || b.valAvg - a.valAvg);
      return { records, wins: byRes("V"), losses: byRes("D"), byRival };
    };

    // ─────────────────────── el agente ───────────────────────
    const buildInsights = (games, perfil) => {
      const out = [];
      const push = (tone, icon, titulo, texto) => out.push({ tone, icon, titulo, texto });
      const s = calcSeason(games);
      if (!s) {
        push("info", "🏀", "Sin datos todavía", "Registra tu primer partido y empiezo a analizar tu juego.");
        return out;
      }
      if (s.n < 3) {
        push("info", "📊", "Poca muestra aún", `Con ${s.n} partido${s.n > 1 ? "s" : ""} el análisis es orientativo. A partir de 3 se afina de verdad.`);
      }
      // Eficiencia de anotación
      if (s.ts != null) {
        if (s.ts >= 60) push("good", "🎯", `TS% de élite (${s.ts.toFixed(1)}%)`, "Eficiencia de anotación excelente. Tu selección de tiro es tu arma: mantenla aunque suba el volumen.");
        else if (s.ts >= 54) push("good", "✅", `TS% sólido (${s.ts.toFixed(1)}%)`, "Anotas con buena eficiencia. Para dar el salto, busca más tiros de alto valor: aro y esquinas.");
        else if (s.ts >= 48) push("warn", "⚠️", `TS% mejorable (${s.ts.toFixed(1)}%)`, "Estás por debajo de un anotador eficiente (~55%). Revisa la selección de tiro: menos tiros forzados de media distancia.");
        else push("bad", "🚨", `TS% bajo (${s.ts.toFixed(1)}%)`, "Cada tiro tuyo rinde poco. Prioriza tiros cerca del aro y provocar faltas antes que el volumen exterior.");
      }
      // Tiros libres
      if (s.tlPct != null && s.tliTot >= 8) {
        if (s.tlPct < 65) {
          const perdidos = ((0.75 - s.tlPct / 100) * s.tliPg).toFixed(1);
          push("warn", "🆓", `Tiros libres al ${s.tlPct.toFixed(0)}%`, `Estás dejando ~${perdidos} puntos por partido en la línea (vs un 75% estándar). Es la mejora más barata que existe: 50 libres al final de cada entreno.`);
        } else if (s.tlPct >= 80) {
          push("good", "🆓", `Tiros libres al ${s.tlPct.toFixed(0)}%`, "Fiable desde la línea. En finales apretados, pide el balón.");
        }
      }
      // Triple
      if (s.t3Pct != null && s.t3iTot >= 10) {
        if (s.t3Pct < 28) push("warn", "3️⃣", `Triple al ${s.t3Pct.toFixed(0)}%`, "Por debajo del umbral rentable (~33%). Reduce volumen o trabaja el catch & shoot con los pies puestos.");
        else if (s.t3Pct >= 38) push("good", "3️⃣", `Triple al ${s.t3Pct.toFixed(0)}%`, "Tirador de verdad. Busca más intentos: con ese porcentaje, cada triple abierto que no tiras es un error.");
      }
      // Asistencias vs pérdidas
      if (s.perTot > 0) {
        const ratio = s.astTot / s.perTot;
        if (ratio >= 2) push("good", "🧠", `Ratio AST/PÉR ${ratio.toFixed(1)}`, "Cuidas el balón y generas para otros. Nivel de organizador serio.");
        else if (ratio < 1) push("bad", "🔄", `Ratio AST/PÉR ${ratio.toFixed(1)}`, "Pierdes más balones de los que conviertes en asistencias. Simplifica: menos bote en tráfico, decisiones más rápidas.");
      }
      // Faltas
      if (s.fpg >= 3.5) push("warn", "🖐️", `${s.fpg.toFixed(1)} faltas / partido`, "Vives al borde de la eliminación. Trabaja la posición defensiva para defender con piernas, no con manos.");
      // Tendencia (últimos 3 vs temporada)
      if (s.n >= 5) {
        const last3 = games.slice(-3);
        const v3 = last3.reduce((a, g) => a + calcGame(g).val, 0) / 3;
        if (s.valAvg > 0 && v3 >= s.valAvg * 1.15) push("good", "📈", "Racha al alza", `Tu valoración media en los últimos 3 partidos (${v3.toFixed(1)}) supera claramente tu media de temporada (${s.valAvg.toFixed(1)}). Sigue con lo que estás haciendo.`);
        else if (s.valAvg > 0 && v3 <= s.valAvg * 0.85) push("warn", "📉", "Bajón reciente", `Tus últimos 3 partidos (VAL ${v3.toFixed(1)}) están por debajo de tu media (${s.valAvg.toFixed(1)}). Revisa descanso, minutos y molestias antes de forzar.`);
      }
      // Récord
      if (s.n >= 3) {
        const ptsList = games.map((g) => calcGame(g).pts);
        const last = ptsList[ptsList.length - 1];
        if (last === Math.max(...ptsList) && last > 0) push("good", "🏆", `Récord personal: ${last} puntos`, "Tu último partido es tu mejor marca anotadora de la temporada.");
      }
      // Por posición
      if (perfil.posicion === "base" && s.n >= 3 && s.apg < 3) {
        push("info", "🎮", "Un base que asiste poco", `${s.apg.toFixed(1)} asistencias por partido es poco para un base. Levanta la cabeza al cruzar medio campo: primero pase, luego tiro.`);
      }
      if ((perfil.posicion === "pivot" || perfil.posicion === "ala-pivot") && s.n >= 3 && s.rpg < 6) {
        push("info", "🧱", "Faltan rebotes para un interior", `${s.rpg.toFixed(1)} rebotes por partido es poca captura para tu posición. El rebote es querer: bloquea el rebote SIEMPRE, incluso cuando no vayas a cogerlo.`);
      }
      // Tie-in zapas
      if (s.n >= 3) {
        if (s.spg >= 2) push("info", "👟", "Tu juego pide tracción", `Con ${s.spg.toFixed(1)} robos por partido, vives de las manos rápidas y los cambios de dirección. Prioriza suela con buen agarre → <a href="/quiz">haz el quiz</a> o mira las <a href="/rankings">mejores por tracción</a>.`);
        else if (s.rpg >= 8) push("info", "👟", "Tu juego pide amortiguación", `${s.rpg.toFixed(1)} rebotes por partido = muchos saltos y aterrizajes. Prioriza cushion y estabilidad → <a href="/quiz">haz el quiz</a>.`);
        else push("info", "👟", "¿Zapas a la altura de tus stats?", `Cuéntanos tu posición y estilo en el <a href="/quiz">quiz</a> y te decimos qué zapatilla encaja con tu juego. Sin humo.`);
      }
      return out;
    };

    // ─────────────────────── gráfico ─────────────────────────
    const CHART_COLOR = "#ea580c"; // validado sobre superficie oscura
    const METRICS = {
      pts: { label: "Puntos", get: (d) => d.pts, fmt: (v) => String(Math.round(v)) },
      val: { label: "Valoración", get: (d) => d.val, fmt: (v) => v.toFixed(0) },
      ts:  { label: "TS%", get: (d) => d.ts ?? 0, fmt: (v) => v.toFixed(1) + "%" },
    };
    let currentMetric = "pts";
    let chartPoints = []; // para el hover: [{x,y,g,value}]

    const renderChart = () => {
      const svg = document.getElementById("st-chart");
      const empty = document.getElementById("st-chart-empty");
      const games = state.partidos;
      chartPoints = [];
      svg.innerHTML = "";
      if (games.length < 2) { empty.classList.remove("hidden"); svg.style.display = "none"; return; }
      empty.classList.add("hidden"); svg.style.display = "block";

      const M = METRICS[currentMetric];
      const data = games.map((g) => ({ g, value: M.get(calcGame(g)) }));
      const W = 720, H = 260, padL = 44, padR = 52, padT = 16, padB = 30;
      const iw = W - padL - padR, ih = H - padT - padB;
      let lo = Math.min(0, ...data.map((d) => d.value));
      let hi = Math.max(...data.map((d) => d.value), 1);
      const span = hi - lo || 1;
      hi += span * 0.08;
      const x = (i) => padL + (data.length === 1 ? iw / 2 : (i / (data.length - 1)) * iw);
      const y = (v) => padT + ih - ((v - lo) / (hi - lo)) * ih;
      const NS = "http://www.w3.org/2000/svg";
      const el = (tag, attrs) => {
        const n = document.createElementNS(NS, tag);
        for (const k in attrs) n.setAttribute(k, attrs[k]);
        return n;
      };

      // grid horizontal recesivo + etiquetas de eje
      const ticks = 4;
      for (let t = 0; t <= ticks; t++) {
        const v = lo + ((hi - lo) * t) / ticks;
        const yy = y(v);
        svg.appendChild(el("line", { x1: padL, x2: W - padR, y1: yy, y2: yy, stroke: "rgba(255,255,255,0.07)", "stroke-width": 1 }));
        const lbl = el("text", { x: padL - 8, y: yy + 3, "text-anchor": "end", fill: "#8a8a93", "font-size": 10, "font-family": "Inter, sans-serif" });
        lbl.textContent = currentMetric === "ts" ? v.toFixed(0) : String(Math.round(v));
        svg.appendChild(lbl);
      }
      // línea base (0) si hay valores negativos
      if (lo < 0) svg.appendChild(el("line", { x1: padL, x2: W - padR, y1: y(0), y2: y(0), stroke: "rgba(255,255,255,0.18)", "stroke-width": 1 }));

      // línea de la serie
      const path = data.map((d, i) => `${i ? "L" : "M"}${x(i).toFixed(1)},${y(d.value).toFixed(1)}`).join(" ");
      svg.appendChild(el("path", { d: path, fill: "none", stroke: CHART_COLOR, "stroke-width": 2, "stroke-linejoin": "round", "stroke-linecap": "round" }));

      // marcadores con anillo del color de la superficie
      data.forEach((d, i) => {
        const cx = x(i), cy = y(d.value);
        svg.appendChild(el("circle", { cx, cy, r: 4, fill: CHART_COLOR, stroke: "#333338", "stroke-width": 2 }));
        chartPoints.push({ x: cx, y: cy, g: d.g, value: d.value });
      });

      // etiquetas eje X (J1, J2… cada n para no saturar)
      const step = Math.max(1, Math.ceil(data.length / 8));
      data.forEach((d, i) => {
        if (i % step !== 0 && i !== data.length - 1) return;
        const lbl = el("text", { x: x(i), y: H - 10, "text-anchor": "middle", fill: "#8a8a93", "font-size": 10, "font-family": "Inter, sans-serif" });
        lbl.textContent = "J" + (i + 1);
        svg.appendChild(lbl);
      });

      // etiqueta directa en el último punto (texto en token de texto, no en color de serie)
      const lastI = data.length - 1;
      const dl = el("text", { x: x(lastI) + 9, y: y(data[lastI].value) + 4, fill: "#d4d4d8", "font-size": 12, "font-weight": "700", "font-family": "Inter, sans-serif" });
      dl.textContent = M.fmt(data[lastI].value);
      svg.appendChild(dl);
    };

    // hover: tooltip del punto más cercano
    const wrap = document.getElementById("st-chart-wrap");
    const tooltip = document.getElementById("st-tooltip");
    wrap.addEventListener("mousemove", (ev) => {
      if (!chartPoints.length) return;
      const svg = document.getElementById("st-chart");
      const r = svg.getBoundingClientRect();
      const mx = ((ev.clientX - r.left) / r.width) * 720;
      let best = chartPoints[0], bd = Infinity;
      chartPoints.forEach((p) => { const d = Math.abs(p.x - mx); if (d < bd) { bd = d; best = p; } });
      const M = METRICS[currentMetric];
      const fecha = best.g.fecha || "—";
      const rival = best.g.rival ? ` · vs ${best.g.rival}` : "";
      tooltip.innerHTML = `<strong>${M.fmt(best.value)}</strong> ${M.label}<br/><span>${fecha}${rival}</span>`;
      const px = (best.x / 720) * r.width, py = (best.y / 260) * r.height;
      tooltip.style.left = Math.min(px + 12, r.width - 150) + "px";
      tooltip.style.top = Math.max(py - 48, 4) + "px";
      tooltip.classList.remove("hidden");
    });
    wrap.addEventListener("mouseleave", () => tooltip.classList.add("hidden"));

    document.querySelectorAll(".st-mtab").forEach((btn) => {
      btn.addEventListener("click", () => {
        currentMetric = btn.dataset.metric;
        document.querySelectorAll(".st-mtab").forEach((b) => {
          b.classList.toggle("active", b === btn);
          b.setAttribute("aria-selected", b === btn ? "true" : "false");
        });
        renderChart();
      });
    });

    // ─────────────────────── render ──────────────────────────
    const esc = (s) => String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
    const fmt1 = (v) => (v == null ? "—" : v.toFixed(1));

    const render = () => {
      const games = state.partidos;
      const s = calcSeason(games);
      document.getElementById("st-pj").textContent = `${games.length} partido${games.length === 1 ? "" : "s"}`;
      document.getElementById("t-pts").textContent = s ? fmt1(s.ppg) : "—";
      document.getElementById("t-reb").textContent = s ? fmt1(s.rpg) : "—";
      document.getElementById("t-ast").textContent = s ? fmt1(s.apg) : "—";
      document.getElementById("t-val").textContent = s ? fmt1(s.valAvg) : "—";
      document.getElementById("t-ts").textContent = s && s.ts != null ? s.ts.toFixed(1) + "%" : "—";
      document.getElementById("t-efg").textContent = s && s.efg != null ? s.efg.toFixed(1) + "%" : "—";

      // tabla
      const tbody = document.getElementById("st-tbody");
      tbody.innerHTML = games.map((g, i) => {
        const d = calcGame(g);
        return `<tr>
          <td>${esc(g.fecha || "—")}</td>
          <td>${esc(g.rival || "—")}</td>
          <td>${g.res === "V" ? '<span class="st-w">V</span>' : g.res === "D" ? '<span class="st-l">D</span>' : "—"}</td>
          <td>${g.min}</td>
          <td><strong>${d.pts}</strong></td>
          <td>${g.t2c}/${g.t2i}</td>
          <td>${g.t3c}/${g.t3i}</td>
          <td>${g.tlc}/${g.tli}</td>
          <td>${d.reb}</td>
          <td>${g.ast}</td>
          <td>${g.rob}</td>
          <td>${g.tap}</td>
          <td>${g.per}</td>
          <td>${g.fal}</td>
          <td>${d.ts == null ? "—" : d.ts.toFixed(0) + "%"}</td>
          <td><strong>${d.val}</strong></td>
          <td><button class="st-del" data-i="${i}" aria-label="Borrar partido" title="Borrar">✕</button></td>
        </tr>`;
      }).join("");
      document.getElementById("st-table-empty").classList.toggle("hidden", games.length > 0);
      tbody.querySelectorAll(".st-del").forEach((b) => b.addEventListener("click", () => {
        const g = state.partidos[Number(b.dataset.i)];
        const quien = g && g.rival ? ` vs ${g.rival}` : "";
        if (!confirm(`¿Borrar el partido${quien}? No se puede deshacer.`)) return;
        state.partidos.splice(Number(b.dataset.i), 1);
        save(); render();
      }));

      // agente (los <a> de los insights los generamos nosotros, no el usuario)
      const insights = buildInsights(games, state.perfil);
      document.getElementById("st-insights").innerHTML = insights.map((it) =>
        `<div class="st-insight st-${it.tone}">
          <span class="st-insight-icon">${it.icon}</span>
          <div><strong>${esc(it.titulo)}</strong><p>${it.texto}</p></div>
        </div>`
      ).join("");

      renderChart();
      renderSplits(games);
      renderMetas(s);
      renderCoachSuggest();
      document.getElementById("share-card").disabled = games.length === 0;
    };

    const renderSplits = (games) => {
      const panel = document.getElementById("st-splits-panel");
      const box = document.getElementById("st-splits");
      const sp = computeSplits(games);
      if (!sp) { panel.classList.add("hidden"); box.innerHTML = ""; return; }
      panel.classList.remove("hidden");
      const rec = (r, label) => {
        const via = r.g.rival ? `vs ${esc(r.g.rival)}` : (r.g.fecha || "");
        return `<div class="st-rec"><strong>${label.v}</strong><span class="st-rec-lbl">${label.t}</span><span class="st-rec-via">${via}</span></div>`;
      };
      const records =
        `<div class="st-recs">` +
        rec(sp.records.pts, { v: sp.records.pts.d.pts, t: "máx. puntos" }) +
        rec(sp.records.reb, { v: sp.records.reb.d.reb, t: "máx. rebotes" }) +
        rec(sp.records.ast, { v: sp.records.ast.g.ast, t: "máx. asistencias" }) +
        rec(sp.records.val, { v: sp.records.val.d.val, t: "máx. valoración" }) +
        `</div>`;
      let vd = "";
      if (sp.wins && sp.losses) {
        vd = `<div class="st-vd">
          <div class="st-vd-col st-vd-w"><span class="st-vd-h">En victorias (${sp.wins.n})</span><strong>${fmt1(sp.wins.ppg)} pts</strong><em>VAL ${fmt1(sp.wins.valAvg)}</em></div>
          <div class="st-vd-col st-vd-l"><span class="st-vd-h">En derrotas (${sp.losses.n})</span><strong>${fmt1(sp.losses.ppg)} pts</strong><em>VAL ${fmt1(sp.losses.valAvg)}</em></div>
        </div>`;
      }
      const rivales = sp.byRival.length
        ? `<div class="st-rival-wrap"><table class="st-table st-rival-table"><thead><tr>
             <th>Rival</th><th>PJ</th><th>V-D</th><th>PTS</th><th>AST</th><th>VAL</th></tr></thead><tbody>` +
          sp.byRival.map((r) =>
            `<tr><td>${esc(r.rival)}</td><td>${r.n}</td><td>${r.balance}</td><td>${fmt1(r.ppg)}</td><td>${fmt1(r.apg)}</td><td><strong>${fmt1(r.valAvg)}</strong></td></tr>`
          ).join("") + `</tbody></table></div>`
        : "";
      box.innerHTML = `<h3 class="st-sub">Récords personales</h3>${records}${vd ? `<h3 class="st-sub">Victorias vs derrotas</h3>${vd}` : ""}<h3 class="st-sub">Por rival</h3>${rivales}`;
    };

    // ─────────────────────── objetivos ───────────────────────
    // dir: "gte" = cuanto más alto mejor · "lte" = cuanto más bajo mejor
    const META_DEFS = {
      ts:  { label: "TS% (tiro real)", unit: "%", dir: "gte", def: 55, get: (s) => s.ts },
      tl:  { label: "Tiros libres", unit: "%", dir: "gte", def: 75, get: (s) => s.tlPct },
      t3:  { label: "Triple", unit: "%", dir: "gte", def: 33, get: (s) => s.t3Pct },
      ppg: { label: "Puntos / partido", unit: "", dir: "gte", def: 15, get: (s) => s.ppg },
      apg: { label: "Asistencias / partido", unit: "", dir: "gte", def: 4, get: (s) => s.apg },
      val: { label: "Valoración media", unit: "", dir: "gte", def: 12, get: (s) => s.valAvg },
      per: { label: "Pérdidas / partido", unit: "", dir: "lte", def: 2, get: (s) => (s.n ? s.perTot / s.n : null) },
    };

    const renderMetas = (s) => {
      const list = document.getElementById("st-metas-list");
      const empty = document.getElementById("st-metas-empty");
      const metas = state.metas || [];
      empty.classList.toggle("hidden", metas.length > 0);
      list.innerHTML = metas.map((m, i) => {
        const def = META_DEFS[m.id];
        if (!def) return "";
        const cur = s ? def.get(s) : null;
        const target = Number(m.target);
        let pct = 0, hit = false, curTxt = "—";
        if (cur != null) {
          curTxt = fmt1(cur) + def.unit;
          if (def.dir === "gte") { pct = target > 0 ? Math.min(100, (cur / target) * 100) : 100; hit = cur >= target; }
          else { pct = cur > 0 ? Math.min(100, (target / cur) * 100) : 100; hit = cur <= target; }
        }
        return `<div class="st-meta ${hit ? "st-meta-hit" : ""}">
          <div class="st-meta-top">
            <span class="st-meta-lbl">${def.dir === "lte" ? "≤ " : ""}${esc(def.label)}</span>
            <span class="st-meta-val">${curTxt} <em>/ ${fmt1(target)}${def.unit}</em> ${hit ? "✓" : ""}</span>
            <button type="button" class="st-meta-del" data-i="${i}" aria-label="Quitar objetivo" title="Quitar">✕</button>
          </div>
          <div class="st-meta-bar"><span style="width:${pct.toFixed(0)}%"></span></div>
        </div>`;
      }).join("");
      list.querySelectorAll(".st-meta-del").forEach((b) => b.addEventListener("click", () => {
        state.metas.splice(Number(b.dataset.i), 1); save(); render();
      }));
    };

    // ──────────────── agente conversacional (IA) ─────────────
    const coachMessages = []; // historial {role, content} para el contexto del modelo
    const SUGERENCIAS = [
      "¿En qué debo mejorar?",
      "¿Cuál fue mi mejor partido?",
      "¿Cómo es mi selección de tiro?",
      "¿Contra qué rival juego mejor?",
    ];
    const coachLog = document.getElementById("coach-log");
    const coachIn = document.getElementById("coach-in");
    const coachSend = document.getElementById("coach-send");

    const linkify = (s) => esc(s).replace(/(\/(quiz|rankings|zapatillas|calculadora|comparar)\b)/g, '<a href="$1">$1</a>');
    const addBubble = (role, text, cls) => {
      const div = document.createElement("div");
      div.className = "st-bubble st-bubble-" + role + (cls ? " " + cls : "");
      div.innerHTML = role === "coach" ? linkify(text).replace(/\n/g, "<br/>") : esc(text);
      coachLog.appendChild(div);
      coachLog.scrollTop = coachLog.scrollHeight;
      return div;
    };

    const renderCoachSuggest = () => {
      const box = document.getElementById("coach-suggest");
      // solo mostramos sugerencias si hay partidos y aún no se ha preguntado nada
      if (!state.partidos.length || coachMessages.length) { box.innerHTML = ""; return; }
      box.innerHTML = SUGERENCIAS.map((q) => `<button type="button" class="st-chip">${esc(q)}</button>`).join("");
      box.querySelectorAll(".st-chip").forEach((b) => b.addEventListener("click", () => askCoach(b.textContent)));
    };

    const askCoach = async (question) => {
      const q = String(question || "").trim();
      if (!q) return;
      if (!state.partidos.length) { addBubble("coach", "Aún no tienes partidos. Apunta o importa alguno y te analizo el juego."); return; }
      document.getElementById("coach-suggest").innerHTML = "";
      addBubble("user", q);
      coachMessages.push({ role: "user", content: q });
      coachIn.value = "";
      coachSend.disabled = true;
      const thinking = addBubble("coach", "Analizando tus partidos…", "st-bubble-wait");
      try {
        const partidos = state.partidos.map((g) => {
          const d = calcGame(g);
          return { fecha: g.fecha, rival: g.rival, res: g.res, min: g.min, pts: d.pts, reb: d.reb,
            ast: g.ast, rob: g.rob, tap: g.tap, per: g.per, fal: g.fal, ts: d.ts, val: d.val };
        });
        const r = await fetch("/api/coach", {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ perfil: state.perfil, resumen: calcSeason(state.partidos), partidos, messages: coachMessages }),
        });
        const d = await r.json();
        const reply = d.reply || "No he podido responder ahora mismo. Reinténtalo.";
        thinking.remove();
        addBubble("coach", reply);
        if (r.ok) coachMessages.push({ role: "assistant", content: reply });
        if (window.plausible) window.plausible("Coach Question");
      } catch {
        thinking.remove();
        addBubble("coach", "No he podido conectar con el agente. Reinténtalo en un momento.");
      } finally {
        coachSend.disabled = false;
      }
    };

    document.getElementById("coach-form").addEventListener("submit", (ev) => { ev.preventDefault(); askCoach(coachIn.value); });

    // ──────────────── tarjeta compartible (canvas) ───────────
    const drawCard = (s, perfil, best) => {
      const cv = document.getElementById("card-canvas");
      const ctx = cv.getContext("2d");
      const W = 1080, H = 1080, P = 76;
      // fondo
      ctx.fillStyle = "#232327"; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = "#2b2b30"; ctx.fillRect(0, 0, W, 8);
      ctx.fillStyle = "#f97316"; ctx.fillRect(0, 0, 360, 8);
      const BC = "'Barlow Condensed', sans-serif", IN = "'Inter', sans-serif";
      // logo
      ctx.textBaseline = "alphabetic";
      ctx.font = `900 58px ${BC}`;
      ctx.textAlign = "left";
      let x = P, y = 128;
      ctx.fillStyle = "#fff"; ctx.fillText("CANCHA", x, y); x += ctx.measureText("CANCHA").width;
      ctx.fillStyle = "#f97316"; ctx.fillText(".", x, y); x += ctx.measureText(".").width;
      ctx.fillStyle = "#fff"; ctx.fillText("ZAPA", x, y);
      // eyebrow + nombre + sub
      ctx.fillStyle = "#f97316"; ctx.font = `700 27px ${IN}`;
      ctx.fillText("★ MI TEMPORADA", P, 214);
      ctx.fillStyle = "#fff"; ctx.font = `900 84px ${BC}`;
      const nombre = (perfil?.nombre || "MI JUGADOR").toUpperCase().slice(0, 18);
      ctx.fillText(nombre, P, 300);
      ctx.fillStyle = "#a1a1aa"; ctx.font = `600 30px ${IN}`;
      const pos = (perfil?.posicion || "").replace("-", "-");
      ctx.fillText(`${pos ? pos.charAt(0).toUpperCase() + pos.slice(1) + " · " : ""}${s.n} partido${s.n === 1 ? "" : "s"}`, P, 346);
      // 2x2 tiles grandes
      const gap = 22, tw = (W - P * 2 - gap) / 2, th = 190, ty = 392;
      const bigTiles = [
        [fmt1(s.ppg), "PUNTOS / PARTIDO"],
        [fmt1(s.rpg), "REBOTES / PARTIDO"],
        [fmt1(s.apg), "ASISTENCIAS / PARTIDO"],
        [fmt1(s.valAvg), "VALORACIÓN MEDIA"],
      ];
      bigTiles.forEach((t, i) => {
        const col = i % 2, row = (i / 2) | 0;
        const tx = P + col * (tw + gap), tyy = ty + row * (th + gap);
        ctx.fillStyle = "#2c2c31"; ctx.fillRect(tx, tyy, tw, th);
        ctx.fillStyle = "#f97316"; ctx.fillRect(tx, tyy, 6, th);
        ctx.textAlign = "left";
        ctx.fillStyle = "#fff"; ctx.font = `900 108px ${BC}`;
        ctx.fillText(t[0], tx + 34, tyy + 120);
        ctx.fillStyle = "#8a8a93"; ctx.font = `700 24px ${IN}`;
        ctx.fillText(t[1], tx + 36, tyy + 160);
      });
      // fila de 3 secundarias
      const sy = ty + 2 * (th + gap) + 8, sw = (W - P * 2 - gap * 2) / 3, sh = 150;
      const smallTiles = [
        [s.ts == null ? "—" : fmt1(s.ts) + "%", "TS% (TIRO REAL)"],
        [s.efg == null ? "—" : fmt1(s.efg) + "%", "eFG%"],
        [String(best || 0), "SU MEJOR PARTIDO (PTS)"],
      ];
      smallTiles.forEach((t, i) => {
        const tx = P + i * (sw + gap);
        ctx.fillStyle = "#2c2c31"; ctx.fillRect(tx, sy, sw, sh);
        ctx.textAlign = "center";
        ctx.fillStyle = "#facc15"; ctx.font = `900 66px ${BC}`;
        ctx.fillText(t[0], tx + sw / 2, sy + 82);
        ctx.fillStyle = "#8a8a93"; ctx.font = `700 20px ${IN}`;
        ctx.fillText(t[1], tx + sw / 2, sy + 120);
      });
      // footer
      ctx.textAlign = "center";
      ctx.fillStyle = "#f97316"; ctx.font = `800 30px ${IN}`;
      ctx.fillText("canchazapa.com/estadisticas", W / 2, H - 54);
    };

    const shareBtn = document.getElementById("share-card");
    shareBtn.addEventListener("click", async () => {
      const games = state.partidos;
      const s = calcSeason(games);
      if (!s) return;
      const best = games.reduce((m, g) => Math.max(m, calcGame(g).pts), 0);
      await (document.fonts?.ready ?? Promise.resolve());
      drawCard(s, state.perfil, best);
      const cv = document.getElementById("card-canvas");
      cv.toBlob(async (blob) => {
        if (!blob) return;
        const file = new File([blob], "mi-temporada-canchazapa.png", { type: "image/png" });
        const shareData = { files: [file], text: "Mi temporada 🏀 analizada en canchazapa.com/estadisticas" };
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          try { await navigator.share(shareData); if (window.plausible) window.plausible("Season Card Share"); return; } catch { /* cancelado → cae a descarga */ }
        }
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob); a.download = file.name; a.click();
        URL.revokeObjectURL(a.href);
        if (window.plausible) window.plausible("Season Card Download");
      }, "image/png");
    });

    // ─────────────────────── formulario ──────────────────────
    const num = (id) => {
      const v = parseInt(document.getElementById(id).value, 10);
      return Number.isFinite(v) && v >= 0 ? v : 0;
    };
    document.getElementById("f-fecha").value = new Date().toISOString().slice(0, 10);

    document.getElementById("st-form").addEventListener("submit", (ev) => {
      ev.preventDefault();
      const g = {
        fecha: document.getElementById("f-fecha").value,
        rival: document.getElementById("f-rival").value.trim(),
        res: document.getElementById("f-res").value,
        min: num("f-min"),
        t2c: num("f-t2c"), t2i: num("f-t2i"),
        t3c: num("f-t3c"), t3i: num("f-t3i"),
        tlc: num("f-tlc"), tli: num("f-tli"),
        ro: num("f-ro"), rd: num("f-rd"),
        ast: num("f-ast"), rob: num("f-rob"), tap: num("f-tap"),
        per: num("f-per"), fal: num("f-fal"),
      };
      const err = document.getElementById("st-form-error");
      const fail = (msg) => { err.textContent = msg; err.classList.remove("hidden"); };
      if (g.t2c > g.t2i) return fail("T2 metidos no puede superar a intentados.");
      if (g.t3c > g.t3i) return fail("T3 metidos no puede superar a intentados.");
      if (g.tlc > g.tli) return fail("TL metidos no puede superar a intentados.");
      if (!g.fecha) return fail("Pon la fecha del partido.");
      err.classList.add("hidden");
      state.partidos.push(g);
      state.partidos.sort((a, b) => (a.fecha < b.fecha ? -1 : a.fecha > b.fecha ? 1 : 0));
      save(); render();
      // reset de contadores (fecha y rival se mantienen para tandas de carga)
      ["f-t2c","f-t2i","f-t3c","f-t3i","f-tlc","f-tli","f-ro","f-rd","f-ast","f-rob","f-tap","f-per","f-fal"].forEach((id) => {
        document.getElementById(id).value = "0";
      });
      if (window.plausible) window.plausible("Stat Game Logged");
    });

    // ──────────────── importar acta FEB ──────────────────────
    const febError = document.getElementById("feb-error");
    const febResult = document.getElementById("feb-result");
    const febFail = (msg) => { febError.textContent = msg; febError.classList.remove("hidden"); febResult.classList.add("hidden"); };

    const fillFromFeb = (j, meta, source) => {
      const set = (id, v) => { document.getElementById(id).value = String(v); };
      set("f-fecha", meta.fecha || new Date().toISOString().slice(0, 10));
      set("f-rival", meta.rival);
      document.getElementById("f-res").value = meta.res;
      set("f-min", Math.min(48, j.min));
      set("f-t2c", j.t2c); set("f-t2i", j.t2i);
      set("f-t3c", j.t3c); set("f-t3i", j.t3i);
      set("f-tlc", j.tlc); set("f-tli", j.tli);
      set("f-ro", j.ro); set("f-rd", j.rd);
      set("f-ast", j.ast); set("f-rob", j.rob); set("f-tap", j.tap);
      set("f-per", j.per); set("f-fal", Math.min(6, j.fal));
      febResult.classList.add("hidden");
      const form = document.getElementById("st-form");
      form.scrollIntoView({ behavior: "smooth", block: "center" });
      febError.classList.add("hidden");
      if (window.plausible) window.plausible(source === "paste" ? "Acta Paste Import" : "FEB Import");
    };

    document.getElementById("feb-q").addEventListener("keydown", (ev) => {
      if (ev.key === "Enter") { ev.preventDefault(); document.getElementById("feb-buscar").click(); }
    });
    document.getElementById("feb-buscar").addEventListener("click", async () => {
      const q = document.getElementById("feb-q").value.trim();
      if (!q) return febFail("Pega la URL del partido (o su ID numérico).");
      febError.classList.add("hidden");
      febResult.innerHTML = '<p class="st-empty">Leyendo el acta…</p>';
      febResult.classList.remove("hidden");
      try {
        const r = await fetch(`/api/feb?partido=${encodeURIComponent(q)}`);
        const d = await r.json();
        if (!r.ok) return febFail(d.error || "No se pudo leer el acta.");
        if (!d.equipos || d.equipos.length !== 2) return febFail("El acta no tiene estadísticas todavía.");
        const [a, b] = d.equipos;
        const resFor = (own, other) => (own.pts > other.pts ? "V" : own.pts < other.pts ? "D" : "");
        febResult.innerHTML =
          `<p class="st-import-hint">${esc(d.competicion)} · ${esc(d.fecha)} · ${esc(a.nombre)} ${a.pts}–${b.pts} ${esc(b.nombre)}<br/><strong>Toca tu nombre</strong> para rellenar el formulario:</p>` +
          d.equipos.map((eq, ti) =>
            `<div class="st-import-team"><h3>${esc(eq.nombre)}</h3><div class="st-import-players">` +
            eq.jugadores.map((j, ji) =>
              `<button type="button" class="st-player" data-t="${ti}" data-j="${ji}"><span>${esc(j.dorsal)}</span>${esc(j.nombre)}</button>`
            ).join("") + `</div></div>`
          ).join("");
        febResult.querySelectorAll(".st-player").forEach((btn) => {
          btn.addEventListener("click", () => {
            const ti = Number(btn.dataset.t), ji = Number(btn.dataset.j);
            const own = d.equipos[ti], other = d.equipos[1 - ti];
            fillFromFeb(own.jugadores[ji], { fecha: d.fecha, rival: other.nombre, res: resFor(own, other) });
          });
        });
      } catch {
        febFail("No se pudo leer el acta. Comprueba la URL y reintenta.");
      }
    });

    // ──────────── importar acta PEGADA (Cataluña / genérico) ──────────
    // Detecta las columnas por su cabecera (catalán/castellano) → no asume orden.
    // Sinónimos normalizados (sin acentos ni símbolos): cabecera → campo interno.
    const COLS = {
      dorsal: ["dorsal", "d", "num", "numero", "no", "n"],
      nombre: ["jugador", "jugadora", "nom", "nombre", "name", "cognom", "cognoms", "jugadores"],
      min: ["min", "minuts", "minutos", "m"],
      pts: ["punts", "puntos", "pts", "pt", "p"],
      t2: ["t2", "2p", "tir2", "tirsde2", "t2ci", "2punts", "2puntos"],
      t2c: ["t2c", "2pc", "c2", "t2m", "t2a"],
      t2i: ["t2i", "2pi", "i2", "t2int"],
      t3: ["t3", "3p", "tir3", "tirsde3", "t3ci", "3punts", "3puntos"],
      t3c: ["t3c", "3pc", "c3", "t3m"],
      t3i: ["t3i", "3pi", "i3", "t3int"],
      tl: ["t1", "tl", "tll", "1p", "tir1", "tirslliures", "tiroslibres", "tlci"],
      tlc: ["t1c", "tlc", "1pc", "c1", "t1m"],
      tli: ["t1i", "tli", "1pi", "i1", "t1int"],
      ro: ["ro", "rebof", "rebotofensiu", "rof", "rebotesofensivos"],
      rd: ["rd", "rebdef", "rebotdefensiu", "rdef", "rebotesdefensivos"],
      rt: ["rt", "reb", "rebot", "rebots", "rebotes", "r", "reboundstotals"],
      ast: ["as", "assist", "assistencies", "asistencias", "ass", "assis", "a"],
      rob: ["br", "rec", "recuperacions", "robos", "robatoris", "recuperaciones", "recup", "rb"],
      tap: ["tap", "taps", "tapones", "tp", "ta"],
      per: ["pp", "perdues", "pilotesperdudes", "perdidas", "balonesperdidos", "bp", "per", "perd", "pilperdudes"],
      fal: ["fp", "faltes", "faltas", "faltespersonals", "faltescomeses", "fc", "f"],
    };
    const normHead = (s) => String(s).toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9]/g, "");
    const pInt = (v) => { const m = String(v).match(/-?\d+/); const x = m ? parseInt(m[0], 10) : 0; return Number.isFinite(x) && x >= 0 ? x : 0; };
    const splitMA = (v) => { const m = String(v).match(/(\d+)\s*[\/\-]\s*(\d+)/); return m ? [+m[1], +m[2]] : null; };

    function parsePaste(raw) {
      const lines = raw.replace(/\r/g, "").split("\n").map((l) => l.trim()).filter(Boolean);
      if (lines.length < 2) throw new Error("Pega al menos la fila de cabecera y una de jugador.");
      const tok = (l) => (l.includes("\t") ? l.split("\t") : l.split(/ {2,}|\t/)).map((x) => x.trim()).filter((x) => x !== "");
      // Busca la cabecera: la línea (de las primeras) con más columnas reconocidas
      let headerMap = null, headerIdx = -1, best = 0;
      for (let i = 0; i < Math.min(lines.length, 5); i++) {
        const cells = tok(lines[i]); const map = {}; let score = 0;
        cells.forEach((c, idx) => {
          const n = normHead(c);
          for (const field in COLS) { if (COLS[field].includes(n)) { if (!(idx in map)) { map[idx] = field; score++; } break; } }
        });
        if (score > best) { best = score; headerMap = map; headerIdx = i; }
      }
      if (best < 3) throw new Error("No reconozco las columnas. Copia también la fila de cabecera (Min, Punts, T2, T3, TL, Reb…).");
      const jugadores = [];
      for (let i = headerIdx + 1; i < lines.length; i++) {
        const cells = tok(lines[i]);
        if (!cells.length) continue;
        const g = { nombre: "", dorsal: "", min: 0, t2c: 0, t2i: 0, t3c: 0, t3i: 0, tlc: 0, tli: 0, ro: 0, rd: 0, ast: 0, rob: 0, tap: 0, per: 0, fal: 0 };
        let rt = null, hasStat = false;
        cells.forEach((cell, idx) => {
          const field = headerMap[idx];
          if (!field) return;
          if (field === "nombre") { g.nombre = cell; return; }
          if (field === "dorsal") { g.dorsal = cell.replace(/[^0-9]/g, ""); return; }
          const ma = splitMA(cell);
          if (field === "t2") { if (ma) { g.t2c = ma[0]; g.t2i = ma[1]; hasStat = true; } return; }
          if (field === "t3") { if (ma) { g.t3c = ma[0]; g.t3i = ma[1]; hasStat = true; } return; }
          if (field === "tl") { if (ma) { g.tlc = ma[0]; g.tli = ma[1]; hasStat = true; } return; }
          if (field === "rt") { rt = pInt(cell); return; }
          if (field === "pts") { hasStat = true; return; } // pts se recalcula; solo marca fila válida
          g[field] = pInt(cell); if (g[field]) hasStat = true;
        });
        // Si no hay nombre marcado, coge el primer token no numérico largo
        if (!g.nombre) {
          const cand = cells.find((c) => /[a-zà-ú]{3,}/i.test(c) && !/^\d/.test(c));
          if (cand) g.nombre = cand;
        }
        // Rebotes: si solo hay total (rt) y no O/D, mételo como defensivos (preserva el total)
        if (rt != null && g.ro === 0 && g.rd === 0) g.rd = rt;
        if (g.nombre && hasStat) jugadores.push(g);
      }
      if (!jugadores.length) throw new Error("Reconocí la cabecera pero no encontré filas de jugador debajo.");
      return jugadores;
    }

    const pasteError = document.getElementById("paste-error");
    const pasteResult = document.getElementById("paste-result");
    const pasteFail = (m) => { pasteError.textContent = m; pasteError.classList.remove("hidden"); pasteResult.classList.add("hidden"); };

    document.getElementById("paste-parse").addEventListener("click", () => {
      const raw = document.getElementById("paste-in").value;
      if (!raw.trim()) return pasteFail("Pega el acta en el recuadro.");
      let jugadores;
      try { jugadores = parsePaste(raw); }
      catch (e) { return pasteFail(e.message); }
      pasteError.classList.add("hidden");
      pasteResult.innerHTML =
        `<p class="st-import-hint">${jugadores.length} jugador${jugadores.length === 1 ? "" : "es"} detectado${jugadores.length === 1 ? "" : "s"}. <strong>Toca tu nombre</strong> para rellenar el formulario (revísalo antes de guardar):</p>` +
        `<div class="st-import-players">` +
        jugadores.map((j, ji) =>
          `<button type="button" class="st-player" data-j="${ji}"><span>${esc(j.dorsal || "·")}</span>${esc(j.nombre)}</button>`
        ).join("") + `</div>`;
      pasteResult.classList.remove("hidden");
      pasteResult.querySelectorAll(".st-player").forEach((btn) => {
        btn.addEventListener("click", () => {
          fillFromFeb(jugadores[Number(btn.dataset.j)], { fecha: new Date().toISOString().slice(0, 10), rival: "", res: "" }, "paste");
        });
      });
    });

    // ─────────────────────── perfil ──────────────────────────
    const inNombre = document.getElementById("p-nombre");
    const inPos = document.getElementById("p-pos");
    inNombre.value = state.perfil.nombre || "";
    inPos.value = state.perfil.posicion || "alero";
    inNombre.addEventListener("change", () => { state.perfil.nombre = inNombre.value.trim(); save(); });
    inPos.addEventListener("change", () => { state.perfil.posicion = inPos.value; save(); render(); });

    // ─────────────────── export / import / reset ─────────────
    document.getElementById("st-export").addEventListener("click", () => {
      const blob = new Blob([JSON.stringify(state, null, 2)], { type: "application/json" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = "canchazapa-stats.json";
      a.click();
      URL.revokeObjectURL(a.href);
    });
    document.getElementById("st-import-file").addEventListener("change", (ev) => {
      const file = ev.target.files && ev.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        try {
          const d = JSON.parse(String(reader.result));
          if (!d || !Array.isArray(d.partidos)) throw new Error("formato");
          state = {
            perfil: d.perfil && typeof d.perfil === "object" ? d.perfil : state.perfil,
            partidos: d.partidos,
            metas: Array.isArray(d.metas) ? d.metas : [],
          };
          save();
          inNombre.value = state.perfil.nombre || "";
          inPos.value = state.perfil.posicion || "alero";
          render();
        } catch { alert("Ese archivo no parece un export válido de CANCHA.ZAPA Stats."); }
      };
      reader.readAsText(file);
      ev.target.value = "";
    });
    document.getElementById("st-reset").addEventListener("click", () => {
      if (!confirm("¿Borrar TODOS tus partidos y perfil? Esto no se puede deshacer.")) return;
      state = { perfil: { nombre: "", posicion: "alero" }, partidos: [], metas: [] };
      save();
      inNombre.value = ""; inPos.value = "alero";
      render();
    });

    // "Ver ejemplo": carga partidos de muestra para que un visitante nuevo vea
    // la herramienta funcionando (solo visible en el estado vacío).
    document.getElementById("st-demo").addEventListener("click", () => {
      state = {
        perfil: { nombre: "Ejemplo", posicion: "base" },
        metas: [{ id: "ts", target: 55 }, { id: "tl", target: 75 }],
        partidos: [
          { fecha: "2026-06-01", rival: "CB Nord", res: "V", min: 26, t2c: 4, t2i: 8, t3c: 1, t3i: 4, tlc: 3, tli: 6, ro: 1, rd: 4, ast: 6, rob: 2, tap: 0, per: 3, fal: 2 },
          { fecha: "2026-06-08", rival: "CB Sud", res: "D", min: 28, t2c: 5, t2i: 12, t3c: 0, t3i: 4, tlc: 2, tli: 3, ro: 2, rd: 5, ast: 4, rob: 3, tap: 1, per: 4, fal: 3 },
          { fecha: "2026-06-15", rival: "CB Nord", res: "V", min: 30, t2c: 7, t2i: 12, t3c: 3, t3i: 6, tlc: 6, tli: 7, ro: 1, rd: 6, ast: 7, rob: 2, tap: 1, per: 1, fal: 2 },
          { fecha: "2026-06-22", rival: "CB Est", res: "V", min: 24, t2c: 6, t2i: 10, t3c: 2, t3i: 5, tlc: 4, tli: 5, ro: 2, rd: 3, ast: 5, rob: 4, tap: 0, per: 2, fal: 4 },
        ],
      };
      save();
      inNombre.value = state.perfil.nombre; inPos.value = state.perfil.posicion;
      render();
      document.getElementById("st-splits-panel").scrollIntoView({ behavior: "smooth", block: "start" });
    });

    // init objetivos: rellena el select y el valor por defecto
    const metaTipo = document.getElementById("meta-tipo");
    const metaTarget = document.getElementById("meta-target");
    metaTipo.innerHTML = Object.entries(META_DEFS).map(([id, d]) => `<option value="${id}">${d.label}</option>`).join("");
    metaTarget.value = String(META_DEFS[metaTipo.value].def);
    metaTipo.addEventListener("change", () => { metaTarget.value = String(META_DEFS[metaTipo.value].def); });
    document.getElementById("meta-add").addEventListener("click", () => {
      const id = metaTipo.value, target = parseFloat(metaTarget.value);
      if (!META_DEFS[id] || !Number.isFinite(target) || target < 0) return;
      state.metas = state.metas || [];
      const ex = state.metas.findIndex((m) => m.id === id);
      if (ex >= 0) state.metas[ex].target = target; else state.metas.push({ id, target });
      save(); render();
    });

    render();
  </script>

  <style is:global>
