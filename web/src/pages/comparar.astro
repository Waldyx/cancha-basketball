---
// /comparar — comparador rediseñado
// Drop-in replacement for web/src/pages/comparar.astro
//
// Lee las zapas a comparar desde la URL (?slugs=A,B,C). Si no hay,
// usa 3 destacadas por defecto. Click en cualquier foto para cambiar.

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
import { zapatillas } from "../data/zapatillas";

const CAT_LABELS: Record<string, string> = {
  "cushion-focused": "Cushion", "responsive": "Reactiva",
  "balanced": "Equilibrada", "traction-king": "Tracción",
};
const CAT_ACCENT: Record<string, string> = {
  "cushion-focused": "#38bdf8", "responsive": "#facc15",
  "balanced": "#d4d4d8", "traction-king": "#fb923c",
};
const ATR_LABELS: Record<string, string> = {
  traccion: "Tracción", amortiguacion: "Amortiguación",
  respuesta: "Respuesta", soporte_lateral: "Soporte",
  estabilidad: "Estabilidad", peso_score: "Ligereza",
  durabilidad_outdoor: "Outdoor", ventilacion: "Ventilación",
};

const scoreOf = (z: typeof zapatillas[0]): number => {
  const v = Object.values(z.puntuaciones);
  return Math.round((v.reduce((a, b) => a + b, 0) / v.length) * 10) / 10;
};

// Read ?slugs= from URL
const params = new URLSearchParams(Astro.url.search);
const slugsParam = params.get("slugs");
const requested = slugsParam ? slugsParam.split(",") : ["nike-lebron-22", "ua-curry-12", "nike-gt-cut-3"];
const shoes = requested.map(s => zapatillas.find(z => z.slug === s)).filter(Boolean) as typeof zapatillas;

// Winner per attribute (highest = best for all 8 attrs in this data model)
const winnerFor = (key: keyof typeof zapatillas[0]["puntuaciones"]): number | null => {
  if (shoes.length < 2) return null;
  let bestIdx = 0;
  for (let i = 1; i < shoes.length; i++) {
    if (shoes[i].puntuaciones[key] > shoes[bestIdx].puntuaciones[key]) bestIdx = i;
  }
  return bestIdx;
};
const cheapestIdx = shoes.length >= 2
  ? shoes.reduce((bi, z, i, arr) => z.precio_msrp_eur < arr[bi].precio_msrp_eur ? i : bi, 0)
  : null;

// Radar SVG helper (inline)
const RADAR_KEYS = ["traccion", "amortiguacion", "respuesta", "soporte_lateral", "estabilidad", "peso_score", "durabilidad_outdoor", "ventilacion"] as const;
const SIZE = 120;
function radarPoints(z: typeof zapatillas[0]) {
  return RADAR_KEYS.map((k, i) => {
    const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
    const v = z.puntuaciones[k];
    const r = (v / 10) * (SIZE / 2 - 6);
    return [SIZE/2 + Math.cos(a)*r, SIZE/2 + Math.sin(a)*r].join(",");
  }).join(" ");
}
function ringPoints(f: number) {
  return RADAR_KEYS.map((_, i) => {
    const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
    const r = f * (SIZE / 2 - 6);
    return `${SIZE/2 + Math.cos(a)*r},${SIZE/2 + Math.sin(a)*r}`;
  }).join(" ");
}
---

<Base title="Comparar zapatillas de baloncesto cara a cara | CANCHA"
      description="Compara hasta 3 zapatillas de baloncesto en 8 atributos, peso, drop, horma y precio. Vista lado a lado sin trampa.">
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo">CANCHA<span class="dot">.</span>ZAPA</a>
        <nav class="cz-nav">
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/quiz">Quiz</a>
          <a href="/metodologia">Método</a>
          <a href="/faq">FAQ</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <section class="cmp-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Comparador</p>
        <h1 class="cmp-h1">Cara a cara<br/><span class="muted">sin trampa.</span></h1>
        <p class="cmp-blurb">Hasta 3 zapas, 8 atributos, precio y veredicto editorial. Cambia cualquier slot clicando en el modelo.</p>
      </div>
    </section>

    <section class="cmp-grid-section">
      <div class="shell">
        <div class="cmp-grid">
          {/* Labels column */}
          <div class="cmp-col cmp-col-labels">
            <div class="cmp-cell head">&nbsp;</div>
            <div class="cmp-cell"><span class="cmp-lab">Marca · Modelo</span></div>
            <div class="cmp-cell"><span class="cmp-lab">Categoría</span></div>
            <div class="cmp-cell"><span class="cmp-lab">Score CANCHA</span></div>
            <div class="cmp-cell radar"><span class="cmp-lab">Perfil técnico</span></div>
            {Object.entries(ATR_LABELS).map(([k, l]) => (
              <div class="cmp-cell"><span class="cmp-lab">{l}</span></div>
            ))}
            <div class="cmp-cell"><span class="cmp-lab">Peso real (US 9)</span></div>
            <div class="cmp-cell"><span class="cmp-lab">Altura</span></div>
            <div class="cmp-cell"><span class="cmp-lab">Drop</span></div>
            <div class="cmp-cell"><span class="cmp-lab">Horma</span></div>
            <div class="cmp-cell"><span class="cmp-lab">Ideal para</span></div>
            <div class="cmp-cell price-row"><span class="cmp-lab">Precio MSRP</span></div>
            <div class="cmp-cell">&nbsp;</div>
          </div>

          {/* Shoe columns */}
          {shoes.map((z, idx) => {
            const cat = CAT_ACCENT[z.categoria_principal];
            const sc = scoreOf(z);
            return (
              <div class="cmp-col" style={`--cat:${cat}`}>
                <div class="cmp-cell head">
                  <button class="cmp-photo" data-slot={idx}>
                    <img src={z.imagen_principal} alt={z.modelo} onerror="this.style.display='none'" />
                    <span class="cmp-photo-overlay">cambiar ↺</span>
                  </button>
                </div>
                <div class="cmp-cell">
                  <p class="cmp-marca">{z.marca}</p>
                  <h3 class="cmp-modelo">{z.modelo}</h3>
                </div>
                <div class="cmp-cell"><span class="cmp-cat" style={`color:${cat}`}>{CAT_LABELS[z.categoria_principal]}</span></div>
                <div class="cmp-cell"><span class="cmp-score-big">{sc}<small>/10</small></span></div>
                <div class="cmp-cell radar">
                  <div class="cmp-radar-wrap">
                    <svg viewBox={`0 0 ${SIZE} ${SIZE}`} width={SIZE} height={SIZE} aria-hidden="true">
                      {[0.33, 0.66, 1].map(f => (
                        <polygon points={ringPoints(f)} fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
                      ))}
                      <polygon points={radarPoints(z)} fill={cat} fill-opacity="0.18" stroke={cat} stroke-width="1.5" />
                    </svg>
                  </div>
                </div>
                {Object.entries(ATR_LABELS).map(([k]) => {
                  const winner = winnerFor(k as keyof typeof z.puntuaciones);
                  return (
                    <div class={`cmp-cell metric ${winner === idx ? "winner" : ""}`}>
                      <span class="cmp-val">{z.puntuaciones[k as keyof typeof z.puntuaciones]}<small>/10</small></span>
                      {winner === idx && <span class="cmp-win-tag">Mejor</span>}
                    </div>
                  );
                })}
                <div class="cmp-cell"><span class="cmp-val">{z.peso_real_g}<small>g</small></span></div>
                <div class="cmp-cell"><span class="cmp-val capz">{z.altura}</span></div>
                <div class="cmp-cell"><span class="cmp-val">{z.drop_mm}<small>mm</small></span></div>
                <div class="cmp-cell"><span class="cmp-val capz">{z.horma}</span></div>
                <div class="cmp-cell ideal">{z.ideal_para.posiciones.join(", ")}</div>
                <div class={`cmp-cell price-row ${cheapestIdx === idx && shoes.length > 1 ? "winner" : ""}`}>
                  <span class="cmp-price">{z.precio_msrp_eur}€</span>
                  {cheapestIdx === idx && shoes.length > 1 && <span class="cmp-win-tag">Más barata</span>}
                </div>
                <div class="cmp-cell">
                  <a href={`/zapatilla/${z.slug}`} class="cmp-cta">Ver review →</a>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <footer style="background:#000;border-top:4px solid #f97316;padding:32px 0;margin-top:40px">
      <div class="shell" style="display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;align-items:center">
        <div class="cz-logo">CANCHA<span class="dot">.</span>ZAPA</div>
        <p style="font-size:10px;color:#52525b;text-transform:uppercase;letter-spacing:.15em;font-weight:700;margin:0">
          Proyecto independiente · Sin sesgo de afiliado
        </p>
      </div>
    </footer>
  </main>

  <script define:vars={{ zapatillas: zapatillas.map(z => ({ slug: z.slug, marca: z.marca, modelo: z.modelo, img: z.imagen_principal })), initialSlugs: requested }}>
    // Slot picker — click on a photo to swap that slot.
    let current = [...initialSlugs];
    const photos = document.querySelectorAll(".cmp-photo");
    photos.forEach(btn => {
      btn.addEventListener("click", () => {
        const slot = parseInt(btn.dataset.slot);
        showPicker(slot);
      });
    });

    function showPicker(slot) {
      const overlay = document.createElement("div");
      overlay.className = "cmp-picker";
      const remaining = zapatillas.filter(z => !current.includes(z.slug));
      overlay.innerHTML = `
        <div class="cmp-picker-card" onclick="event.stopPropagation()">
          <p class="cz-eyebrow">★ Cambiar zapa ${slot + 1}</p>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:32px;text-transform:uppercase;letter-spacing:-0.03em;margin:6px 0 14px">Elige otra zapa</h3>
          <div class="cmp-picker-grid">
            ${remaining.map(z => `
              <button class="cmp-pick-item" data-slug="${z.slug}">
                <img src="${z.img}" alt="" onerror="this.style.display='none'">
                <span class="cpi-name"><strong>${z.marca}</strong>${z.modelo}</span>
              </button>
            `).join("")}
          </div>
          <button class="cmp-pick-close">Cerrar</button>
        </div>
      `;
      overlay.addEventListener("click", () => overlay.remove());
      overlay.querySelector(".cmp-pick-close").addEventListener("click", () => overlay.remove());
      overlay.querySelectorAll(".cmp-pick-item").forEach(item => {
        item.addEventListener("click", () => {
          current[slot] = item.dataset.slug;
          // Reload with new slugs
          location.search = `?slugs=${current.join(",")}`;
        });
      });
      document.body.appendChild(overlay);
    }
  </script>
</Base>
