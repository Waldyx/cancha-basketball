---
// /comparar — comparador rediseñado
// Drop-in replacement for web/src/pages/comparar.astro
//
// La página es estática: el render inicial (SEO / sin JS) usa 3 zapas por
// defecto o las del parámetro ?slugs=. El cambio de zapa se hace en cliente
// (JS), sin recargar, porque un sitio estático no puede leer la query en runtime.

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
import { zapatillas } from "../data/zapatillas";

const CAT_LABELS: Record<string, string> = {
  "cushion-focused": "Cushion", "responsive": "Reactiva",
  "balanced": "Equilibrada", "traction-king": "Tracción",
};
const CAT_ACCENT: Record<string, string> = {
  "cushion-focused": "#38bdf8", "responsive": "#facc15",
  "balanced": "#d4d4d8", "traction-king": "#fb923c",
};
const ATR_LABELS: Record<string, string> = {
  traccion: "Tracción", amortiguacion: "Amortiguación",
  respuesta: "Respuesta", soporte_lateral: "Soporte",
  estabilidad: "Estabilidad", peso_score: "Ligereza",
  durabilidad_outdoor: "Outdoor", ventilacion: "Ventilación",
};

const scoreOf = (z: typeof zapatillas[0]): number => {
  const v = Object.values(z.puntuaciones);
  return Math.round((v.reduce((a, b) => a + b, 0) / v.length) * 10) / 10;
};

// Read ?slugs= from URL (solo para el render inicial en build)
const params = new URLSearchParams(Astro.url.search);
const slugsParam = params.get("slugs");
const requested = slugsParam ? slugsParam.split(",") : ["nike-lebron-22", "ua-curry-12", "nike-gt-cut-3"];
const shoes = requested.map(s => zapatillas.find(z => z.slug === s)).filter(Boolean) as typeof zapatillas;

// Winner per attribute (highest = best for all 8 attrs in this data model)
const winnerFor = (key: keyof typeof zapatillas[0]["puntuaciones"]): number | null => {
  if (shoes.length < 2) return null;
  let bestIdx = 0;
  for (let i = 1; i < shoes.length; i++) {
    if (shoes[i].puntuaciones[key] > shoes[bestIdx].puntuaciones[key]) bestIdx = i;
  }
  return bestIdx;
};
const cheapestIdx = shoes.length >= 2
  ? shoes.reduce((bi, z, i, arr) => z.precio_msrp_eur < arr[bi].precio_msrp_eur ? i : bi, 0)
  : null;

// Radar SVG helper (inline)
const RADAR_KEYS = ["traccion", "amortiguacion", "respuesta", "soporte_lateral", "estabilidad", "peso_score", "durabilidad_outdoor", "ventilacion"] as const;
const SIZE = 120;
function radarPoints(z: typeof zapatillas[0]) {
  return RADAR_KEYS.map((k, i) => {
    const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
    const v = z.puntuaciones[k];
    const r = (v / 10) * (SIZE / 2 - 6);
    return [SIZE/2 + Math.cos(a)*r, SIZE/2 + Math.sin(a)*r].join(",");
  }).join(" ");
}
function ringPoints(f: number) {
  return RADAR_KEYS.map((_, i) => {
    const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
    const r = f * (SIZE / 2 - 6);
    return `${SIZE/2 + Math.cos(a)*r},${SIZE/2 + Math.sin(a)*r}`;
  }).join(" ");
}
const ringFracs = [0.33, 0.66, 1];
---

<Base title="Comparar zapatillas de baloncesto cara a cara | CANCHA"
      description="Compara hasta 3 zapatillas de baloncesto en 8 atributos, peso, drop, horma y precio. Vista lado a lado sin trampa.">
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo">CANCHA<span class="dot">.</span>ZAPA</a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a> <a href="/comparar" class="active" aria-current="page">Comparar</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/calculadora">Calculadora</a>
          <a href="/balones">Accesorios</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <section class="cmp-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Comparador</p>
        <h1 class="cmp-h1">Cara a cara<br/><span style="color:#f97316">sin trampa.</span></h1>
        <p class="cmp-blurb">Hasta 3 zapas, 8 atributos, precio y veredicto editorial. Cambia cualquier slot clicando en el modelo.</p>
      </div>
    </section>

    <section class="cmp-grid-section">
      <div class="shell">
        <div class="cmp-grid" id="cmp-grid" data-cols={shoes.length}>
          {/* HEAD */}
          <div class="cmp-cell head lab">&nbsp;</div>
          {shoes.map((z, idx) => (
            <div class="cmp-cell head" style={`--cat:${CAT_ACCENT[z.categoria_principal]}`}>
              <button class="cmp-photo" data-slot={idx}>
                <img src={z.imagen_principal} alt={z.modelo} onerror="this.style.display='none'" />
                <span class="cmp-photo-overlay">cambiar ↺</span>
              </button>
            </div>
          ))}

          {/* MARCA · MODELO */}
          <div class="cmp-cell lab"><span class="cmp-lab">Marca · Modelo</span></div>
          {shoes.map((z) => (
            <div class="cmp-cell"><p class="cmp-marca">{z.marca}</p><h3 class="cmp-modelo">{z.modelo}</h3></div>
          ))}

          {/* CATEGORÍA */}
          <div class="cmp-cell lab"><span class="cmp-lab">Categoría</span></div>
          {shoes.map((z) => (
            <div class="cmp-cell"><span class="cmp-cat" style={`color:${CAT_ACCENT[z.categoria_principal]}`}>{CAT_LABELS[z.categoria_principal]}</span></div>
          ))}

          {/* SCORE */}
          <div class="cmp-cell lab"><span class="cmp-lab">Score CANCHA</span></div>
          {shoes.map((z) => (
            <div class="cmp-cell"><span class="cmp-score-big">{scoreOf(z)}<small>/10</small></span></div>
          ))}

          {/* RADAR */}
          <div class="cmp-cell radar lab"><span class="cmp-lab">Perfil técnico</span></div>
          {shoes.map((z) => (
            <div class="cmp-cell radar">
              <div class="cmp-radar-wrap">
                <svg viewBox={`0 0 ${SIZE} ${SIZE}`} width={SIZE} height={SIZE} aria-hidden="true">
                  {ringFracs.map(f => (
                    <polygon points={ringPoints(f)} fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
                  ))}
                  <polygon points={radarPoints(z)} fill={CAT_ACCENT[z.categoria_principal]} fill-opacity="0.18" stroke={CAT_ACCENT[z.categoria_principal]} stroke-width="1.5" />
                </svg>
              </div>
            </div>
          ))}

          {/* 8 ATRIBUTOS */}
          {Object.entries(ATR_LABELS).map(([k, l]) => (
            <Fragment>
              <div class="cmp-cell lab"><span class="cmp-lab">{l}</span></div>
              {shoes.map((z, idx) => {
                const winner = winnerFor(k as keyof typeof z.puntuaciones);
                return (
                  <div class={`cmp-cell metric ${winner === idx ? "winner" : ""}`}>
                    <span class="cmp-val">{z.puntuaciones[k as keyof typeof z.puntuaciones]}<small>/10</small></span>
                    {winner === idx && <span class="cmp-win-tag">Mejor</span>}
                  </div>
                );
              })}
            </Fragment>
          ))}

          {/* PESO */}
          <div class="cmp-cell lab"><span class="cmp-lab">Peso real (US 9)</span></div>
          {shoes.map((z) => (<div class="cmp-cell"><span class="cmp-val">{z.peso_real_g}<small>g</small></span></div>))}

          {/* ALTURA */}
          <div class="cmp-cell lab"><span class="cmp-lab">Altura</span></div>
          {shoes.map((z) => (<div class="cmp-cell"><span class="cmp-val capz">{z.altura}</span></div>))}

          {/* DROP */}
          <div class="cmp-cell lab"><span class="cmp-lab">Drop</span></div>
          {shoes.map((z) => (<div class="cmp-cell"><span class="cmp-val">{z.drop_mm}<small>mm</small></span></div>))}

          {/* HORMA */}
          <div class="cmp-cell lab"><span class="cmp-lab">Horma</span></div>
          {shoes.map((z) => (<div class="cmp-cell"><span class="cmp-val capz">{z.horma}</span></div>))}

          {/* IDEAL PARA */}
          <div class="cmp-cell lab"><span class="cmp-lab">Ideal para</span></div>
          {shoes.map((z) => (<div class="cmp-cell ideal">{z.ideal_para.posiciones.join(", ")}</div>))}

          {/* PRECIO */}
          <div class="cmp-cell lab price-row"><span class="cmp-lab">Precio MSRP</span></div>
          {shoes.map((z, idx) => (
            <div class={`cmp-cell price-row ${cheapestIdx === idx && shoes.length > 1 ? "winner" : ""}`}>
              <span class="cmp-price">{z.precio_msrp_eur}€</span>
              {cheapestIdx === idx && shoes.length > 1 && <span class="cmp-win-tag">Más barata</span>}
            </div>
          ))}

          {/* CTA */}
          <div class="cmp-cell lab">&nbsp;</div>
          {shoes.map((z) => (
            <div class="cmp-cell"><a href={`/zapatilla/${z.slug}`} class="cmp-cta">Ver review →</a></div>
          ))}
        </div>
      </div>
    </section>

  </main>

  <script define:vars={{ DATA: zapatillas.map(z => ({ slug: z.slug, marca: z.marca, modelo: z.modelo, img: z.imagen_principal, cat: z.categoria_principal, punt: z.puntuaciones, peso: z.peso_real_g, altura: z.altura, drop: z.drop_mm, horma: z.horma, ideal: z.ideal_para.posiciones.join(", "), precio: z.precio_msrp_eur, es_retro: z.es_retro ?? false })), initialSlugs: requested, CAT_LABELS, CAT_ACCENT, ATR_LABELS, RADAR_KEYS, SIZE }}>
    const RINGS = [0.33, 0.66, 1];
    const grid = document.getElementById("cmp-grid");

    function scoreOf(d) {
      const v = Object.values(d.punt);
      return Math.round((v.reduce((a, b) => a + b, 0) / v.length) * 10) / 10;
    }
    function radarPoints(d) {
      return RADAR_KEYS.map((k, i) => {
        const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
        const r = (d.punt[k] / 10) * (SIZE / 2 - 6);
        return (SIZE/2 + Math.cos(a)*r) + "," + (SIZE/2 + Math.sin(a)*r);
      }).join(" ");
    }
    function ringPoints(f) {
      return RADAR_KEYS.map((_, i) => {
        const a = (i / RADAR_KEYS.length) * Math.PI * 2 - Math.PI / 2;
        const r = f * (SIZE / 2 - 6);
        return (SIZE/2 + Math.cos(a)*r) + "," + (SIZE/2 + Math.sin(a)*r);
      }).join(" ");
    }
    function winnerFor(shoes, key) {
      if (shoes.length < 2) return null;
      let b = 0;
      for (let i = 1; i < shoes.length; i++) {
        if (shoes[i].punt[key] > shoes[b].punt[key]) b = i;
      }
      return b;
    }
    function esc(s) {
      return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function render(slugs) {
      const shoes = slugs.map(s => DATA.find(d => d.slug === s)).filter(Boolean);
      if (!shoes.length) return;
      const cheapest = shoes.length >= 2
        ? shoes.reduce((bi, z, i, arr) => z.precio < arr[bi].precio ? i : bi, 0)
        : -1;
      let h = "";

      // head
      h += `<div class="cmp-cell head lab">&nbsp;</div>`;
      shoes.forEach((z, idx) => {
        h += `<div class="cmp-cell head" style="--cat:${CAT_ACCENT[z.cat]}">
          <button class="cmp-photo" data-slot="${idx}">
            <img src="${esc(z.img)}" alt="${esc(z.modelo)}" onerror="this.style.display='none'">
            <span class="cmp-photo-overlay">cambiar ↺</span>
          </button></div>`;
      });

      // marca modelo
      h += `<div class="cmp-cell lab"><span class="cmp-lab">Marca · Modelo</span></div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell"><p class="cmp-marca">${esc(z.marca)}</p><h3 class="cmp-modelo">${esc(z.modelo)}</h3></div>`; });

      // categoría
      h += `<div class="cmp-cell lab"><span class="cmp-lab">Categoría</span></div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell"><span class="cmp-cat" style="color:${CAT_ACCENT[z.cat]}">${CAT_LABELS[z.cat]}</span></div>`; });

      // score
      h += `<div class="cmp-cell lab"><span class="cmp-lab">Score CANCHA</span></div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell"><span class="cmp-score-big">${scoreOf(z)}<small>/10</small></span></div>`; });

      // radar
      h += `<div class="cmp-cell radar lab"><span class="cmp-lab">Perfil técnico</span></div>`;
      shoes.forEach(z => {
        const rings = RINGS.map(f => `<polygon points="${ringPoints(f)}" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"></polygon>`).join("");
        h += `<div class="cmp-cell radar"><div class="cmp-radar-wrap"><svg viewBox="0 0 ${SIZE} ${SIZE}" width="${SIZE}" height="${SIZE}" aria-hidden="true">${rings}<polygon points="${radarPoints(z)}" fill="${CAT_ACCENT[z.cat]}" fill-opacity="0.18" stroke="${CAT_ACCENT[z.cat]}" stroke-width="1.5"></polygon></svg></div></div>`;
      });

      // 8 atributos
      Object.keys(ATR_LABELS).forEach(k => {
        h += `<div class="cmp-cell lab"><span class="cmp-lab">${ATR_LABELS[k]}</span></div>`;
        const w = winnerFor(shoes, k);
        shoes.forEach((z, idx) => {
          h += `<div class="cmp-cell metric ${w === idx ? "winner" : ""}"><span class="cmp-val">${z.punt[k]}<small>/10</small></span>${w === idx ? '<span class="cmp-win-tag">Mejor</span>' : ""}</div>`;
        });
      });

      // peso
      h += `<div class="cmp-cell lab"><span class="cmp-lab">Peso real (US 9)</span></div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell"><span class="cmp-val">${z.peso}<small>g</small></span></div>`; });
      // altura
      h += `<div class="cmp-cell lab"><span class="cmp-lab">Altura</span></div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell"><span class="cmp-val capz">${esc(z.altura)}</span></div>`; });
      // drop
      h += `<div class="cmp-cell lab"><span class="cmp-lab">Drop</span></div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell"><span class="cmp-val">${z.drop}<small>mm</small></span></div>`; });
      // horma
      h += `<div class="cmp-cell lab"><span class="cmp-lab">Horma</span></div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell"><span class="cmp-val capz">${esc(z.horma)}</span></div>`; });
      // ideal
      h += `<div class="cmp-cell lab"><span class="cmp-lab">Ideal para</span></div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell ideal">${esc(z.ideal)}</div>`; });
      // precio
      h += `<div class="cmp-cell lab price-row"><span class="cmp-lab">Precio MSRP</span></div>`;
      shoes.forEach((z, idx) => { h += `<div class="cmp-cell price-row ${cheapest === idx && shoes.length > 1 ? "winner" : ""}"><span class="cmp-price">${z.precio}€</span>${cheapest === idx && shoes.length > 1 ? '<span class="cmp-win-tag">Más barata</span>' : ""}</div>`; });
      // cta
      h += `<div class="cmp-cell lab">&nbsp;</div>`;
      shoes.forEach(z => { h += `<div class="cmp-cell"><a href="/zapatilla/${z.slug}" class="cmp-cta">Ver review →</a></div>`; });

      grid.setAttribute("data-cols", String(shoes.length));
      grid.innerHTML = h;
      attachPhotos();
    }

    // ── Slot picker ──
    let current = [...initialSlugs];

    function attachPhotos() {
      grid.querySelectorAll(".cmp-photo").forEach(btn => {
        btn.addEventListener("click", () => showPicker(parseInt(btn.dataset.slot)));
      });
    }

    function buildItems(retroOnly, q) {
      const query = (q || "").trim().toLowerCase();
      const remaining = DATA.filter(z => !current.includes(z.slug)
        && (!retroOnly || z.es_retro)
        && (!query || (z.marca + " " + z.modelo).toLowerCase().includes(query)));
      return remaining.map(z => `
        <button class="cmp-pick-item" data-slug="${z.slug}">
          <img src="${esc(z.img)}" alt="" onerror="this.style.display='none'">
          <span class="cpi-name"><strong>${esc(z.marca)}</strong> ${esc(z.modelo)}${z.es_retro ? ' <span style="color:#fbbf24">🏅</span>' : ''}</span>
        </button>`).join("") || `<p style="color:var(--cz-text-muted);grid-column:1/-1;padding:20px;text-align:center">Sin resultados con este filtro.</p>`;
    }

    function attachItemListeners(overlay, slot) {
      overlay.querySelectorAll(".cmp-pick-item").forEach(item => {
        item.addEventListener("click", () => {
          current[slot] = item.dataset.slug;
          overlay.remove();
          render(current);
          try { history.replaceState(null, "", "?slugs=" + current.join(",")); } catch (e) {}
        });
      });
    }

    function showPicker(slot) {
      const overlay = document.createElement("div");
      overlay.className = "cmp-picker";
      let retroOnly = false;
      overlay.innerHTML = `
        <div class="cmp-picker-card" onclick="event.stopPropagation()">
          <p class="cz-eyebrow">★ Cambiar zapa ${slot + 1}</p>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:32px;text-transform:uppercase;letter-spacing:-0.03em;margin:6px 0 10px">Elige otra zapa</h3>
          <div style="margin-bottom:12px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            <input id="cmp-search" type="text" placeholder="Buscar marca o modelo…" autocomplete="off" style="flex:1;min-width:150px;padding:8px 12px;background:rgba(255,255,255,0.04);border:1px solid var(--cz-border2);color:var(--cz-text);font-size:13px;outline:none" />
            <button id="cmp-retro-chip" style="padding:7px 12px;border:1px solid var(--cz-border2);background:transparent;color:var(--cz-text-muted);font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:0.1em;cursor:pointer;transition:all .15s;white-space:nowrap" type="button">🏅 Solo retro</button>
          </div>
          <div class="cmp-picker-grid" id="cmp-picker-items">${buildItems(false, "")}</div>
          <button class="cmp-pick-close">Cerrar</button>
        </div>`;
      overlay.addEventListener("click", () => overlay.remove());
      overlay.querySelector(".cmp-pick-close").addEventListener("click", () => overlay.remove());
      attachItemListeners(overlay, slot);

      const chip = overlay.querySelector("#cmp-retro-chip");
      const itemsGrid = overlay.querySelector("#cmp-picker-items");
      const search = overlay.querySelector("#cmp-search");
      let query = "";
      const refresh = () => {
        itemsGrid.innerHTML = buildItems(retroOnly, query);
        attachItemListeners(overlay, slot);
      };
      chip.addEventListener("click", (e) => {
        e.stopPropagation();
        retroOnly = !retroOnly;
        chip.style.color = retroOnly ? "#fbbf24" : "var(--cz-text-muted)";
        chip.style.borderColor = retroOnly ? "#fbbf24" : "var(--cz-border2)";
        chip.style.background = retroOnly ? "rgba(251,191,36,0.08)" : "transparent";
        refresh();
      });
      search.addEventListener("input", () => { query = search.value; refresh(); });

      document.body.appendChild(overlay);
      setTimeout(() => search.focus(), 30);
    }

    // Init: si la URL trae ?slugs= (link compartido), renderiza en cliente.
    const q = new URLSearchParams(location.search).get("slugs");
    if (q) {
      current = q.split(",");
      render(current);
    } else {
      attachPhotos();
    }
  </script>
</Base>
