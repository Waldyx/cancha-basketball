---
// /balones — catálogo de balones de baloncesto recomendados
import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
import { balones, scoreBalon } from "../data/balones";

const TERRENO_LABEL: Record<string, string> = {
  indoor: "Interior",
  outdoor: "Exterior",
  hybrid: "Mixto",
};
const MATERIAL_LABEL: Record<string, string> = {
  leather: "Cuero",
  composite: "Composite",
  rubber: "Goma",
};
const TIENDA_LABEL: Record<string, string> = {
  amazon_es: "Amazon",
  decathlon: "Decathlon",
};

// Orden: mejor score primero
const ordenados = [...balones].sort((a, b) => scoreBalon(b) - scoreBalon(a));

// Accesorios: calcetines y plantillas (afiliado Amazon)
const CALCETINES = [
  { altura: "Corto", nombre: "Nike Everyday No-Show", precio: "~13€", nota: "Invisibles — court feel máximo, ideal low-top", img: "/accesorios/calcetin-corto.webp", url: "https://www.amazon.es/s?k=nike+everyday+no+show+calcetines&tag=canchazapa-21" },
  { altura: "Tobillo", nombre: "Jordan Everyday Ankle", precio: "~16€", nota: "Cubre el tobillo sin caña — equilibrio comodidad y frescura", img: "/accesorios/calcetin-tobillo-jordan.webp", url: "https://www.amazon.es/s?k=jordan+ankle+calcetines+baloncesto&tag=canchazapa-21" },
  { altura: "Largo", nombre: "Nike Elite Crew", precio: "~15€", nota: "El calcetín de baloncesto por excelencia — acolchado y soporte", img: "/accesorios/calcetin-largo-elite.webp", url: "https://www.amazon.es/s?k=nike+elite+crew+calcetines+baloncesto&tag=canchazapa-21" },
  { altura: "Largo", nombre: "Stance NBA Crew", precio: "~18€", nota: "El look NBA — calcetín oficial de la liga, grosor premium", img: "/accesorios/calcetin-largo-stance.webp", url: "https://www.amazon.es/s?k=stance+nba+calcetines&tag=canchazapa-21" },
  { altura: "Largo", nombre: "UA Playmaker Crew", precio: "~12€", nota: "Crew con soporte de tobillo — popular y económico", img: "/accesorios/calcetin-medio.webp", url: "https://www.amazon.es/s?k=under+armour+playmaker+crew+calcetines&tag=canchazapa-21" },
  { altura: "Económico", nombre: "Kipsta Mid 500 (Decathlon)", precio: "~6€", nota: "La mejor relación calidad-precio — rinde más que cualquier algodón", img: "/accesorios/calcetin-eco.webp", url: "https://www.awin1.com/cread.php?awinmid=105405&awinaffid=2908587&ued=https%3A%2F%2Fwww.decathlon.es%2Fes%2Fsearch%3FNtt%3Dcalcetines%2Bbaloncesto" },
  { altura: "Grip", nombre: "Tapedesign Antideslizantes", precio: "~14€", nota: "Almohadillas antideslizantes — el pie no baila dentro de la zapa", img: "/accesorios/calcetin-grip.webp", url: "https://www.amazon.es/s?k=tapedesign+calcetines+antideslizantes&tag=canchazapa-21" },
];
const PLANTILLAS = [
  { nombre: "Superfeet Green Premium", precio: "~38€", nota: "Soporte de arco máximo — pronación y pie plano", img: "/accesorios/plantilla-superfeet.webp", url: "https://www.amazon.es/s?k=superfeet+green+plantillas+deporte&tag=canchazapa-21" },
  { nombre: "Sof Sole Athlete Full Length", precio: "~18€", nota: "Cushion extra para zapatillas básicas o retros", img: "/accesorios/plantilla-sofsole.webp", url: "https://www.amazon.es/s?k=sof+sole+athlete+full+length+plantillas&tag=canchazapa-21" },
  { nombre: "Bauerfeind Sports Basketball", precio: "~45€", nota: "Soporte médico para tobillo y rodilla sensibles", img: "/accesorios/plantilla-bauerfeind.webp", url: "https://www.amazon.es/s?k=bauerfeind+sports+plantillas+baloncesto&tag=canchazapa-21" },
  { nombre: "Currex SupportST", precio: "~40€", nota: "Arco dinámico — estabilidad sin perder reactividad", img: "/accesorios/plantilla-currex.webp", url: "https://www.amazon.es/s?k=currex+supportst+plantillas+deporte&tag=canchazapa-21" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Mejores balones de baloncesto 2026",
  itemListElement: ordenados.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Product",
      name: `${b.marca} ${b.modelo}`,
      category: "Balón de baloncesto",
      offers: {
        "@type": "Offer",
        price: b.precio_msrp_eur,
        priceCurrency: "EUR",
      },
    },
  })),
};
---

<Base
  title="Mejores balones de baloncesto 2026: indoor, outdoor y composite | CANCHA.ZAPA"
  description="Guía de los mejores balones de baloncesto: Wilson, Molten, Spalding y Decathlon. Por terreno (interior/exterior), material y precio. Análisis honesto y dónde comprarlos."
  jsonLd={jsonLd}
>
  <main class="app">
    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/balones" class="active" aria-current="page">Accesorios</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <section class="rk-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Equipamiento · CANCHA.ZAPA</p>
        <h1 class="rk-h1">Mejores balones<br/><span class="rk-h1-cat">de baloncesto</span></h1>
        <p class="rk-blurb">{balones.length} balones analizados sin BS · Por terreno, material y precio · Con dónde comprarlos</p>
      </div>
    </section>

    <nav class="rk-tabs">
      <div class="shell rk-tabs-inner">
        <button class="rk-tab is-active" data-f="all">Todos</button>
        <button class="rk-tab" data-f="indoor">Interior</button>
        <button class="rk-tab" data-f="hybrid">Mixto</button>
        <button class="rk-tab" data-f="outdoor">Exterior</button>
      </div>
    </nav>

    <section class="shell bl-grid">
      {ordenados.map((b) => {
        const score = scoreBalon(b);
        const accent = b.terreno === "indoor" ? "#c08457" : b.terreno === "outdoor" ? "#f97316" : "#facc15";
        return (
          <article class="bl-card" data-terreno={b.terreno}>
            <div class="bl-card-top">
              <span class="bl-badge" style={`--c:${accent}`}>{TERRENO_LABEL[b.terreno]}</span>
              <span class="bl-score">{score}</span>
            </div>
            <div class="bl-ball">
              <img src={b.imagen_principal} alt={`${b.marca} ${b.modelo}`} width="180" height="180" />
            </div>
            <div class="bl-body">
              <p class="bl-marca">{b.marca}</p>
              <h2 class="bl-modelo">{b.modelo}</h2>
              <div class="bl-meta">
                <span>{MATERIAL_LABEL[b.material]}</span>
                <span>·</span>
                <span>Talla {b.talla_principal}</span>
              </div>
              <div class="bl-scores">
                <div><b>{b.puntuaciones.grip}</b><span>Grip</span></div>
                <div><b>{b.puntuaciones.rebote}</b><span>Rebote</span></div>
                <div><b>{b.puntuaciones.durabilidad}</b><span>Durab.</span></div>
                <div><b>{b.puntuaciones.control}</b><span>Control</span></div>
              </div>
              <p class="bl-veredicto">{b.veredicto}</p>
              <div class="bl-buy">
                {b.links_compra.filter((l) => l.disponible).map((l) => (
                  <a class="bl-btn" href={l.url} target="_blank" rel="nofollow sponsored noopener">
                    {TIENDA_LABEL[l.tienda] ?? l.tienda} · {l.precio_actual}€ →
                  </a>
                ))}
              </div>
            </div>
          </article>
        );
      })}
    </section>

    {/* ── Calcetines ── */}
    <section class="shell bl-acc">
      <div class="bl-acc-head">
        <h2 class="bl-acc-title">🧦 Calcetines de baloncesto</h2>
        <a href="/calcetines-baloncesto" class="bl-acc-link">Guía completa →</a>
      </div>
      <div class="bl-acc-grid">
        {CALCETINES.map((c) => (
          <a href={c.url} target="_blank" rel="noopener noreferrer sponsored" class="bl-acc-card">
            <div class="bl-acc-img"><img src={c.img} alt={c.nombre} width="160" height="160" /></div>
            <span class="bl-acc-badge">{c.altura}</span>
            <span class="bl-acc-name">{c.nombre}</span>
            <span class="bl-acc-nota">{c.nota}</span>
            <span class="bl-acc-buy">{c.precio} · {c.url.includes("awin1") ? "Decathlon" : "Amazon"} →</span>
          </a>
        ))}
      </div>
    </section>

    {/* ── Plantillas ── */}
    <section class="shell bl-acc">
      <div class="bl-acc-head">
        <h2 class="bl-acc-title">🦶 Plantillas de baloncesto</h2>
        <a href="/plantillas-baloncesto" class="bl-acc-link">Guía completa →</a>
      </div>
      <div class="bl-acc-grid">
        {PLANTILLAS.map((c) => (
          <a href={c.url} target="_blank" rel="noopener noreferrer sponsored" class="bl-acc-card">
            <div class="bl-acc-img"><img src={c.img} alt={c.nombre} width="160" height="160" /></div>
            <span class="bl-acc-name">{c.nombre}</span>
            <span class="bl-acc-nota">{c.nota}</span>
            <span class="bl-acc-buy">{c.precio} · Amazon →</span>
          </a>
        ))}
      </div>
    </section>

    <aside class="shell bl-cta">
      <div>
        <p class="bl-cta-title">¿Y las zapatillas?</p>
        <p class="bl-cta-sub">Tenemos {`182`} modelos analizados sin sesgo. Encuentra las tuyas en 60 segundos.</p>
      </div>
      <a href="/quiz" class="home-btn primary">Hacer el quiz →</a>
    </aside>

    <p class="bl-disclaimer shell">
      Los enlaces a Amazon y Decathlon son de afiliado: si compras, podemos llevarnos una pequeña comisión sin coste extra para ti. No afecta a nuestros análisis — puntuamos igual de duro a todos. <a href="/financiacion">Cómo nos financiamos</a>.
    </p>
  </main>

  <style>
    .bl-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; padding: 24px 0 48px; }
    .bl-card { background: #131316; border: 1px solid #27272a; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: border-color .15s, transform .15s; }
    .bl-card:hover { border-color: #3f3f46; transform: translateY(-2px); }
    .bl-card-top { display: flex; justify-content: space-between; align-items: center; padding: 14px 16px 0; }
    .bl-badge { font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; color: var(--c); border: 1px solid var(--c); padding: 3px 10px; border-radius: 999px; }
    .bl-score { font-family: "Barlow Condensed", sans-serif; font-weight: 900; font-size: 28px; color: #f97316; }
    .bl-ball { display: flex; justify-content: center; padding: 8px 0 4px; background: #fff; border-radius: 12px; margin: 0 16px; }
    .bl-ball img { width: 180px; height: 180px; object-fit: contain; }
    .bl-body { padding: 4px 18px 18px; display: flex; flex-direction: column; flex: 1; }
    .bl-marca { color: #71717a; font-size: 12px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; margin: 0; }
    .bl-modelo { font-family: "Barlow Condensed", sans-serif; font-weight: 900; font-size: 26px; text-transform: uppercase; color: #fff; margin: 2px 0 6px; line-height: 1; }
    .bl-meta { display: flex; gap: 6px; color: #a1a1aa; font-size: 13px; font-weight: 600; margin-bottom: 12px; }
    .bl-scores { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; margin-bottom: 12px; }
    .bl-scores div { text-align: center; background: #0c0c0c; border-radius: 8px; padding: 6px 2px; }
    .bl-scores b { display: block; color: #f97316; font-size: 18px; font-family: "Barlow Condensed", sans-serif; }
    .bl-scores span { font-size: 10px; color: #71717a; text-transform: uppercase; letter-spacing: .5px; }
    .bl-veredicto { color: #d4d4d8; font-size: 13px; line-height: 1.5; margin: 0 0 14px; flex: 1; }
    .bl-buy { display: flex; flex-direction: column; gap: 8px; }
    .bl-btn { display: block; text-align: center; background: #f97316; color: #0c0c0c; font-weight: 900; padding: 11px; border-radius: 10px; text-decoration: none; font-size: 14px; transition: background .15s; }
    .bl-btn:hover { background: #fb923c; }
    .bl-btn:nth-child(2) { background: #18181b; color: #f97316; border: 1px solid #f97316; }
    .bl-btn:nth-child(2):hover { background: #1f1f23; }

    /* Accesorios (calcetines / plantillas) */
    .bl-acc { padding: 8px 0 24px; }
    .bl-acc-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; border-top: 1px solid #27272a; padding-top: 24px; margin-bottom: 16px; flex-wrap: wrap; }
    .bl-acc-title { font-family: "Barlow Condensed", sans-serif; font-weight: 900; font-size: 28px; text-transform: uppercase; color: #fff; margin: 0; }
    .bl-acc-link { color: #f97316; font-weight: 800; font-size: 13px; text-decoration: none; white-space: nowrap; }
    .bl-acc-link:hover { text-decoration: underline; }
    .bl-acc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 14px; }
    .bl-acc-card { display: flex; flex-direction: column; gap: 4px; background: #131316; border: 1px solid #27272a; border-radius: 12px; padding: 16px; text-decoration: none; transition: border-color .15s, transform .15s; }
    .bl-acc-card:hover { border-color: #f97316; transform: translateY(-2px); }
    .bl-acc-img { background: #fff; border-radius: 8px; display: flex; justify-content: center; align-items: center; padding: 6px; margin-bottom: 4px; }
    .bl-acc-img img { width: 100%; max-width: 150px; height: 130px; object-fit: contain; }
    .bl-acc-badge { align-self: flex-start; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; color: #f97316; border: 1px solid #f97316; padding: 2px 8px; border-radius: 999px; margin-bottom: 2px; }
    .bl-acc-name { font-weight: 900; color: #fff; font-size: 15px; }
    .bl-acc-nota { color: #a1a1aa; font-size: 12px; line-height: 1.4; flex: 1; }
    .bl-acc-buy { color: #f97316; font-weight: 800; font-size: 13px; margin-top: 6px; }

    .bl-cta { display: flex; justify-content: space-between; align-items: center; gap: 20px; background: linear-gradient(135deg, #1a1a1d, #0c0c0c); border: 1px solid #27272a; border-radius: 16px; padding: 24px 28px; margin-bottom: 24px; flex-wrap: wrap; }
    .bl-cta-title { font-family: "Barlow Condensed", sans-serif; font-weight: 900; font-size: 24px; color: #fff; margin: 0; text-transform: uppercase; }
    .bl-cta-sub { color: #a1a1aa; font-size: 14px; margin: 4px 0 0; }
    .bl-disclaimer { color: #71717a; font-size: 12px; line-height: 1.6; padding-bottom: 40px; text-align: center; max-width: 700px; margin: 0 auto; }
    .bl-disclaimer a { color: #a1a1aa; }
  </style>

  <script is:inline>
    document.querySelectorAll(".rk-tab").forEach((tab) => {
      tab.addEventListener("click", () => {
        const f = tab.getAttribute("data-f");
        document.querySelectorAll(".rk-tab").forEach((c) => c.classList.remove("is-active"));
        tab.classList.add("is-active");
        document.querySelectorAll(".bl-card").forEach((card) => {
          const show = f === "all" || card.getAttribute("data-terreno") === f;
          card.style.display = show ? "" : "none";
        });
      });
    });
  </script>
</Base>
