---
// /quiz — quiz completo 10 pasos
import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
---

<Base
  title="Quiz: Encuentra tu zapatilla de baloncesto ideal 2026 | CANCHA.ZAPA"
  description="Quiz gratuito de zapatillas de baloncesto: 10 preguntas, menos de 1 minuto. Te recomendamos las mejores zapas para tu posición, peso y presupuesto. Sin registro."
>
  <noscript>
    <div style="padding:60px 24px;text-align:center;max-width:560px;margin:0 auto">
      <p style="font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.2em;color:#f97316;margin-bottom:14px">
        ⚠ JavaScript requerido
      </p>
      <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:48px;line-height:.9;letter-spacing:-.04em;text-transform:uppercase;color:#fff;margin:0 0 14px">
        Activa JavaScript<br/>para usar el quiz
      </h1>
      <p style="color:#a1a1aa;font-size:15px;line-height:1.55;margin:0 0 24px">
        El quiz necesita JavaScript para guardar tus respuestas. Mientras tanto, puedes
        explorar el catálogo completo de zapatillas.
      </p>
      <a href="/zapatillas" style="display:inline-block;padding:14px 22px;background:#f97316;color:#0c0c0c;font-weight:900;text-transform:uppercase;letter-spacing:.14em;font-size:12px;box-shadow:5px 5px 0 0 #facc15;text-decoration:none">
        → Ver catálogo
      </a>
    </div>
  </noscript>

  <main class="quiz-app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/quiz" class="active">Quiz</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/balones">Balones</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    {/* Progress */}
    <div class="quiz-progress-bar">
      <div class="shell quiz-progress-inner">
        <div class="qp-row">
          <span class="qp-label">★ Pregunta <strong id="step-num">1</strong> de <strong>10</strong></span>
          <span class="qp-pct" id="step-pct">10%</span>
        </div>
        <div class="qp-track">
          <div class="qp-fill" id="step-fill" style="width:10%"></div>
        </div>
        <div class="qp-dots" id="step-dots">
          {[...Array(10)].map((_, i) => (
            <span class={`qp-dot ${i === 0 ? "current" : ""}`} data-step={i + 1}>{i + 1}</span>
          ))}
        </div>
      </div>
    </div>

    <section class="quiz-main">
      <div class="shell">
        {/* STEP 1 — Perfil */}
        <div class="quiz-step in" data-step="1">
          <p class="cz-eyebrow">★ 01 / 10</p>
          <h2 class="quiz-title">¿Para quién es?</h2>
          <p class="quiz-sub">Ajustaremos las recomendaciones según el perfil.</p>
          <div class="quiz-options cols-3">
            <button class="quiz-opt" data-field="perfil" data-value="hombre">
              <span class="qo-icon">♂</span>
              <div class="qo-text"><span class="qo-title">Hombre</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="perfil" data-value="mujer">
              <span class="qo-icon">♀</span>
              <div class="qo-text"><span class="qo-title">Mujer</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="perfil" data-value="junior">
              <span class="qo-icon">JR</span>
              <div class="qo-text"><span class="qo-title">Junior</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 2 — Posición */}
        <div class="quiz-step hidden" data-step="2">
          <p class="cz-eyebrow">★ 02 / 10</p>
          <h2 class="quiz-title">¿En qué posición juegas?</h2>
          <p class="quiz-sub">Elige la que mejor te describa.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="posicion" data-value="base">
              <div class="qo-text"><span class="qo-title">Base</span><span class="qo-sub">Point Guard · #1</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="posicion" data-value="escolta">
              <div class="qo-text"><span class="qo-title">Escolta</span><span class="qo-sub">Shooting Guard · #2</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="posicion" data-value="alero">
              <div class="qo-text"><span class="qo-title">Alero</span><span class="qo-sub">Small Forward · #3</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="posicion" data-value="ala-pivot">
              <div class="qo-text"><span class="qo-title">Ala-pívot</span><span class="qo-sub">Power Forward · #4</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" style="grid-column:span 2" data-field="posicion" data-value="pivot">
              <div class="qo-text"><span class="qo-title">Pívot</span><span class="qo-sub">Center · #5</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 3 — Peso */}
        <div class="quiz-step hidden" data-step="3">
          <p class="cz-eyebrow">★ 03 / 10</p>
          <h2 class="quiz-title">¿Cuál es tu peso aproximado?</h2>
          <p class="quiz-sub">Lo necesitamos para ajustar el soporte.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="peso" data-value="menos-70">
              <div class="qo-text"><span class="qo-title">Menos de 70kg</span><span class="qo-sub">Guardias, bases</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="peso" data-value="70-85">
              <div class="qo-text"><span class="qo-title">70–85kg</span><span class="qo-sub">Escoltas, aleros</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="peso" data-value="85-100">
              <div class="qo-text"><span class="qo-title">85–100kg</span><span class="qo-sub">Alas, pívots</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="peso" data-value="mas-100">
              <div class="qo-text"><span class="qo-title">Más de 100kg</span><span class="qo-sub">Pívots potentes</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 4 — Estilo */}
        <div class="quiz-step hidden" data-step="4">
          <p class="cz-eyebrow">★ 04 / 10</p>
          <h2 class="quiz-title">¿Cómo describirías tu juego?</h2>
          <p class="quiz-sub">Lo ideal sería que todo, pero elige tu fortaleza.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="estilo" data-value="explosivo">
              <div class="qo-text"><span class="qo-title">Explosivo</span><span class="qo-sub">Salto, velocidad, transiciones</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="estilo" data-value="equilibrado">
              <div class="qo-text"><span class="qo-title">Equilibrado</span><span class="qo-sub">Todo un poco, versatilidad</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="estilo" data-value="potente">
              <div class="qo-text"><span class="qo-title">Potente</span><span class="qo-sub">Fuerza, defensa, rebotes</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="estilo" data-value="tirador">
              <div class="qo-text"><span class="qo-title">Tirador</span><span class="qo-sub">Tiroteo exterior, spacing</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 5 — Cancha */}
        <div class="quiz-step hidden" data-step="5">
          <p class="cz-eyebrow">★ 05 / 10</p>
          <h2 class="quiz-title">¿En qué cancha juegas principalmente?</h2>
          <p class="quiz-sub">El suelo afecta a la tracción y desgaste.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="cancha" data-value="interior">
              <div class="qo-text"><span class="qo-title">Interior (pala/madera)</span><span class="qo-sub">Piso liso, buena tracción</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="cancha" data-value="exterior">
              <div class="qo-text"><span class="qo-title">Exterior (asfalto/cemento)</span><span class="qo-sub">Superficie dura, abrasiva</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="cancha" data-value="mixto">
              <div class="qo-text"><span class="qo-title">Mixto (las dos)</span><span class="qo-sub">Adaptable a ambas superficies</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 6 — Lesiones (multi-select) */}
        <div class="quiz-step hidden" data-step="6">
          <p class="cz-eyebrow">★ 06 / 10</p>
          <h2 class="quiz-title">¿Tienes lesiones previas a considerar?</h2>
          <p class="quiz-sub">Puedes elegir más de una. La zapatilla se filtrará para protegerte mejor.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="lesiones" data-value="rodillas">
              <div class="qo-text"><span class="qo-title">Rodillas</span><span class="qo-sub">Soporte extra, estabilidad</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="lesiones" data-value="tobillos">
              <div class="qo-text"><span class="qo-title">Tobillos</span><span class="qo-sub">Ancaje alto, soporte</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="lesiones" data-value="fascia">
              <div class="qo-text"><span class="qo-title">Planta del pie</span><span class="qo-sub">Fascitis, dolor arco</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="lesiones" data-value="ninguna">
              <div class="qo-text"><span class="qo-title">Ninguna</span><span class="qo-sub">Juego libre, máximo rendimiento</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 7 — Prioridad */}
        <div class="quiz-step hidden" data-step="7">
          <p class="cz-eyebrow">★ 07 / 10</p>
          <h2 class="quiz-title">¿Qué priorizas en una zapatilla?</h2>
          <p class="quiz-sub">Elige tu #1. Lo demás vendrá después.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="prioridad" data-value="proteccion">
              <div class="qo-text"><span class="qo-title">Protección</span><span class="qo-sub">Evitar lesiones, durabilidad</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="prioridad" data-value="reactividad">
              <div class="qo-text"><span class="qo-title">Reactividad</span><span class="qo-sub">Cushion responsive, retorno</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="prioridad" data-value="soporte-tobillo">
              <div class="qo-text"><span class="qo-title">Soporte tobillo</span><span class="qo-sub">Estabilidad lateral, ancaje</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="prioridad" data-value="durabilidad">
              <div class="qo-text"><span class="qo-title">Durabilidad</span><span class="qo-sub">Suela resistente, vida útil</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="prioridad" data-value="precio">
              <div class="qo-text"><span class="qo-title">Precio</span><span class="qo-sub">Calidad/precio óptimo</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 8 — Presupuesto */}
        <div class="quiz-step hidden" data-step="8">
          <p class="cz-eyebrow">★ 08 / 10</p>
          <h2 class="quiz-title">¿Cuál es tu presupuesto máximo?</h2>
          <p class="quiz-sub">El precio influye en la elección final.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="presupuesto" data-value="80">
              <div class="qo-text"><span class="qo-title">Hasta 80€</span><span class="qo-sub">Entry-level, buena relación calidad/precio</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="presupuesto" data-value="130">
              <div class="qo-text"><span class="qo-title">Hasta 130€</span><span class="qo-sub">Mid-range, sweet spot</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="presupuesto" data-value="180">
              <div class="qo-text"><span class="qo-title">Hasta 180€</span><span class="qo-sub">Premium, tecnologías top</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="presupuesto" data-value="null">
              <div class="qo-text"><span class="qo-title">Presupuesto abierto</span><span class="qo-sub">Lo mejor sin importar precio</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 9 — Ancho de pie */}
        <div class="quiz-step hidden" data-step="9">
          <p class="cz-eyebrow">★ 09 / 10</p>
          <h2 class="quiz-title">¿Cómo sería tu ancho de pie?</h2>
          <p class="quiz-sub">Evita apretado que cause ampollas.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="ancho" data-value="normal">
              <div class="qo-text"><span class="qo-title">Normal</span><span class="qo-sub">Estándar, ajuste cómodo</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="ancho" data-value="ancho">
              <div class="qo-text"><span class="qo-title">Ancho</span><span class="qo-sub">Wide fit, antepié amplio</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="ancho" data-value="no-se">
              <div class="qo-text"><span class="qo-title">No lo sé</span><span class="qo-sub">Estándar, sin preferencia</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 10 — Uso */}
        <div class="quiz-step hidden" data-step="10">
          <p class="cz-eyebrow">★ 10 / 10</p>
          <h2 class="quiz-title">¿Para qué la usarás?</h2>
          <p class="quiz-sub">El uso define la durabilidad y el enfoque.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="uso" data-value="competicion">
              <div class="qo-text"><span class="qo-title">Competición</span><span class="qo-sub">Ligas, torneos, partidos</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="uso" data-value="entrenamiento">
              <div class="qo-text"><span class="qo-title">Entrenamiento</span><span class="qo-sub">Gym, streetball, práctica</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="uso" data-value="ambos">
              <div class="qo-text"><span class="qo-title">Ambos</span><span class="qo-sub">Competición y entrenamiento</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        <div class="quiz-nav">
          <button class="qn-btn ghost" id="back-btn" disabled>← Atrás</button>
          <span class="qn-hint" id="hint">Elige una opción para continuar</span>
          <button class="qn-btn primary" id="next-btn" disabled>Siguiente →</button>
        </div>
      </div>
    </section>

    <footer class="quiz-footer">
      <div class="shell quiz-footer-inner">
        <span>Gratis · sin registro · 100% honestos</span>
        <a href="/zapatillas" class="qf-skip">Saltar el quiz, ir al catálogo →</a>
      </div>
    </footer>
  </main>

  <script>
    // ─── Quiz de 10 pasos completo ───
    // Lesiones es multi-select, el resto single-select con auto-avance.

    const TOTAL = 10;
    let current = 1;
    const answers: Record<string, any> = { lesiones: [] };

    const $back = document.getElementById("back-btn") as HTMLButtonElement;
    const $next = document.getElementById("next-btn") as HTMLButtonElement;
    const $hint = document.getElementById("hint")!;
    const $stepNum = document.getElementById("step-num")!;
    const $stepPct = document.getElementById("step-pct")!;
    const $fill = document.getElementById("step-fill") as HTMLElement;
    const $steps = document.querySelectorAll<HTMLElement>(".quiz-step");
    const $dots = document.querySelectorAll<HTMLElement>(".qp-dot");
    let advanceTimer: number | undefined;

    function show(step: number, _dir: 1 | -1 = 1) {
      window.clearTimeout(advanceTimer);
      current = Math.min(Math.max(step, 1), TOTAL);
      $steps.forEach(s => {
        if (parseInt(s.dataset.step!) === current) {
          s.classList.remove("hidden", "out-left", "out-right");
          s.classList.add("in");
        } else {
          s.classList.add("hidden");
          s.classList.remove("in", "out-left", "out-right");
        }
      });
      $stepNum.textContent = String(current);
      const pct = Math.round((current / TOTAL) * 100);
      $stepPct.textContent = `${pct}%`;
      $fill.style.width = `${pct}%`;
      $dots.forEach((d, i) => {
        d.classList.remove("done", "current");
        if (i + 1 < current) d.classList.add("done");
        if (i + 1 === current) d.classList.add("current");
      });
      $back.disabled = current === 1;
      refreshNext();
    }

    function refreshNext() {
      const stepEl = document.querySelector<HTMLElement>(`.quiz-step[data-step="${current}"]`)!;
      const field = stepEl.querySelector<HTMLElement>("[data-field]")?.dataset.field;
      let ok = false;
      if (field === "lesiones") {
        ok = (answers.lesiones as string[]).length > 0;
      } else {
        ok = field ? answers[field] !== undefined : false;
      }
      $next.disabled = !ok;
      $hint.textContent = ok
        ? (current < TOTAL ? "Avanzando…" : "Listos. Ver tus matches.")
        : "Elige una opción para continuar";
    }

    document.querySelectorAll<HTMLButtonElement>(".quiz-opt").forEach(btn => {
      btn.addEventListener("click", () => {
        const field = btn.dataset.field!;
        const value = btn.dataset.value!;

        if (field === "lesiones") {
          // Multi-select: "ninguna" exclusivo
          if (value === "ninguna") {
            answers.lesiones = ["ninguna"];
            document.querySelectorAll<HTMLButtonElement>(`[data-field="lesiones"]`).forEach(b => {
              b.classList.toggle("is-selected", b === btn);
            });
          } else {
            const set = new Set<string>((answers.lesiones as string[]).filter((v: string) => v !== "ninguna"));
            set.has(value) ? set.delete(value) : set.add(value);
            answers.lesiones = [...set];
            document.querySelectorAll<HTMLButtonElement>(`[data-field="lesiones"]`).forEach(b => {
              b.classList.toggle("is-selected", set.has(b.dataset.value!));
            });
          }
          refreshNext();
          // Auto-avance: 700ms tras la última selección (da tiempo a marcar varias)
          window.clearTimeout(advanceTimer);
          if ((answers.lesiones as string[]).length > 0) {
            advanceTimer = window.setTimeout(() => show(current + 1), 700);
          }
        } else {
          answers[field] = value;
          document.querySelectorAll<HTMLButtonElement>(`[data-field="${field}"]`).forEach(b =>
            b.classList.toggle("is-selected", b === btn)
          );
          refreshNext();
          if (current < TOTAL) {
            // Pasos 1-9: avanzar al siguiente
            advanceTimer = window.setTimeout(() => show(current + 1), 180);
          } else {
            // Paso 10 (último): enviar directamente
            advanceTimer = window.setTimeout(() => {
              const respuestas = {
                posicion:            answers.posicion,
                peso:                answers.peso,
                estilo:              answers.estilo,
                cancha:              answers.cancha,
                lesiones:            (answers.lesiones as string[]).filter((l: string) => l !== "ninguna"),
                prioridad:           answers.prioridad,
                presupuesto_max_eur: (!answers.presupuesto || answers.presupuesto === "null")
                                       ? null
                                       : parseInt(answers.presupuesto as string, 10),
                ancho_pie:           answers.ancho,
                perfil:              answers.perfil,
                uso:                 answers.uso,
              };
              sessionStorage.setItem("cancha-quiz-respuestas", JSON.stringify(respuestas));
              location.href = "/resultados";
            }, 400);
          }
        }
      });
    });

    $back.addEventListener("click", () => { if (current > 1) show(current - 1, -1); });

    $next.addEventListener("click", () => {
      if ($next.disabled) return;
      if (current < TOTAL) {
        show(current + 1);
      } else {
        const respuestas = {
          posicion:            answers.posicion,
          peso:                answers.peso,
          estilo:              answers.estilo,
          cancha:              answers.cancha,
          lesiones:            (answers.lesiones as string[]).filter((l: string) => l !== "ninguna"),
          prioridad:           answers.prioridad,
          presupuesto_max_eur: (!answers.presupuesto || answers.presupuesto === "null")
                                 ? null
                                 : parseInt(answers.presupuesto as string, 10),
          ancho_pie:           answers.ancho,
          perfil:              answers.perfil,
          uso:                 answers.uso,
        };
        sessionStorage.setItem("cancha-quiz-respuestas", JSON.stringify(respuestas));
        location.href = "/resultados";
      }
    });

    show(1);
  </script>

  <style>.hidden { display: none !important; }</style>
</Base>
