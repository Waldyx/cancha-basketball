---
// /quiz — quiz rediseñado
// Drop-in replacement for web/src/pages/quiz.astro
// NOTA: la lógica JS del quiz original (estado, navegación, persistencia
// de respuestas) sigue funcionando. Lo que cambia aquí es la estructura
// HTML + CSS y las micro-animaciones entre pasos. Si tu quiz.astro
// original tenía lógica adicional, mantén el bloque <script> al final.

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
---

<Base
  title="Quiz: Encuentra tu zapatilla de baloncesto ideal | CANCHA"
  description="Quiz gratuito: responde 10 preguntas y te recomendamos las 5 zapatillas más compatibles con tu juego. Sin registro. Sin BS."
>
  <main class="quiz-app">
    <div class="cz-courtbg"><img src="/bg-court.svg" alt="" /><div></div></div>

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo">CANCHA<span class="dot">.</span>ZAPA</a>
        <nav class="cz-nav">
          <a href="/zapatillas">Catálogo</a>
          <a href="/rankings">Rankings</a>
          <a href="/faq">FAQ</a>
        </nav>
      </div>
    </header>

    {/* Progress */}
    <div class="quiz-progress-bar">
      <div class="shell quiz-progress-inner">
        <div class="qp-row">
          <span class="qp-label">★ Pregunta <strong id="step-num">1</strong> de <strong>10</strong></span>
          <span class="qp-pct" id="step-pct">10%</span>
        </div>
        <div class="qp-track">
          <div class="qp-fill" id="step-fill" style="width:10%"></div>
        </div>
        <div class="qp-dots" id="step-dots">
          {[...Array(10)].map((_, i) => (
            <span class={`qp-dot ${i === 0 ? "current" : ""}`} data-step={i + 1}>{i + 1}</span>
          ))}
        </div>
      </div>
    </div>

    <main class="quiz-main">
      <div class="shell">
        {/* STEP 1 — Perfil */}
        <div class="quiz-step in" data-step="1">
          <p class="cz-eyebrow">★ 01 / 10</p>
          <h1 class="quiz-title">¿Para quién es?</h1>
          <p class="quiz-sub">Ajustaremos las recomendaciones según el perfil.</p>
          <div class="quiz-options cols-3">
            <button class="quiz-opt" data-field="perfil" data-value="hombre">
              <span class="qo-icon">♂</span>
              <div class="qo-text"><span class="qo-title">Hombre</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="perfil" data-value="mujer">
              <span class="qo-icon">♀</span>
              <div class="qo-text"><span class="qo-title">Mujer</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="perfil" data-value="junior">
              <span class="qo-icon">JR</span>
              <div class="qo-text"><span class="qo-title">Junior</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/* STEP 2 — Posición */}
        <div class="quiz-step hidden" data-step="2">
          <p class="cz-eyebrow">★ 02 / 10</p>
          <h1 class="quiz-title">¿En qué posición juegas?</h1>
          <p class="quiz-sub">Elige la que mejor te describa.</p>
          <div class="quiz-options cols-2">
            <button class="quiz-opt" data-field="posicion" data-value="base">
              <div class="qo-text"><span class="qo-title">Base</span><span class="qo-sub">Point Guard · #1</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="posicion" data-value="escolta">
              <div class="qo-text"><span class="qo-title">Escolta</span><span class="qo-sub">Shooting Guard · #2</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="posicion" data-value="alero">
              <div class="qo-text"><span class="qo-title">Alero</span><span class="qo-sub">Small Forward · #3</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" data-field="posicion" data-value="ala-pivot">
              <div class="qo-text"><span class="qo-title">Ala-pívot</span><span class="qo-sub">Power Forward · #4</span></div>
              <span class="qo-check">→</span>
            </button>
            <button class="quiz-opt" style="grid-column:span 2" data-field="posicion" data-value="pivot">
              <div class="qo-text"><span class="qo-title">Pívot</span><span class="qo-sub">Center · #5</span></div>
              <span class="qo-check">→</span>
            </button>
          </div>
        </div>

        {/*
          STEPS 3-10 — copia los pasos 3 al 10 de tu quiz.astro original
          y reemplaza el chrome de cada paso por este patrón:

            <div class="quiz-step hidden" data-step="N">
              <p class="cz-eyebrow">★ NN / 10</p>
              <h1 class="quiz-title">¿…?</h1>
              <p class="quiz-sub">…</p>
              <div class="quiz-options cols-2">
                <button class="quiz-opt" data-field="…" data-value="…">
                  <span class="qo-icon">…</span>   <!-- opcional -->
                  <div class="qo-text">
                    <span class="qo-title">…</span>
                    <span class="qo-sub">…</span>  <!-- opcional -->
                  </div>
                  <span class="qo-check">→</span>
                </button>
                …
              </div>
            </div>
        */}

        <div class="quiz-nav">
          <button class="qn-btn ghost" id="back-btn" disabled>← Atrás</button>
          <span class="qn-hint" id="hint">Elige una opción para continuar</span>
          <button class="qn-btn primary" id="next-btn" disabled>Siguiente →</button>
        </div>
      </div>
    </main>

    <footer class="quiz-footer">
      <div class="shell quiz-footer-inner">
        <span>Gratis · sin registro · 100% honestos</span>
        <a href="/zapatillas" class="qf-skip">Saltar el quiz, ir al catálogo →</a>
      </div>
    </footer>
  </main>

  <script>
    // ─── Reusa la lógica del quiz original (web/src/pages/quiz.astro) ───
    // Solo necesita estos pequeños cambios para encajar con las clases nuevas:
    //   .quiz-option           →  .quiz-opt
    //   .quiz-option.is-selected →  .quiz-opt.is-selected
    //   .quiz-option-title     →  .qo-title
    //   .quiz-option-sub       →  .qo-sub
    //   .hidden                →  igual
    //
    // Aquí abajo va una versión simplificada para los 2 primeros pasos.
    // Reemplázala con tu lógica completa de 10 pasos.

    const TOTAL = 10;
    let current = 1;
    const answers: Record<string, any> = { lesiones: [] };

    const $back = document.getElementById("back-btn") as HTMLButtonElement;
    const $next = document.getElementById("next-btn") as HTMLButtonElement;
    const $hint = document.getElementById("hint")!;
    const $stepNum = document.getElementById("step-num")!;
    const $stepPct = document.getElementById("step-pct")!;
    const $fill = document.getElementById("step-fill") as HTMLElement;
    const $steps = document.querySelectorAll<HTMLElement>(".quiz-step");
    const $dots = document.querySelectorAll<HTMLElement>(".qp-dot");

    function show(step: number, dir: 1 | -1 = 1) {
      $steps.forEach(s => {
        if (parseInt(s.dataset.step!) === step) {
          s.classList.remove("hidden", "out-left", "out-right");
          s.classList.add("in");
        } else {
          s.classList.add("hidden");
          s.classList.remove("in", "out-left", "out-right");
        }
      });
      $stepNum.textContent = String(step);
      const pct = Math.round((step / TOTAL) * 100);
      $stepPct.textContent = `${pct}%`;
      $fill.style.width = `${pct}%`;
      $dots.forEach((d, i) => {
        d.classList.remove("done", "current");
        if (i + 1 < step) d.classList.add("done");
        if (i + 1 === step) d.classList.add("current");
      });
      $back.disabled = step === 1;
      refreshNext();
    }

    function refreshNext() {
      const stepEl = document.querySelector<HTMLElement>(`.quiz-step[data-step="${current}"]`)!;
      const field = stepEl.querySelector<HTMLElement>("[data-field]")?.dataset.field;
      const ok = field ? answers[field] !== undefined : false;
      $next.disabled = !ok;
      $hint.textContent = ok ? (current < TOTAL ? "Avanzando…" : "Listos. Ver tus matches.") : "Elige una opción para continuar";
    }

    document.querySelectorAll<HTMLButtonElement>(".quiz-opt").forEach(btn => {
      btn.addEventListener("click", () => {
        const field = btn.dataset.field!;
        const value = btn.dataset.value!;
        answers[field] = value;
        document.querySelectorAll<HTMLButtonElement>(`[data-field="${field}"]`).forEach(b => b.classList.toggle("is-selected", b === btn));
        refreshNext();
        if (current < TOTAL) {
          setTimeout(() => { current++; show(current); }, 280);
        }
      });
    });

    $back.addEventListener("click", () => { if (current > 1) { current--; show(current, -1); } });
    $next.addEventListener("click", () => {
      if (current < TOTAL) { current++; show(current); }
      else { location.href = "/resultados?" + new URLSearchParams(answers).toString(); }
    });

    show(1);
  </script>

  <style>.hidden { display: none !important; }</style>
</Base>
