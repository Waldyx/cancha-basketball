---
// /blog/[slug] — Artículo individual
import Base from "../../layouts/Base.astro";
import "../../styles/cancha-redesign.css";
import { ARTICLES, getArticle } from "../../lib/articles";
import { zapatillas } from "../../data/zapatillas";
import { findMejorPrecio } from "../../lib/scoring";
import { getSeoPage } from "../../lib/seoPages";

export async function getStaticPaths() {
  return ARTICLES.map((a) => ({
    params: { slug: a.slug },
    props: { article: a },
  }));
}

const { article } = Astro.props;

// Related shoes data
const relatedZapas = article.relatedShoes
  .map((s) => zapatillas.find((z) => z.slug === s))
  .filter(Boolean);

// Related articles (same category, exclude current)
const relatedArticles = ARTICLES
  .filter((a) => a.slug !== article.slug && a.categoria === article.categoria)
  .slice(0, 3);

// Related SEO pages
const relatedSeoGuias = article.relatedSeoPages
  .map((s) => getSeoPage(s))
  .filter((p): p is NonNullable<typeof p> => p !== undefined)
  .slice(0, 3);

// JSON-LD Article
const ogImg = article.imagen
  ? (article.imagen.startsWith("http") ? article.imagen : new URL(article.imagen, Astro.site).toString())
  : new URL("/og-default.svg", Astro.site).toString();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.description,
  image: ogImg,
  author: {
    "@type": "Organization",
    name: article.author,
    url: Astro.site?.toString(),
  },
  publisher: {
    "@type": "Organization",
    name: "CANCHA.ZAPA",
    logo: { "@type": "ImageObject", url: new URL("/logo-cancha-zapa.svg", Astro.site).toString() },
    url: Astro.site?.toString(),
  },
  datePublished: article.fecha,
  dateModified: article.fecha,
  mainEntityOfPage: new URL(`/blog/${article.slug}`, Astro.site).toString(),
  wordCount: Math.round(article.body.replace(/<[^>]+>/g, " ").trim().split(/\s+/).length),
};

// Breadcrumb JSON-LD
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "Blog", item: new URL("/blog", Astro.site).toString() },
    { "@type": "ListItem", position: 3, name: article.title, item: new URL(`/blog/${article.slug}`, Astro.site).toString() },
  ],
};

const CATEGORIA_COLOR: Record<string, string> = {
  "Guías": "#f97316",
  "Comparativas": "#facc15",
  "Análisis": "#38bdf8",
};
---

<Base title={article.metaTitle} description={article.description} ogImage={article.imagen} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  {/* Reading progress bar */}
  <div id="art-progress" aria-hidden="true"></div>

  <div class="cz-strip"></div>
  <header class="cz-header">
    <div class="shell cz-header-inner">
      <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
      <nav class="cz-nav">
        <a href="/quiz">Quiz</a> <a href="/comparar">Comparar</a>
        <a href="/rankings">Rankings</a>
        <a href="/zapatillas">Catálogo</a>
        <a href="/balones">Accesorios</a>
          <a href="/blog" class="active" aria-current="page">Blog</a>
        <a href="/mis-zapas">♥ Mis zapas</a>
      </nav>
    </div>
  </header>

  <main>
    {/* Article Hero */}
    <section class="art-hero">
      <div class="shell">
        <nav class="cz-breadcrumbs" aria-label="Ruta">
          <a href="/">Inicio</a>
          <span class="bc-sep">›</span>
          <a href="/blog">Blog</a>
          <span class="bc-sep">›</span>
          <span>{article.categoria}</span>
        </nav>

        <div class="art-hero-meta">
          <span
            class="blog-cat"
            style={`background:${CATEGORIA_COLOR[article.categoria] ?? "#f97316"};color:#000`}
          >
            {article.categoria}
          </span>
          <span class="art-read">{article.readMinutes} min de lectura</span>
          <time class="art-date" datetime={article.fecha}>{article.fechaLabel}</time>
        </div>

        <h1 class="art-h1">{article.heroTitle}</h1>
        <p class="art-subtitle">{article.heroSubtitle}</p>
        <p class="art-author">Por {article.author}</p>
      </div>
    </section>

    {/* Content */}
    <div class="art-layout shell">
      <article class="art-body" set:html={article.body} />

      {/* Sidebar */}
      <aside class="art-sidebar">
        {/* Table of Contents — populated by JS if article has 3+ h2s */}
        <div id="art-toc-widget" class="art-widget" style="display:none">
          <p class="art-widget-title">★ En este artículo</p>
          <nav id="art-toc-nav" aria-label="Contenidos"></nav>
        </div>

        {/* Related shoes */}
        {relatedZapas.length > 0 && (
          <div class="art-widget">
            <p class="art-widget-title">★ Zapatillas mencionadas</p>
            <ul class="art-shoe-list">
              {relatedZapas.map((z) => {
                if (!z) return null;
                const mejor = findMejorPrecio(z.links_compra);
                return (
                  <li class="art-shoe-item">
                    <a href={`/zapatilla/${z.slug}`} class="art-shoe-link">
                      <img src={z.imagen_principal} alt={`${z.marca} ${z.modelo}`} loading="lazy"
                           onerror="this.style.display='none'" width="48" height="48"
                           style="object-fit:contain;background:var(--cz-bg);flex-shrink:0" />
                      <div>
                        <span class="art-shoe-name">{z.marca} {z.modelo}</span>
                        <span class="art-shoe-price">
                          {mejor ? `${mejor.precio_actual}€` : `${z.precio_msrp_eur}€`}
                        </span>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {/* Quiz CTA */}
        <div class="art-widget art-quiz-cta">
          <p class="art-widget-title">★ ¿Cuál es tu zapa?</p>
          <p style="font-size:13px;color:var(--cz-text-2);margin:0 0 14px">10 preguntas, menos de 1 minuto. Te damos las 5 más compatibles con tu perfil.</p>
          <a href="/quiz" class="rs-btn primary" style="width:100%;text-align:center;display:block">
            → Hacer el quiz
          </a>
        </div>

        {/* Related articles */}
        {relatedArticles.length > 0 && (
          <div class="art-widget">
            <p class="art-widget-title">★ Artículos relacionados</p>
            <ul class="art-related-list">
              {relatedArticles.map((a) => (
                <li class="art-related-item">
                  <a href={`/blog/${a.slug}`} class="art-related-link">
                    <span class="art-related-cat">{a.categoria}</span>
                    <span class="art-related-title">{a.title}</span>
                    <span class="art-related-time">{a.readMinutes} min</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* Related SEO guides */}
        {relatedSeoGuias.length > 0 && (
          <div class="art-widget">
            <p class="art-widget-title">★ Guías relacionadas</p>
            <ul class="art-related-list">
              {relatedSeoGuias.map((p) => (
                <li class="art-related-item">
                  <a href={`/${p.slug}`} class="art-related-link">
                    <span class="art-related-cat">Guía SEO</span>
                    <span class="art-related-title">{p.h1Pre} {p.h1Accent}</span>
                    <span class="art-related-time">Top 5 →</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>

    {/* Bottom nav */}
    <div class="art-bottom-nav shell">
      <a href="/blog" class="rs-btn ghost">← Volver al blog</a>
      <a href="/zapatillas" class="rs-btn ghost">Ver catálogo →</a>
    </div>
  </main>

  <style>
    .art-hero {
      padding: 48px 0 40px;
      border-bottom: 1px solid var(--cz-border);
    }
    .art-hero-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin: 16px 0;
    }
    .blog-cat {
      font-size: 10px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .1em;
      padding: 3px 8px;
    }
    .art-read, .art-date {
      font-size: 11px;
      color: var(--cz-text-muted);
      text-transform: uppercase;
      letter-spacing: .08em;
    }
    .art-h1 {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(40px, 6vw, 72px);
      line-height: .95;
      letter-spacing: -.04em;
      text-transform: uppercase;
      color: var(--cz-text);
      margin: 0 0 12px;
    }
    .art-subtitle {
      font-size: 18px;
      color: var(--cz-text-2);
      margin: 0 0 12px;
      max-width: 640px;
      line-height: 1.5;
    }
    .art-author {
      font-size: 12px;
      color: var(--cz-text-dim);
      text-transform: uppercase;
      letter-spacing: .1em;
      margin: 0;
    }
    .art-layout {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 48px;
      padding-top: 48px;
      padding-bottom: 64px;
    }
    @media (max-width: 900px) {
      .art-layout { grid-template-columns: 1fr; }
      .art-sidebar { order: -1; }
    }
    /* Article body styles */
    .art-body { max-width: 720px; }
    .art-body :global(h2) {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 28px;
      text-transform: uppercase;
      letter-spacing: -.02em;
      color: var(--cz-text);
      margin: 40px 0 12px;
      padding-bottom: 8px;
      border-bottom: 2px solid #f97316;
    }
    .art-body :global(h3) {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 20px;
      text-transform: uppercase;
      letter-spacing: -.01em;
      color: var(--cz-text-soft);
      margin: 28px 0 8px;
    }
    .art-body :global(p) {
      font-size: 16px;
      line-height: 1.7;
      color: var(--cz-text-2);
      margin: 0 0 16px;
    }
    .art-body :global(.art-intro) {
      font-size: 18px;
      color: var(--cz-text-soft);
      line-height: 1.65;
      border-left: 3px solid #f97316;
      padding-left: 16px;
      margin-bottom: 32px;
    }
    .art-body :global(.art-outro) {
      font-size: 15px;
      color: var(--cz-text-soft);
      background: var(--cz-surface);
      border: 1px solid var(--cz-border);
      padding: 16px 20px;
      margin-top: 32px;
      line-height: 1.6;
    }
    .art-body :global(ul), .art-body :global(ol) {
      padding-left: 20px;
      color: var(--cz-text-2);
      line-height: 1.7;
      margin: 0 0 16px;
      font-size: 15px;
    }
    .art-body :global(li) { margin-bottom: 6px; }
    .art-body :global(strong) { color: var(--cz-text-soft); }
    .art-body :global(a) { color: #f97316; }
    .art-body :global(a:hover) { color: #facc15; }
    .art-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
      margin: 16px 0 24px;
      color: var(--cz-text-2);
    }
    .art-body :global(th) { color: var(--cz-text-soft); }
    /* Sidebar */
    .art-widget {
      background: var(--cz-surface);
      border: 1px solid var(--cz-border);
      padding: 20px;
      margin-bottom: 20px;
    }
    .art-widget-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: #f97316;
      margin: 0 0 14px;
    }
    .art-shoe-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
    .art-shoe-link {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: inherit;
    }
    .art-shoe-link:hover .art-shoe-name { color: #f97316; }
    .art-shoe-name {
      font-size: 13px;
      font-weight: 700;
      color: var(--cz-text-soft);
      display: block;
      text-transform: uppercase;
      font-family: 'Barlow Condensed', sans-serif;
    }
    .art-shoe-price {
      font-size: 12px;
      color: #f97316;
      display: block;
    }
    .art-quiz-cta {
      background: linear-gradient(135deg, var(--cz-surface), var(--cz-surface2));
      border-color: #f97316;
    }
    .art-related-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
    .art-related-link {
      display: flex;
      flex-direction: column;
      gap: 2px;
      text-decoration: none;
      padding: 8px 10px;
      border: 1px solid transparent;
      transition: border-color .15s;
    }
    .art-related-link:hover { border-color: #f97316; }
    .art-related-cat {
      font-size: 9px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: #f97316;
    }
    .art-related-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--cz-text-soft);
      font-family: 'Barlow Condensed', sans-serif;
      text-transform: uppercase;
      line-height: 1.2;
    }
    .art-related-time {
      font-size: 10px;
      color: var(--cz-text-dim);
    }
    .art-bottom-nav {
      display: flex;
      gap: 12px;
      padding-bottom: 64px;
      border-top: 1px solid var(--cz-border);
      padding-top: 24px;
    }
    /* Table of Contents */
    .art-toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .art-toc-link {
      display: block;
      font-size: 12px;
      color: var(--cz-text-2);
      text-decoration: none;
      padding: 4px 8px;
      border-left: 2px solid transparent;
      transition: border-color .15s, color .15s;
      font-family: 'Barlow Condensed', sans-serif;
      text-transform: uppercase;
      letter-spacing: .04em;
      line-height: 1.3;
    }
    .art-toc-link:hover, .art-toc-link.active {
      color: #f97316;
      border-left-color: #f97316;
    }
    /* Reading progress bar */
    #art-progress {
      position: fixed;
      top: 0;
      left: 0;
      height: 3px;
      width: 0%;
      background: #f97316;
      z-index: 9999;
      transition: width 0.1s linear;
      pointer-events: none;
    }
  </style>
  <script>
    // Table of Contents
    const tocWidget = document.getElementById("art-toc-widget");
    const tocNav = document.getElementById("art-toc-nav");
    const articleBody = document.querySelector(".art-body");
    if (tocWidget && tocNav && articleBody) {
      const headings = Array.from(articleBody.querySelectorAll("h2"));
      if (headings.length >= 3) {
        const ul = document.createElement("ul");
        ul.className = "art-toc-list";
        headings.forEach((h, i) => {
          const id = "sec-" + i + "-" + h.textContent!.trim().toLowerCase()
            .replace(/[^a-z0-9à-ü]/g, "-").replace(/-+/g, "-").slice(0, 40);
          h.id = id;
          const li = document.createElement("li");
          const a = document.createElement("a");
          a.href = "#" + id;
          a.textContent = h.textContent;
          a.className = "art-toc-link";
          li.appendChild(a);
          ul.appendChild(li);
        });
        tocNav.appendChild(ul);
        tocWidget.style.display = "";
      }
    }

    // Reading progress bar + ToC active highlighting
    const bar = document.getElementById("art-progress");
    const artElem = document.querySelector(".art-body");
    if (bar && artElem) {
      const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>(".art-toc-link"));
      const tocHeadings = tocLinks.map(a => document.getElementById(a.getAttribute("href")!.slice(1)));

      const update = () => {
        // Progress bar
        const rect = artElem.getBoundingClientRect();
        const total = rect.height - window.innerHeight;
        const scrolled = -rect.top;
        const pct = Math.min(100, Math.max(0, total > 0 ? (scrolled / total) * 100 : 0));
        bar.style.width = pct + "%";

        // Active ToC link
        if (tocLinks.length > 0) {
          const scrollY = window.scrollY + 120;
          let activeIdx = 0;
          tocHeadings.forEach((h, i) => {
            if (h && h.offsetTop <= scrollY) activeIdx = i;
          });
          tocLinks.forEach((a, i) => {
            a.classList.toggle("active", i === activeIdx);
          });
        }
      };
      window.addEventListener("scroll", update, { passive: true });
      update();
    }
  </script>
</Base>
