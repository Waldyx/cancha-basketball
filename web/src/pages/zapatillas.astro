---
// /zapatillas — catálogo rediseñado
// Drop-in replacement for web/src/pages/zapatillas.astro
// Importa tu CSS personalizado desde web/src/styles/cancha-redesign.css

import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";
import { zapatillas } from "../data/zapatillas";
import { findMejorPrecio } from "../lib/scoring";

const LABELS_TIENDA: Record<string, string> = {
  amazon_es: "Amazon", decathlon: "Decathlon", nike_es: "Nike", adidas_es: "Adidas",
  puma_es: "Puma", ua_es: "Under Armour", nb_es: "New Balance", reebok_es: "Reebok",
  footlocker_es: "Foot Locker", jd_sports_es: "JD Sports", zalando_es: "Zalando",
  sprinter_es: "Sprinter", basket_world: "Basket World", aliexpress: "AliExpress",
  kickscrew: "KicksCrew", basket4ballers_es: "Basket4Ballers", manelsanchez_es: "Manel Sánchez",
  fuikaomar_es: "Fuikaomar", "24segons_es": "24 Segons", idealo_es: "Idealo", snipes_eu: "Snipes", atmosfera_sport: "Atmósfera Sport", joom: "Joom", basketballemotion_es: "Basketball Emotion", moolahkicks: "Moolah Kicks",
};

const CAT_LABELS: Record<string, string> = {
  "cushion-focused": "Cushion",
  "responsive":      "Reactiva",
  "balanced":        "Equilibrada",
  "traction-king":   "Tracción",
};

const CAT_ACCENT: Record<string, string> = {
  "cushion-focused": "#38bdf8",
  "responsive":      "#facc15",
  "balanced":        "#d4d4d8",
  "traction-king":   "#fb923c",
};

const scoreOf = (z: typeof zapatillas[0]): number => {
  const v = Object.values(z.puntuaciones);
  return Math.round((v.reduce((a, b) => a + b, 0) / v.length) * 10) / 10;
};

// Junior/GS: se OCULTAN por defecto (duplican a la adulta) → solo con chip Junior.
// Mujer: el chip ♀ Mujer muestra (a) los moldes 100% femeninos (genero="women") y
// (b) las signatures unisex con ADN femenino etiquetadas con tag "mujer" (Sabrina,
// Stewie, A'One, Heir Series…). Todas siguen visibles en el catálogo normal; el chip
// solo filtra para que la jugadora vea de golpe todo su arsenal (como Trending/Retro).
const esGS = (z: typeof zapatillas[0]) => z.genero === "gs";
const esW = (z: typeof zapatillas[0]) => z.genero === "women";
const oculta = (z: typeof zapatillas[0]) => esGS(z); // solo GS se oculta del catálogo
const nonGSCount = zapatillas.filter(z => !oculta(z)).length;

const marcas = [...new Set(zapatillas.map(z => z.marca))].sort();
const marcaCounts: Record<string, number> = {};
zapatillas.forEach(z => { if (!oculta(z)) marcaCounts[z.marca] = (marcaCounts[z.marca] || 0) + 1; });

// Precio mínimo de TODOS los links (disponible irrelevant — solo afecta al botón de compra)
function minPrecioLink(links: typeof zapatillas[0]['links_compra']) {
  if (!links.length) return undefined;
  return links.reduce((a, b) => b.precio_actual < a.precio_actual ? b : a);
}

// Editor's pick = highest score. Tie-break: WoW 12 preferida sobre Curry 12 a igual score.
// Si una zapa futura supera el score actual, gana ella sin importar el override.
const EDITOR_PICK_OVERRIDE = 'lining-wow-12';
const editorPick = [...zapatillas]
  .map(z => ({ z, mejor: minPrecioLink(z.links_compra), score: scoreOf(z) }))
  .filter(x => x.mejor && !oculta(x.z))
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    if (a.z.slug === EDITOR_PICK_OVERRIDE) return -1;
    if (b.z.slug === EDITOR_PICK_OVERRIDE) return 1;
    return 0;
  })[0];

// Trending: top 3 by score
const trending = [...zapatillas].filter(z => !oculta(z)).sort((a, b) => scoreOf(b) - scoreOf(a)).slice(0, 3);

const today = new Date().toLocaleDateString("es-ES", { day: "2-digit", month: "short" }).toUpperCase();

const ordenadas = [...zapatillas].sort((a, b) => scoreOf(b) - scoreOf(a));
---

<Base
  title={`Catálogo de zapatillas de baloncesto | ${zapatillas.length}+ modelos analizados | CANCHA`}
  description={`Catálogo de ${zapatillas.length}+ zapatillas de baloncesto analizadas. Filtra por marca, precio y categoría. Comparativa honesta con precio verificado en tiendas españolas.`}
>
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo">CANCHA<span class="dot">.</span>ZAPA</a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a> <a href="/comparar">Comparar</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas" class="active">Catálogo</a>
          <a href="/calculadora">Calculadora</a>
          <a href="/balones">Accesorios</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    {/* HERO */}
    <section class="cz-hero">
      <div class="shell">
        <div class="cz-hero-grid">
          <div class="hero-left">
            <p class="cz-eyebrow">★ Catálogo · {zapatillas.length} zapas analizadas</p>
            <h1>Encuentra<br/>tu <span class="accent">zapa</span> <span class="italic">sin BS</span></h1>
            <p class="lede">
              Puntuaciones técnicas, precio verificado en tiendas españolas y veredicto honesto.
              Filtra a tu juego o <a href="/quiz" class="lede-link">haz el quiz →</a>
            </p>
            <div class="meta-row">
              <span><span class="pulse"></span>Precios re-verificados {today}</span>
              <span class="sep">·</span>
              <span>Sin sesgo de afiliado</span>
            </div>
            <p style="margin:12px 0 0;font-size:12px;color:var(--cz-text-muted);line-height:1.5">
              ℹ️ Imágenes orientativas y precios en fase beta (pueden variar): confirma color, talla y precio finales en la tienda al abrir el enlace.
            </p>
          </div>
          <aside class="hero-panel">
            <div class="panel-header">
              <span class="dot-pulse"></span>
              <span>RADAR EN VIVO</span>
            </div>
            <div class="panel-grid">
              <div class="stat"><div class="v">{zapatillas.length}</div><div class="k">zapas</div></div>
              <div class="stat"><div class="v">{marcas.length}</div><div class="k">marcas</div></div>
              <div class="stat"><div class="v">15<small>+</small></div><div class="k">tiendas</div></div>
              <div class="stat"><div class="v">100<small>%</small></div><div class="k">honesto</div></div>
            </div>
            <div class="panel-ticker">
              <div class="ticker-label">★ Trending hoy</div>
              {trending.map(z => (
                <div class="ticker-row">
                  <span class="t-rank">{scoreOf(z)}</span>
                  <span class="t-name"><strong>{z.marca}</strong> {z.modelo}</span>
                  <span class="t-price">{Math.round(findMejorPrecio(z.links_compra)?.precio_actual ?? z.precio_msrp_eur)}€</span>
                </div>
              ))}
            </div>
          </aside>
        </div>
        <div class="hero-match">
          <span>Mostrando <strong id="catalogo-count">{nonGSCount}</strong> de <strong>{nonGSCount}</strong> zapas con tus filtros</span>
          <span class="sep">·</span>
          <span><span class="dot-orange"></span>Recomendado: ajusta el quiz para resultados a medida</span>
        </div>
      </div>
    </section>

    {/* ACTION BAR */}
    <div class="shell">
      <div class="cz-actionbar">
        <div class="cz-search">
          <span class="icon">⌕</span>
          <input id="search" placeholder="Buscar marca o modelo…" autocomplete="off" />
        </div>
        <div class="right">
          <div class="cz-select">
            <span class="label">Ordenar</span>
            <select id="sort">
              <option value="score-desc" selected>★ Mejor score</option>
              <option value="precio-asc">↑ Precio</option>
              <option value="precio-desc">↓ Precio</option>
              <option value="nuevas">Más nuevas</option>
            </select>
          </div>
          <div class="cz-segmented" role="group" aria-label="Densidad">
            <button data-density="roomy" class="">▢ AMPLIO</button>
            <button data-density="cozy" class="is-active">▦ NORMAL</button>
            <button data-density="compact" class="">▤ COMPACTO</button>
          </div>
        </div>
      </div>
    </div>

    {/* Active filters bar */}
    <div class="shell">
      <div class="cz-active" id="active-filters">
        <span class="label">Sin filtros activos · mostrando todas</span>
        <span class="count"><strong id="shown-count">{zapatillas.length}</strong> / {zapatillas.length} zapas</span>
      </div>

      <div class="cz-main">
        {/* SIDEBAR */}
        <aside class="cz-sidebar">
          <section>
            <h3><span class="num">01</span> Marca</h3>
            {marcas.map(m => (
              <label class="row">
                <input type="checkbox" data-filter="marca" value={m} />
                <span>{m}</span>
                <span class="count">{marcaCounts[m]}</span>
              </label>
            ))}
          </section>

          <section>
            <h3><span class="num">02</span> Categoría</h3>
            <div class="chip-row">
              {Object.entries(CAT_LABELS).map(([k, l]) => (
                <button class="chip" data-filter="categoria" data-value={k}>{l}</button>
              ))}
              <button class="chip" id="chip-outdoor">Outdoor</button>
              <button class="chip" id="chip-ligera">Ligera</button>
            </div>
          </section>

          <section>
            <h3><span class="num">03</span> Altura</h3>
            <div class="chip-row">
              {["low", "mid", "high"].map(a => (
                <button class="chip" data-filter="altura" data-value={a}>{a}</button>
              ))}
            </div>
          </section>

          <section>
            <h3><span class="num">04</span> Posición</h3>
            <div class="chip-row">
              {["base", "escolta", "alero", "ala-pivot", "pivot"].map(p => (
                <button class="chip" data-filter="posicion" data-value={p}>
                  {p === "ala-pivot" ? "Ala-pívot" : p[0].toUpperCase() + p.slice(1)}
                </button>
              ))}
            </div>
          </section>

          <section>
            <h3><span class="num">05</span> Precio máx.</h3>
            <input type="range" class="range" id="price-range" min="40" max="250" step="10" value="250" />
            <div class="range-label">
              <span>40€</span>
              <span id="price-label" style="color:#f97316;font-weight:900">sin tope</span>
            </div>
          </section>

          <section>
            <h3><span class="num">06</span> Solo</h3>
            <label class="row"><input type="checkbox" id="only-new"/><span>Nuevas (2026)</span></label>
            <label class="row"><input type="checkbox" id="only-verified"/><span>Precio verificado</span></label>
          </section>

          <section>
            <h3><span class="num">07</span> Colección</h3>
            <div class="chip-row">
              <button class="chip" id="chip-trending">🔥 Trending</button>
              <button class="chip" id="chip-retro">🏅 Retro</button>
              <button class="chip" id="chip-gs">👟 Junior (GS)</button>
              <button class="chip" id="chip-w">♀ Mujer</button>
            </div>
          </section>

          <button class="clear-btn" id="clear-filters">↻ Limpiar filtros</button>
        </aside>

        {/* GRID */}
        <div>
          <div class="cz-grid cols-3" id="catalogo-grid">
            {/* Editor's pick */}
            {editorPick && (() => {
              const z = editorPick.z;
              const mejor = editorPick.mejor!;
              const ahorro = z.precio_msrp_eur - mejor.precio_actual;
              return (
                <article class="cz-pick" data-pick="true" style={`--cat:${CAT_ACCENT[z.categoria_principal]}`}>
                  <div class="pick-photo">
                    <span class="pick-watermark">★ PICK</span>
                    {z.imagen_principal && !z.imagen_principal.includes('placeholder') && (
                      <img src={z.imagen_principal} alt={`${z.marca} ${z.modelo}`} loading="eager"
                           onerror="this.style.display='none'" />
                    )}
                  </div>
                  <div class="pick-body">
                    <div class="pick-eyebrow">
                      <span class="pick-tag">★ Pick del editor</span>
                      <span class="pick-cat">{CAT_LABELS[z.categoria_principal]}</span>
                      {z.año_lanzamiento >= 2026 && <span class="pick-new">Nueva {z.año_lanzamiento}</span>}
                    </div>
                    <h2 class="pick-title">
                      <span class="pick-marca">{z.marca}</span>
                      <span class="pick-modelo">{z.modelo}</span>
                    </h2>
                    <p class="pick-verdict">{z.veredicto}</p>
                    <div class="pick-stats">
                      <div class="ps"><div class="psv">{editorPick.score.toFixed(1)}<small>/10</small></div><div class="psk">Score global</div></div>
                      <div class="ps"><div class="psv">{z.peso_real_g}<small>g</small></div><div class="psk">Peso (US 9)</div></div>
                      <div class="ps"><div class="psv">{z.puntuaciones.traccion}<small>/10</small></div><div class="psk">Tracción</div></div>
                      <div class="ps"><div class="psv">{z.puntuaciones.amortiguacion}<small>/10</small></div><div class="psk">Cushion</div></div>
                    </div>
                    <div class="pick-foot">
                      <div class="pick-price">
                        <div class="pp-now">{Math.round(mejor.precio_actual)}€</div>
                        <div class="pp-meta">
                          <span class="msrp">msrp {z.precio_msrp_eur}€</span>
                          <span class="save">−{Math.round(ahorro)}€</span>
                        </div>
                        <div class="pp-tienda"><span class="dot"></span>Verificado en {LABELS_TIENDA[mejor.tienda] || mejor.tienda}</div>
                      </div>
                      <div class="pick-actions">
                        <a class="pick-btn primary" href={`/zapatilla/${z.slug}`}>Ver review →</a>
                      </div>
                    </div>
                  </div>
                </article>
              );
            })()}

            {/* SHOE CARDS */}
            {ordenadas.map((z, i) => {
              const mejor = minPrecioLink(z.links_compra);
              const precio = mejor?.precio_actual ?? z.precio_msrp_eur;
              const tienda = mejor ? LABELS_TIENDA[mejor.tienda] || mejor.tienda : null;
              const score = scoreOf(z);
              const cat = CAT_ACCENT[z.categoria_principal];
              const isNew = z.año_lanzamiento >= 2026;
              const isTrending = (z.tags || []).includes("trending");
              const scClass = score >= 8 ? "hi" : score >= 6.5 ? "mid" : "lo";
              return (
                <a
                  href={`/zapatilla/${z.slug}`}
                  class="cz-card has-reveal"
                  style={`--cat:${cat}`}
                  data-marca={z.marca}
                  data-precio={precio}
                  data-score={score}
                  data-año={z.año_lanzamiento}
                  data-nombre={`${z.marca} ${z.modelo}`.toLowerCase()}
                  data-categoria={z.categoria_principal}
                  data-altura={z.altura}
                  data-posicion={z.ideal_para.posiciones.join(",")}
                  data-outdoor={z.puntuaciones.durabilidad_outdoor >= 7 ? "true" : "false"}
                  data-ligera={z.peso_real_g <= 340 ? "true" : "false"}
                  data-verified={mejor ? "true" : "false"}
                  data-retro={z.es_retro ? "true" : "false"}
                  data-trending={isTrending ? "true" : "false"}
                  data-gs={esGS(z) ? "true" : "false"}
                  data-w={(esW(z) || (z.tags || []).includes("mujer")) ? "true" : "false"}
                >
                  <div class="photo">
                    <span class="cat-badge">{CAT_LABELS[z.categoria_principal]}</span>
                    {z.es_retro
                      ? <span class="new-badge" style="background:#b45309;color:#fef3c7">🏅 Retro</span>
                      : isNew && <span class="new-badge">★ Nueva</span>
                    }
                    {isTrending && <span class="new-badge" style="background:#dc2626;color:#fff;top:auto;bottom:8px">🔥 HOT</span>}
                    <span class={`cz-score-pill ${scClass} score-pill`}>{score}</span>
                    {z.imagen_principal && !z.imagen_principal.includes('placeholder') && (
                      <img src={z.imagen_principal} alt={`${z.marca} ${z.modelo}`} loading="lazy"
                           onerror="this.style.display='none'" />
                    )}
                    <span class="cat-stripe"></span>
                    <div class="cz-ideal-overlay">
                      <div class="lab">Ideal para</div>
                      <div class="rows">
                        <div class="r">
                          <span class="k">Posición</span>
                          <span class="v">{z.ideal_para.posiciones.map(p => p === "ala-pivot" ? "Ala-pívot" : p[0].toUpperCase() + p.slice(1)).join(" · ")}</span>
                        </div>
                        <div class="r">
                          <span class="k">Estilo</span>
                          <span class="v">{z.ideal_para.estilos.join(" / ")}</span>
                        </div>
                        <div class="r">
                          <span class="k">Peso</span>
                          <span class="v">{z.peso_real_g}g · {z.horma}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="body">
                    <div>
                      <p class="marca">{z.marca}</p>
                      <h3 class="modelo">{z.modelo}</h3>
                    </div>
                    <div class="cz-specs">
                      <div class="spec"><span class="v">{z.peso_real_g}<small>g</small></span><span class="k">Peso</span></div>
                      <div class="spec"><span class="v">{z.altura}</span><span class="k">Altura</span></div>
                      <div class="spec"><span class="v">{z.drop_mm}<small>mm</small></span><span class="k">Drop</span></div>
                      <div class="spec"><span class="v">{z.horma}</span><span class="k">Horma</span></div>
                    </div>
                    <div class="foot">
                      <div>
                        {mejor
                          ? <span class="price-meta"><span class="dot"></span>Verificado</span>
                          : <span class="price-meta" style="color:#71717a"><span class="dot" style="background:#71717a"></span>Editorial</span>
                        }
                        <span class="price">{Math.round(precio)}€</span>
                        {tienda && <p class="tienda">en {tienda}</p>}
                      </div>
                      <span class="card-ver-btn">VER →</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>

          <div class="cz-empty hidden" id="catalogo-vacio">
            <div class="icon">🏀</div>
            <h3>Sin matches con esos filtros</h3>
            <p>Aflojar uno o dos filtros, o probar el quiz para una recomendación a medida.</p>
            <button onclick="document.getElementById('clear-filters').click()">↻ Limpiar filtros</button>
          </div>
        </div>
      </div>
    </div>

    {/* Footer */}

  </main>

  <script>
    // ── Load all card images eagerly after page renders ───────────
    // lazy loading + long page = images below fold never load. Fix: after DOMContentLoaded
    // switch all unloaded card images to eager so they load regardless of scroll position.
    {
      const loadAllCardImages = () => {
        document.querySelectorAll<HTMLImageElement>(".cz-card img, .cz-pick img").forEach(img => {
          if (img.loading === "lazy" && (!img.complete || img.naturalWidth === 0)) {
            img.loading = "eager";
          }
        });
      };
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => setTimeout(loadAllCardImages, 100));
      } else {
        setTimeout(loadAllCardImages, 100);
      }
    }
    // ── Filter / sort / search state ─────────────────────────────
    type Filters = {
      q: string;
      marcas: Set<string>;
      categorias: Set<string>;
      alturas: Set<string>;
      posiciones: Set<string>;
      precioMax: number;
      soloNuevas: boolean;
      soloVerificado: boolean;
      soloOutdoor: boolean;
      soloLigera: boolean;
      soloRetro: boolean;
      soloTrending: boolean;
      soloGS: boolean;
      soloW: boolean;
    };
    const filters: Filters = {
      q: "", marcas: new Set(), categorias: new Set(), alturas: new Set(),
      posiciones: new Set(), precioMax: 250,
      soloNuevas: false, soloVerificado: false, soloOutdoor: false, soloLigera: false, soloRetro: false, soloTrending: false, soloGS: false, soloW: false,
    };
    let sortMode = "score-desc";

    const $grid = document.getElementById("catalogo-grid")!;
    const $vacio = document.getElementById("catalogo-vacio")!;
    const $shown = document.getElementById("shown-count")!;
    const $active = document.getElementById("active-filters")!;
    const $count = document.getElementById("catalogo-count")!;
    const $cards = $grid.querySelectorAll<HTMLAnchorElement>(".cz-card");
    const $pick = $grid.querySelector<HTMLElement>("[data-pick]");
    // Total base = sin GS (ocultas por defecto). Las de Mujer SÍ cuentan (están en el catálogo).
    const totalAll = [...$cards].filter(c => c.dataset.gs !== "true").length;

    function activeChips(): { k: string; lab: string; remove: () => void }[] {
      const out: { k: string; lab: string; remove: () => void }[] = [];
      filters.marcas.forEach(m => out.push({ k: "marca", lab: m, remove: () => { filters.marcas.delete(m); apply(); refreshUI(); } }));
      filters.categorias.forEach(c => out.push({ k: "cat", lab: c, remove: () => { filters.categorias.delete(c); apply(); refreshUI(); } }));
      filters.alturas.forEach(a => out.push({ k: "alt", lab: a.toUpperCase(), remove: () => { filters.alturas.delete(a); apply(); refreshUI(); } }));
      filters.posiciones.forEach(p => out.push({ k: "pos", lab: p, remove: () => { filters.posiciones.delete(p); apply(); refreshUI(); } }));
      if (filters.precioMax < 250) out.push({ k: "precio", lab: `≤ ${filters.precioMax}€`, remove: () => { filters.precioMax = 250; (document.getElementById("price-range") as HTMLInputElement).value = "250"; apply(); refreshUI(); } });
      if (filters.soloNuevas) out.push({ k: "new", lab: "Nuevas 2026", remove: () => { filters.soloNuevas = false; (document.getElementById("only-new") as HTMLInputElement).checked = false; apply(); refreshUI(); } });
      if (filters.soloVerificado) out.push({ k: "ver", lab: "Verificado", remove: () => { filters.soloVerificado = false; (document.getElementById("only-verified") as HTMLInputElement).checked = false; apply(); refreshUI(); } });
      if (filters.soloOutdoor) out.push({ k: "out", lab: "Outdoor", remove: () => { filters.soloOutdoor = false; document.getElementById("chip-outdoor")?.classList.remove("is-active"); apply(); refreshUI(); } });
      if (filters.soloLigera) out.push({ k: "ligera", lab: "Ligera", remove: () => { filters.soloLigera = false; document.getElementById("chip-ligera")?.classList.remove("is-active"); apply(); refreshUI(); } });
      if (filters.soloRetro) out.push({ k: "retro", lab: "🏅 Retro", remove: () => { filters.soloRetro = false; document.getElementById("chip-retro")?.classList.remove("is-active"); apply(); refreshUI(); } });
      if (filters.soloTrending) out.push({ k: "trend", lab: "🔥 Trending", remove: () => { filters.soloTrending = false; document.getElementById("chip-trending")?.classList.remove("is-active"); apply(); refreshUI(); } });
      if (filters.soloGS) out.push({ k: "gs", lab: "👟 Junior (GS)", remove: () => { filters.soloGS = false; document.getElementById("chip-gs")?.classList.remove("is-active"); apply(); refreshUI(); } });
      if (filters.soloW) out.push({ k: "w", lab: "♀ Mujer", remove: () => { filters.soloW = false; document.getElementById("chip-w")?.classList.remove("is-active"); apply(); refreshUI(); } });
      if (filters.q) out.push({ k: "q", lab: `“${filters.q}”`, remove: () => { filters.q = ""; (document.getElementById("search") as HTMLInputElement).value = ""; apply(); refreshUI(); } });
      return out;
    }

    function refreshUI() {
      const chips = activeChips();
      $active.innerHTML = "";
      if (chips.length === 0) {
        $active.innerHTML = `<span class="label">Sin filtros activos · mostrando todas</span><span class="count"><strong id="shown-count">${visibleCount()}</strong> / ${totalAll} zapas</span>`;
      } else {
        const html = ['<span class="label">Filtros:</span>'];
        chips.forEach((c, i) => {
          html.push(`<span class="chip">${c.lab}<button class="x" data-idx="${i}">×</button></span>`);
        });
        html.push(`<button style="background:transparent;color:#71717a;border:1px solid #27272a;padding:5px 10px;font-size:10px;letter-spacing:.15em;text-transform:uppercase;font-weight:800;margin-left:4px" id="clear-chips">Limpiar todo</button>`);
        html.push(`<span class="count"><strong>${visibleCount()}</strong> / ${totalAll} zapas</span>`);
        $active.innerHTML = html.join("");
        $active.querySelectorAll<HTMLButtonElement>(".x").forEach((btn) => {
          btn.addEventListener("click", () => chips[parseInt(btn.dataset.idx!)].remove());
        });
        document.getElementById("clear-chips")?.addEventListener("click", () => document.getElementById("clear-filters")?.click());
      }
      $count.textContent = String(visibleCount());
      // Update chip + checkbox states
      document.querySelectorAll<HTMLButtonElement>("[data-filter='categoria']").forEach(b => b.classList.toggle("is-active", filters.categorias.has(b.dataset.value!)));
      document.querySelectorAll<HTMLButtonElement>("[data-filter='altura']").forEach(b => b.classList.toggle("is-active", filters.alturas.has(b.dataset.value!)));
      document.querySelectorAll<HTMLButtonElement>("[data-filter='posicion']").forEach(b => b.classList.toggle("is-active", filters.posiciones.has(b.dataset.value!)));
      document.getElementById("chip-outdoor")?.classList.toggle("is-active", filters.soloOutdoor);
      document.getElementById("chip-ligera")?.classList.toggle("is-active", filters.soloLigera);
      document.getElementById("chip-retro")?.classList.toggle("is-active", filters.soloRetro);
      document.getElementById("chip-trending")?.classList.toggle("is-active", filters.soloTrending);
      document.getElementById("chip-gs")?.classList.toggle("is-active", filters.soloGS);
      document.getElementById("chip-w")?.classList.toggle("is-active", filters.soloW);
    }

    function visibleCount(): number {
      let n = 0;
      $cards.forEach(c => { if (!c.classList.contains("hidden")) n++; });
      return n;
    }

    function apply() {
      let visible = 0;
      const card = (c: HTMLElement) => {
        const marca = c.dataset.marca!;
        const cat = c.dataset.categoria!;
        const alt = c.dataset.altura!;
        const año = parseInt(c.dataset.año!);
        const precio = parseFloat(c.dataset.precio!);
        const nombre = c.dataset.nombre!;
        const pos = (c.dataset.posicion || "").split(",");
        const outdoor = c.dataset.outdoor === "true";
        const ligera = c.dataset.ligera === "true";
        const verified = c.dataset.verified === "true";
        const retro = c.dataset.retro === "true";
        const trending = c.dataset.trending === "true";
        const gs = c.dataset.gs === "true";
        const wm = c.dataset.w === "true";

        let ok = true;
        // GS ocultas por defecto (chip Junior las muestra). Mujer SÍ visibles por defecto;
        // el chip ♀ Mujer filtra a solo-mujer (como Trending/Retro).
        if (filters.soloGS) { if (!gs) ok = false; }
        else if (filters.soloW) { if (!wm) ok = false; }
        else if (gs) ok = false;
        if (filters.marcas.size && !filters.marcas.has(marca)) ok = false;
        if (filters.categorias.size && !filters.categorias.has(cat)) ok = false;
        if (filters.alturas.size && !filters.alturas.has(alt)) ok = false;
        if (filters.posiciones.size && !pos.some(p => filters.posiciones.has(p))) ok = false;
        if (precio > filters.precioMax) ok = false;
        if (filters.soloNuevas && año < 2026) ok = false;
        if (filters.soloVerificado && !verified) ok = false;
        if (filters.soloOutdoor && !outdoor) ok = false;
        if (filters.soloLigera && !ligera) ok = false;
        if (filters.soloRetro && !retro) ok = false;
        if (filters.soloTrending && !trending) ok = false;
        if (filters.q && !nombre.includes(filters.q.toLowerCase())) ok = false;

        c.classList.toggle("hidden", !ok);
        if (ok) visible++;
      };
      $cards.forEach(c => card(c));

      // Hide pick when any filter is on (it's not filterable)
      const filtering = filters.marcas.size + filters.categorias.size + filters.alturas.size + filters.posiciones.size + (filters.precioMax < 250 ? 1 : 0) + (filters.soloNuevas?1:0) + (filters.soloVerificado?1:0) + (filters.soloOutdoor?1:0) + (filters.soloLigera?1:0) + (filters.soloRetro?1:0) + (filters.soloTrending?1:0) + (filters.soloGS?1:0) + (filters.soloW?1:0) + (filters.q?1:0);
      if ($pick) $pick.classList.toggle("hidden", filtering > 0);

      // Sort — usa CSS order en lugar de appendChild para no resetear lazy loading
      const arr = [...$cards];
      arr.sort((a, b) => {
        const aH = a.classList.contains("hidden"), bH = b.classList.contains("hidden");
        if (aH && !bH) return 1; if (!aH && bH) return -1;
        if (sortMode === "precio-asc")  return parseFloat(a.dataset.precio!) - parseFloat(b.dataset.precio!);
        if (sortMode === "precio-desc") return parseFloat(b.dataset.precio!) - parseFloat(a.dataset.precio!);
        if (sortMode === "score-desc")  return parseFloat(b.dataset.score!) - parseFloat(a.dataset.score!);
        if (sortMode === "nuevas")      return parseInt(b.dataset.año!) - parseInt(a.dataset.año!);
        return 0;
      });
      arr.forEach((c, i) => { (c as HTMLElement).style.order = String(i); });

      // Force lazy images to load — css order changes don't retrigger IntersectionObserver
      // Switching loading="eager" is the only reliable way to force load off-screen images
      requestAnimationFrame(() => {
        $cards.forEach(c => {
          if (c.classList.contains("hidden")) return;
          c.querySelectorAll<HTMLImageElement>("img").forEach(img => {
            if (!img.complete || img.naturalWidth === 0) {
              img.loading = "eager";
            }
          });
        });
      });

      $vacio.classList.toggle("hidden", visible > 0);
      $shown && ($shown.textContent = String(visible));
    }

    // Bind controls
    document.getElementById("search")!.addEventListener("input", (e) => {
      filters.q = (e.target as HTMLInputElement).value;
      apply(); refreshUI();
    });
    document.getElementById("sort")!.addEventListener("change", (e) => {
      sortMode = (e.target as HTMLSelectElement).value;
      apply();
    });
    document.querySelectorAll<HTMLInputElement>("[data-filter='marca']").forEach(cb => {
      cb.addEventListener("change", () => {
        cb.checked ? filters.marcas.add(cb.value) : filters.marcas.delete(cb.value);
        apply(); refreshUI();
      });
    });
    document.querySelectorAll<HTMLButtonElement>("[data-filter='categoria']").forEach(b => {
      b.addEventListener("click", () => {
        const v = b.dataset.value!;
        filters.categorias.has(v) ? filters.categorias.delete(v) : filters.categorias.add(v);
        apply(); refreshUI();
      });
    });
    document.querySelectorAll<HTMLButtonElement>("[data-filter='altura']").forEach(b => {
      b.addEventListener("click", () => {
        const v = b.dataset.value!;
        filters.alturas.has(v) ? filters.alturas.delete(v) : filters.alturas.add(v);
        apply(); refreshUI();
      });
    });
    document.querySelectorAll<HTMLButtonElement>("[data-filter='posicion']").forEach(b => {
      b.addEventListener("click", () => {
        const v = b.dataset.value!;
        filters.posiciones.has(v) ? filters.posiciones.delete(v) : filters.posiciones.add(v);
        apply(); refreshUI();
      });
    });
    const $range = document.getElementById("price-range") as HTMLInputElement;
    const $rangeLabel = document.getElementById("price-label")!;
    $range.addEventListener("input", () => {
      filters.precioMax = parseInt($range.value);
      $rangeLabel.textContent = filters.precioMax >= 250 ? "sin tope" : `${filters.precioMax}€`;
      apply(); refreshUI();
    });
    ["only-new","only-verified"].forEach((id, i) => {
      const cb = document.getElementById(id) as HTMLInputElement;
      cb?.addEventListener("change", () => {
        if (i === 0) filters.soloNuevas = cb.checked;
        if (i === 1) filters.soloVerificado = cb.checked;
        apply(); refreshUI();
      });
    });
    // Colección chips (trending / outdoor / ligera / retro)
    const colChips: Array<{ id: string; get: () => boolean; toggle: () => void }> = [
      { id: "chip-trending", get: () => filters.soloTrending, toggle: () => { filters.soloTrending = !filters.soloTrending; } },
      { id: "chip-outdoor",  get: () => filters.soloOutdoor,  toggle: () => { filters.soloOutdoor  = !filters.soloOutdoor;  } },
      { id: "chip-ligera",   get: () => filters.soloLigera,   toggle: () => { filters.soloLigera   = !filters.soloLigera;   } },
      { id: "chip-retro",    get: () => filters.soloRetro,    toggle: () => { filters.soloRetro    = !filters.soloRetro;    } },
      { id: "chip-gs",       get: () => filters.soloGS,       toggle: () => { filters.soloGS      = !filters.soloGS;       } },
      { id: "chip-w",        get: () => filters.soloW,        toggle: () => { filters.soloW       = !filters.soloW;        } },
    ];
    colChips.forEach(({ id, get, toggle }) => {
      document.getElementById(id)?.addEventListener("click", () => {
        toggle(); apply(); refreshUI();
        document.getElementById(id)?.classList.toggle("is-active", get());
      });
    });
    document.getElementById("clear-filters")!.addEventListener("click", () => {
      filters.marcas.clear(); filters.categorias.clear(); filters.alturas.clear(); filters.posiciones.clear();
      filters.precioMax = 250; filters.soloNuevas = false; filters.soloVerificado = false; filters.soloOutdoor = false; filters.soloLigera = false; filters.soloRetro = false; filters.soloTrending = false; filters.soloGS = false; filters.soloW = false;
      filters.q = "";
      document.querySelectorAll<HTMLInputElement>("input[type=checkbox]").forEach(cb => cb.checked = false);
      ["chip-outdoor","chip-ligera","chip-retro","chip-trending","chip-gs","chip-w"].forEach(id => document.getElementById(id)?.classList.remove("is-active"));
      $range.value = "250"; $rangeLabel.textContent = "sin tope";
      (document.getElementById("search") as HTMLInputElement).value = "";
      apply(); refreshUI();
    });

    // Density toggle
    document.querySelectorAll<HTMLButtonElement>("[data-density]").forEach(b => {
      b.addEventListener("click", () => {
        document.querySelectorAll<HTMLButtonElement>("[data-density]").forEach(x => x.classList.remove("is-active"));
        b.classList.add("is-active");
        const d = b.dataset.density!;
        $grid.classList.remove("cols-2","cols-3","cols-4");
        $grid.classList.add(d === "roomy" ? "cols-2" : d === "compact" ? "cols-4" : "cols-3");
      });
    });

    // ── Leer URL params al cargar (desde páginas SEO long-tail) ──────
    // Ejemplos: ?posicion=base  ?categoria=cushion-focused  ?marca=Nike
    //           ?precio_max=80  ?cancha=exterior
    (function initFromUrl() {
      const sp = new URLSearchParams(window.location.search);
      const pos = sp.get("posicion");
      if (pos) { filters.posiciones.add(pos); document.querySelector<HTMLButtonElement>("[data-filter='posicion'][data-value='"+pos+"']")?.classList.add("is-active"); }
      const cat = sp.get("categoria");
      if (cat) { filters.categorias.add(cat); document.querySelector<HTMLButtonElement>("[data-filter='categoria'][data-value='"+cat+"']")?.classList.add("is-active"); }
      const mrc = sp.get("marca");
      if (mrc) { filters.marcas.add(mrc); const cb = document.querySelector<HTMLInputElement>("input[data-filter='marca'][value='"+mrc+"']"); if (cb) cb.checked = true; }
      const pmax = sp.get("precio_max");
      if (pmax) { const v = parseInt(pmax,10); if (!isNaN(v) && v < 250) { filters.precioMax = v; const rng = document.getElementById("price-range") as HTMLInputElement; const lbl = document.getElementById("price-label"); if(rng) rng.value=String(v); if(lbl) lbl.textContent=v+"€"; } }
      const cancha = sp.get("cancha");
      if (cancha === "exterior") { filters.soloOutdoor = true; }
      const trend = sp.get("trending") || sp.get("coleccion");
      if (trend === "1" || trend === "trending") { filters.soloTrending = true; }
      const gs = sp.get("junior") || sp.get("gs");
      if (gs === "1" || gs === "junior" || gs === "gs") { filters.soloGS = true; }
      const wm = sp.get("mujer") || sp.get("women");
      if (wm === "1" || wm === "mujer" || wm === "women") { filters.soloW = true; }
    })();
    // Siempre aplicar al cargar: oculta las GS por defecto (y activa cualquier filtro de la URL).
    apply();
    refreshUI();

  </script>
</Base>

<style>
  /* Tiny inline overrides — most styles come from cancha-redesign.css */
  .hidden { display: none !important; }
</style>
