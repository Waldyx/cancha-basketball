---
// /metodologia — rediseñado coherente con el resto
import "../styles/cancha-redesign.css";
import Base from "../layouts/Base.astro";

const atributos = [
  { lab: "Tracción",          desc: "Agarre de la suela en pista. Crucial para frenos y cambios de dirección." },
  { lab: "Amortiguación",     desc: "Protección frente a impactos. Más cushion = menos castigo en rodillas." },
  { lab: "Respuesta",         desc: "Court feel. Lo cerca que sientes el suelo, lo rápido que reaccionas." },
  { lab: "Soporte lateral",   desc: "Contención del pie en cortes. Reduce riesgo de torceduras." },
  { lab: "Estabilidad",       desc: "Base ancha, sin tambaleo. Importante si pesas mucho o juegas de poste." },
  { lab: "Ligereza",          desc: "Inverso del peso. Más ligera = mejor para guardias rápidos." },
  { lab: "Durabilidad outdoor", desc: "Resistencia en asfalto. Si juegas calle, prioritario." },
  { lab: "Ventilación",       desc: "Transpiración del upper. Útil en verano o pies sudorosos." },
];

const fuentes = [
  {
    nombre: "WearTesters",
    url: "https://weartesters.com",
    desc: "Reviews editoriales en profundidad, escala A+ a F que convertimos a 1-10. La referencia más respetada.",
    col: "#f97316",
  },
  {
    nombre: "TheHoopsGeek",
    url: "https://www.thehoopsgeek.com",
    desc: "BBDD con scores 1-10 en 5 ejes, agregados de 2.000+ reviews independientes. Validación de consenso.",
    col: "#facc15",
  },
  {
    nombre: "RunRepeat Lab",
    url: "https://runrepeat.com",
    desc: "Lab tests reales: peso, tracción SATRA TM144, drop, flexibilidad. Datos objetivos para lo medible.",
    col: "#fb923c",
  },
];

const noHacemos = [
  "Ajustar el ranking según qué tienda paga más comisión. Nunca.",
  "Aceptar pago de marcas a cambio de subir su score.",
  "Esconder los contras de una zapatilla para que parezca mejor.",
  "Recomendar la más cara si la más barata encaja mejor en tu perfil.",
];
---

<Base
  title="Cómo analizamos zapatillas de baloncesto · Metodología | CANCHA.ZAPA"
  description="Cómo puntuamos cada zapatilla de baloncesto. Fuentes: WearTesters, TheHoopsGeek, RunRepeat. Fórmula abierta, sin sesgo de afiliado."
>
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/quiz">Quiz</a>
          <a href="/metodologia" class="active">Método</a>
          <a href="/faq">FAQ</a>
                  <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    {/* HERO */}
    <section class="doc-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Metodología</p>
        <h1 class="doc-h1">
          Cómo<br/>
          <span class="accent">puntuamos</span><br/>
          cada zapa
        </h1>
        <p class="doc-lede">
          Sin secretos. Esto es exactamente cómo decidimos qué zapatilla te recomendamos.
          Si algo te chirría, verifica en las fuentes y juzga tú.
        </p>
      </div>
    </section>

    {/* SECCIONES */}
    <article class="doc-article">
      <div class="shell shell-narrow">

        {/* 01 — Atributos */}
        <section class="doc-section">
          <div class="doc-section-head">
            <span class="doc-num">01</span>
            <h2 class="doc-h2">Los 8 atributos</h2>
          </div>
          <p class="doc-body">
            Cada zapatilla se puntúa de 1 a 10 en 8 dimensiones técnicas.
            No inventamos cosas: son las mismas dimensiones que evalúan
            WearTesters, TheHoopsGeek y RunRepeat.
          </p>
          <div class="doc-grid-2">
            {atributos.map(a => (
              <div class="doc-card">
                <p class="doc-card-lab">{a.lab}</p>
                <p class="doc-card-desc">{a.desc}</p>
              </div>
            ))}
          </div>
        </section>

        {/* 02 — Fuentes */}
        <section class="doc-section">
          <div class="doc-section-head">
            <span class="doc-num">02</span>
            <h2 class="doc-h2">Las fuentes</h2>
          </div>
          <p class="doc-body">
            No probamos cada zapa nosotros — sería deshonesto pretenderlo.
            Combinamos 3 fuentes públicas reconocidas y declaramos en cada ficha
            de qué fuente sale cada score.
          </p>
          <ul class="doc-sources">
            {fuentes.map(f => (
              <li class="doc-source" style={`--col:${f.col}`}>
                <a href={f.url} target="_blank" rel="noopener noreferrer">
                  <p class="doc-source-name">{f.nombre} <span class="doc-source-ext">↗</span></p>
                  <p class="doc-source-desc">{f.desc}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>

        {/* 03 — Fórmula */}
        <section class="doc-section">
          <div class="doc-section-head">
            <span class="doc-num">03</span>
            <h2 class="doc-h2">La fórmula del match</h2>
          </div>
          <p class="doc-body">
            Cuando rellenas el quiz, cada respuesta modifica el peso de los atributos.
            Por ejemplo, si dices "rodillas", la amortiguación pasa a pesar más en el cálculo.
          </p>
          <div class="doc-code">
            <p class="doc-code-comment">// Por cada zapatilla:</p>
            <p><span class="doc-code-num">1.</span> Filtros duros (presupuesto, durabilidad outdoor, cushion mínimo según lesiones, no low-top si tobillos).</p>
            <p><span class="doc-code-num">2.</span> Score = Σ(puntuación × peso) / Σ(pesos)</p>
            <p><span class="doc-code-num">3.</span> Match % = round(score × 10)</p>
            <p><span class="doc-code-num">4.</span> Top 5 con regla de diversidad (máx 2 zapas de la misma marca).</p>
          </div>
          <p class="doc-body" style="margin-top:14px">
            Pura matemática ponderada que tú puedes auditar. No hay ML mágico, no hay IA opaca.
          </p>
        </section>

        {/* 04 — Lo que NO hacemos */}
        <section class="doc-section">
          <div class="doc-section-head">
            <span class="doc-num">04</span>
            <h2 class="doc-h2">Lo que NO hacemos</h2>
          </div>
          <ul class="doc-no-list">
            {noHacemos.map(item => (
              <li><span class="bull">✗</span>{item}</li>
            ))}
          </ul>
          <p style="margin-top:24px">
            <a href="/financiacion" class="doc-link">Mira cómo nos financiamos →</a>
          </p>
        </section>

        {/* Disclaimer */}
        <aside class="doc-disclaimer">
          <p class="cz-eyebrow" style="color:#facc15">⚠ Lo que sí asumimos</p>
          <p>
            Esto es un proyecto independiente hecho como hobby. Las puntuaciones
            son nuestra mejor interpretación de las fuentes públicas — pueden tener errores.
            Si encuentras algo raro, escríbenos. Y si pruebas una zapa y discrepas con
            nuestro veredicto, también: la BD se mejora con feedback real.
          </p>
        </aside>
      </div>
    </article>

    <footer style="background:#000;border-top:4px solid #f97316;padding:32px 0;margin-top:40px">
      <div class="shell" style="display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;align-items:center">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/quiz">Quiz</a>
          <a href="/financiacion">Financiación</a>
          <a href="/faq">FAQ</a>
        </nav>
        <p style="font-size:10px;color:#52525b;text-transform:uppercase;letter-spacing:.15em;font-weight:700;margin:0">
          Proyecto independiente · Sin sesgo de afiliado
        </p>
      </div>
    </footer>
  </main>
</Base>
