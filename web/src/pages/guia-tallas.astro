---
// /guia-tallas — rediseñado coherente con el resto
import Base from "../layouts/Base.astro";
import "../styles/cancha-redesign.css";

const tallasHombre = [
  ["6", "38.5", "5.5", "24.0"],
  ["6.5", "39", "6", "24.5"],
  ["7", "40", "6.5", "25.0"],
  ["7.5", "40.5", "7", "25.5"],
  ["8", "41", "7.5", "26.0"],
  ["8.5", "42", "8", "26.5"],
  ["9", "42.5", "8.5", "27.0"],
  ["9.5", "43", "9", "27.5"],
  ["10", "44", "9.5", "28.0"],
  ["10.5", "44.5", "10", "28.5"],
  ["11", "45", "10.5", "29.0"],
  ["11.5", "45.5", "11", "29.5"],
  ["12", "46", "11.5", "30.0"],
  ["13", "47.5", "12.5", "31.0"],
  ["14", "48.5", "13.5", "32.0"],
];

const tallasMujer = [
  ["5", "35.5", "3", "22.0"],
  ["5.5", "36", "3.5", "22.5"],
  ["6", "36.5", "4", "23.0"],
  ["6.5", "37.5", "4.5", "23.5"],
  ["7", "38", "5", "24.0"],
  ["7.5", "38.5", "5.5", "24.5"],
  ["8", "39", "6", "25.0"],
  ["8.5", "40", "6.5", "25.5"],
  ["9", "40.5", "7", "26.0"],
  ["9.5", "41", "7.5", "26.5"],
  ["10", "42", "8", "27.0"],
  ["10.5", "42.5", "8.5", "27.5"],
  ["11", "43", "9", "28.0"],
];

const pasos = [
  { n: "01", t: "Coloca el pie sobre papel", d: "Pon una hoja en el suelo y apoya el pie encima con el peso del cuerpo distribuido normalmente (de pie, no sentado)." },
  { n: "02", t: "Traza el contorno",         d: "Con un lápiz, traza el contorno de todo el pie manteniéndolo perfectamente vertical." },
  { n: "03", t: "Mide la longitud",          d: "Desde el punto más extremo del talón hasta la punta del dedo más largo. Esa es tu medida en cm." },
  { n: "04", t: "Añade entre 0,5 y 1 cm",    d: "Las zapas de baloncesto necesitan holgura para el movimiento durante los cortes. 0,5 cm para ajustado, 1 cm para cómodo." },
  { n: "05", t: "Mide por la tarde",         d: "El pie se hincha a lo largo del día. Mídelo por la tarde para evitar que aprieten cuando más lo necesitas." },
];

const marcas = [
  { marca: "Nike / Jordan",      horma: "Estrecha",         col: "#f97316",
    c: "Suelen ir un poco estrechos, especialmente en el antepié. Si tienes pie ancho, sube medio número o busca horma ancha (serie LeBron)." },
  { marca: "Adidas",             horma: "Normal",           col: "#4ade80",
    c: "Horma bastante estándar. Modelos con Primeknit (Harden, Dame) se sienten algo más anchos gracias al tejido elástico." },
  { marca: "New Balance",        horma: "Ancha",            col: "#38bdf8",
    c: "Conocida por hormas anchas y tallas generosas. Si tienes pie ancho, NB es tu mejor aliada sin subir talla." },
  { marca: "Under Armour",       horma: "Normal-estrecha",  col: "#facc15",
    c: "Depende del modelo. La línea Curry (Flow) puede ir estrecha. Sube medio número si tienes pie ancho." },
  { marca: "Puma",               horma: "Normal",           col: "#a78bfa",
    c: "Horma estándar. La línea MB (LaMelo) puede ir algo estrecha en pies anchos." },
  { marca: "Anta / Li-Ning",     horma: "Normal-estrecha",  col: "#fb923c",
    c: "Las chinas suelen ir un poco pequeñas en tallas bajas. Sube 0,5–1 número si es tu primera compra de esa marca." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Cómo elegir la talla correcta de zapatillas de baloncesto",
  description: "Guía completa para medir tu pie y encontrar la talla correcta de zapatillas de baloncesto según marca.",
  step: pasos.map(p => ({ "@type": "HowToStep", name: p.t, text: p.d })),
};
---

<Base
  title="Guía de tallas de zapatillas de baloncesto | CANCHA.ZAPA"
  description="Tabla de conversión de tallas US, EU, UK y CM para zapatillas de baloncesto de hombre y mujer. Consejos por marca: Nike, Adidas, Jordan y más."
  jsonLd={jsonLd}
>
  <main class="app">

    <div class="cz-strip"></div>
    <header class="cz-header">
      <div class="shell cz-header-inner">
        <a href="/" class="cz-logo"><span class="logo">CANCHA</span><span class="dot">.</span><span class="logo">ZAPA</span></a>
        <nav class="cz-nav">
          <a href="/quiz">Quiz</a> <a href="/comparar">Comparar</a>
          <a href="/rankings">Rankings</a>
          <a href="/zapatillas">Catálogo</a>
          <a href="/calculadora">Calculadora</a>
          <a href="/guia-tallas" class="active" aria-current="page">Tallas</a>
                  <a href="/balones">Accesorios</a>
          <a href="/blog">Blog</a>
          <a href="/mis-zapas">♥ Mis zapas</a>
        </nav>
      </div>
    </header>

    <section class="doc-hero">
      <div class="shell">
        <p class="cz-eyebrow">★ Tallas y medidas</p>
        <h1 class="doc-h1">
          Guía de tallas<br/>
          <span class="accent">zapatillas</span><br/>
          de baloncesto
        </h1>
        <p class="doc-lede">
          Tabla de conversión US → EU → UK → CM para hombre y mujer.
          Consejos por marca y cómo medir tu pie correctamente.
        </p>
      </div>
    </section>

    <article class="doc-article">
      <div class="shell shell-narrow">

        {/* TABLA HOMBRE */}
        <section class="doc-section">
          <div class="doc-section-head">
            <span class="doc-num">01</span>
            <h2 class="doc-h2">Tabla de tallas <span class="muted">— Hombre</span></h2>
          </div>
          <div class="doc-table-wrap">
            <table class="doc-table size-table">
              <thead>
                <tr><th>US</th><th>EU</th><th>UK</th><th>CM</th></tr>
              </thead>
              <tbody>
                {tallasHombre.map(([us, eu, uk, cm]) => (
                  <tr><td><strong>{us}</strong></td><td>{eu}</td><td>{uk}</td><td>{cm}</td></tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        {/* TABLA MUJER */}
        <section class="doc-section">
          <div class="doc-section-head">
            <span class="doc-num">02</span>
            <h2 class="doc-h2">Tabla de tallas <span class="muted">— Mujer</span></h2>
          </div>
          <div class="doc-table-wrap">
            <table class="doc-table size-table">
              <thead>
                <tr><th>US (W)</th><th>EU</th><th>UK</th><th>CM</th></tr>
              </thead>
              <tbody>
                {tallasMujer.map(([us, eu, uk, cm]) => (
                  <tr><td><strong>{us}</strong></td><td>{eu}</td><td>{uk}</td><td>{cm}</td></tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        {/* CÓMO MEDIR */}
        <section class="doc-section">
          <div class="doc-section-head">
            <span class="doc-num">03</span>
            <h2 class="doc-h2">Cómo medir tu pie</h2>
          </div>
          <ol class="doc-principles">
            {pasos.map(p => (
              <li>
                <p class="doc-principle-num">{p.n}</p>
                <div>
                  <p class="doc-principle-title">{p.t}</p>
                  <p class="doc-principle-body">{p.d}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>

        {/* POR MARCA */}
        <section class="doc-section">
          <div class="doc-section-head">
            <span class="doc-num">04</span>
            <h2 class="doc-h2">Particularidades por marca</h2>
          </div>
          <div class="doc-marcas">
            {marcas.map(m => (
              <div class="doc-marca" style={`--col:${m.col}`}>
                <div class="dm-head">
                  <span class="dm-name">{m.marca}</span>
                  <span class="dm-horma">{m.horma}</span>
                </div>
                <p class="dm-body">{m.c}</p>
              </div>
            ))}
          </div>
        </section>

        <aside class="doc-cta-box">
          <div>
            <p class="doc-cta-title">¿Ya sabes tu talla?</p>
            <p class="doc-cta-sub">Usa el quiz para encontrar la zapa perfecta según tu juego. 60 segundos.</p>
          </div>
          <a href="/quiz" class="home-btn primary">Hacer el quiz →</a>
        </aside>
      </div>
    </article>

  </main>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Base>
