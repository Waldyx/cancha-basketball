---
// Updated Base.astro — drop-in replacement for web/src/layouts/Base.astro
// Adds: font preload, skip-to-content link, dynamic OG support, broken-img fallback.

import "../styles/global.css";
import CommandPalette from "../components/CommandPalette.astro";
import CookieBanner from "../components/CookieBanner.astro";
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description?: string;
  /** Slug de imagen OG si quieres una específica. Por defecto usa la marca. */
  ogImage?: string;
  /** Tipo de OG: website (default) o article para fichas de zapatillas. */
  ogType?: "website" | "article";
  /** JSON-LD para schema.org (Product, Review, etc.). */
  jsonLd?: object;
}

const {
  title,
  description = "Encuentra la zapatilla de baloncesto perfecta para tu juego. Quiz personalizado + comparador honesto de precios.",
  ogImage = "/og-default.svg",
  ogType = "website",
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0c0c0c" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="CANCHA.ZAPA" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: preconnect + preload de los archivos críticos para reducir FOUT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Inter 900 (display weight) + Barlow Condensed 900 + Italic 900 -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/inter/v18/UcCo3FwrK3iLTcvneQg7Ca725JhhKnNqk4j1ebLhAm8SrXTcv0L8.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/barlowcondensed/v12/HTxxL3I-JCGChYJ8VI-L6OO_au7B6xPTBYNwSGSdsdg.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Barlow+Condensed:ital,wght@0,700;0,900;1,700;1,900&display=swap"
      rel="stylesheet"
    />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Schema.org JSON-LD -->
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }

    <!-- Analytics (Plausible — solo en producción, sin cookies) -->
    <Analytics />

    <!-- Skip-link styles (accesibilidad) -->
    <style is:global>
      .skip-to-content {
        position: absolute;
        top: -40px;
        left: 8px;
        z-index: 100;
        padding: 8px 14px;
        background: #f97316;
        color: #0c0c0c;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 12px;
        text-decoration: none;
        transition: top 0.15s;
      }
      .skip-to-content:focus {
        top: 8px;
        outline: 2px solid #facc15;
        outline-offset: 2px;
      }
    </style>
  </head>
  <body class="bg-zinc-950 text-white antialiased">
    <!-- Skip-to-content para usuarios de teclado / lectores de pantalla -->
    <a href="#main-content" class="skip-to-content">Saltar al contenido</a>

    <!-- Cancha street de fondo (muy sutil en páginas interiores) -->
    <div class="fixed inset-0 pointer-events-none select-none z-0" aria-hidden="true">
      <img
        src="/bg-court.svg"
        alt=""
        role="presentation"
        class="w-full h-full object-cover opacity-[0.18]"
      />
      <div class="absolute inset-0 bg-zinc-950/50"></div>
    </div>

    <!-- Main content target for skip link -->
    <div id="main-content" class="relative z-10">
      <slot />
    </div>

    <!-- Footer global -->
    <footer style="position:relative;z-index:10;border-top:1px solid rgba(63,63,70,0.3);padding:16px 0;margin-top:0">
      <div style="max-width:1280px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
        <p style="font-size:11px;color:#3f3f46;text-transform:uppercase;letter-spacing:.12em;font-weight:700;margin:0">
          © 2026 CANCHA.ZAPA · Proyecto independiente
        </p>
        <div style="display:flex;gap:20px">
          <a href="/blog" style="font-size:11px;color:#52525b;text-transform:uppercase;letter-spacing:.12em;font-weight:700;text-decoration:none">Blog</a>
          <a href="/faq" style="font-size:11px;color:#52525b;text-transform:uppercase;letter-spacing:.12em;font-weight:700;text-decoration:none">FAQ</a>
          <a href="/metodologia" style="font-size:11px;color:#52525b;text-transform:uppercase;letter-spacing:.12em;font-weight:700;text-decoration:none">Metodología</a>
          <a href="/financiacion" style="font-size:11px;color:#52525b;text-transform:uppercase;letter-spacing:.12em;font-weight:700;text-decoration:none">Financiación</a>
          <a href="/privacidad" style="font-size:11px;color:#52525b;text-transform:uppercase;letter-spacing:.12em;font-weight:700;text-decoration:none">Privacidad</a>
        </div>
      </div>
    </footer>

    <!-- Búsqueda global Cmd+K -->
    <CommandPalette />

    <!-- Cookie banner (EU compliance) -->
    <CookieBanner />

    <script>
      const hideBrokenImages = () => {
        document.querySelectorAll("img").forEach((img) => {
          const hide = () => {
            if (img.closest(".cz-courtbg") || img.getAttribute("role") === "presentation") return;
            img.style.display = "none";
          };
          img.addEventListener("error", hide, { once: true });
          window.setTimeout(() => {
            if (img.naturalWidth === 0) hide();
          }, 1800);
        });
      };
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", hideBrokenImages, { once: true });
      } else {
        hideBrokenImages();
      }
    </script>
  </body>
</html>
