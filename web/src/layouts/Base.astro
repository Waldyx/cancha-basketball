---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Slug de imagen OG si quieres una específica. Por defecto usa la marca. */
  ogImage?: string;
  /** Tipo de OG: website (default) o article para fichas de zapatillas. */
  ogType?: "website" | "article";
  /** JSON-LD para schema.org (Product, Review, etc.). */
  jsonLd?: object;
}

const {
  title,
  description = "Encuentra la zapatilla de baloncesto perfecta para tu juego. Quiz personalizado + comparador honesto de precios.",
  ogImage = "/og-default.svg",
  ogType = "website",
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Cancha" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fuente -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Barlow+Condensed:ital,wght@0,700;0,900;1,700;1,900&display=swap" rel="stylesheet" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Schema.org JSON-LD -->
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
  </head>
  <body class="bg-zinc-950 text-white antialiased">
    <!-- Cancha street de fondo (muy sutil en páginas interiores) -->
    <div class="fixed inset-0 pointer-events-none select-none z-0" aria-hidden="true">
      <img
        src="/bg-court.svg"
        alt=""
        role="presentation"
        class="w-full h-full object-cover opacity-[0.18]"
      />
      <div class="absolute inset-0 bg-zinc-950/75"></div>
    </div>
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>
