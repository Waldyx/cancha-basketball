---
// Componente: CommandPalette (Cmd+K / Ctrl+K)
//
// Inclúyelo en Base.astro para que esté disponible en todas las páginas.
// Busca por marca, modelo, slug, categoría, tag. Navegación con flechas + Enter.

import { zapatillas } from "../data/zapatillas";

// Build index for client-side fuzzy search
const index = zapatillas.map((z) => ({
  slug: z.slug,
  marca: z.marca,
  modelo: z.modelo,
  search: `${z.marca} ${z.modelo} ${z.slug} ${z.categoria_principal} ${z.tags.join(" ")}`.toLowerCase(),
  precio: z.precio_msrp_eur,
  cat: z.categoria_principal,
  img: z.imagen_principal,
}));

// Static shortcuts (always shown when query is empty)
const shortcuts = [
  { lab: "Catálogo",     href: "/zapatillas", icon: "▦", k: "G C" },
  { lab: "Quiz",         href: "/quiz",       icon: "★", k: "G Q" },
  { lab: "Rankings",     href: "/rankings",   icon: "↑", k: "G R" },
  { lab: "Comparar",     href: "/comparar",   icon: "⇄", k: "G P" },
  { lab: "Mis favoritas", href: "/mis-zapas",  icon: "♥", k: "G F" },
  { lab: "Metodología",  href: "/metodologia", icon: "?", k: "G M" },
  { lab: "Guía de tallas", href: "/guia-tallas", icon: "↧", k: "G T" },
];
---

<!-- Overlay -->
<div id="cmdk" class="cmdk-overlay hidden" role="dialog" aria-modal="true" aria-label="Búsqueda global">
  <div class="cmdk-card" id="cmdk-card">
    <div class="cmdk-search">
      <span class="cmdk-icon">⌕</span>
      <input
        id="cmdk-input"
        type="text"
        placeholder="Buscar zapatillas, marcas, secciones…"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="cmdk-esc">ESC</kbd>
    </div>
    <div class="cmdk-results" id="cmdk-results" role="listbox">
      <!-- Inicial: shortcuts -->
      <div class="cmdk-group">
        <div class="cmdk-group-label">Ir a</div>
        {shortcuts.map((s, i) => (
          <a class="cmdk-item" href={s.href} data-idx={i} role="option">
            <span class="cmdk-item-icon">{s.icon}</span>
            <span class="cmdk-item-text">{s.lab}</span>
            <span class="cmdk-item-kbd">{s.k}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="cmdk-foot">
      <span><kbd>↑↓</kbd> mover</span>
      <span><kbd>↵</kbd> abrir</span>
      <span><kbd>ESC</kbd> cerrar</span>
      <span style="margin-left:auto">{zapatillas.length} zapas indexadas</span>
    </div>
  </div>
</div>

<script define:vars={{ index, shortcuts }}>
  const $overlay = document.getElementById("cmdk");
  const $input = document.getElementById("cmdk-input");
  const $results = document.getElementById("cmdk-results");
  let active = 0;

  function open() {
    $overlay.classList.remove("hidden");
    $input.value = "";
    renderShortcuts();
    requestAnimationFrame(() => $input.focus());
  }
  function close() {
    $overlay.classList.add("hidden");
  }

  // Open on Cmd+K / Ctrl+K
  window.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      open();
      return;
    }
    if (e.key === "Escape" && !$overlay.classList.contains("hidden")) {
      close();
    }
  });

  // Close on overlay click (but not card)
  $overlay.addEventListener("click", (e) => {
    if (e.target === $overlay) close();
  });

  function renderShortcuts() {
    $results.innerHTML = `
      <div class="cmdk-group">
        <div class="cmdk-group-label">Ir a</div>
        ${shortcuts.map((s, i) => `
          <a class="cmdk-item ${i === 0 ? "is-active" : ""}" href="${s.href}" data-idx="${i}" role="option">
            <span class="cmdk-item-icon">${s.icon}</span>
            <span class="cmdk-item-text">${s.lab}</span>
            <span class="cmdk-item-kbd">${s.k}</span>
          </a>
        `).join("")}
      </div>
    `;
    active = 0;
  }

  function escapeHtml(s) {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  function renderResults(q) {
    if (!q) { renderShortcuts(); return; }
    const ql = q.toLowerCase();
    const matched = index
      .filter(z => z.search.includes(ql))
      .slice(0, 20);

    if (matched.length === 0) {
      $results.innerHTML = `
        <div class="cmdk-empty">
          <p>Sin resultados para <strong>"${escapeHtml(q)}"</strong></p>
          <a href="/zapatillas?q=${encodeURIComponent(q)}" class="cmdk-empty-link">Buscar en catálogo →</a>
        </div>
      `;
      active = -1;
      return;
    }

    $results.innerHTML = `
      <div class="cmdk-group">
        <div class="cmdk-group-label">Zapatillas (${matched.length})</div>
        ${matched.map((z, i) => `
          <a class="cmdk-item ${i === 0 ? "is-active" : ""}" href="/zapatilla/${z.slug}" data-idx="${i}" role="option">
            <span class="cmdk-item-thumb"><img src="${z.img}" alt="" onerror="this.style.display='none'" /></span>
            <span class="cmdk-item-text">
              <span class="cmdk-item-marca">${escapeHtml(z.marca)}</span>
              <span class="cmdk-item-modelo">${escapeHtml(z.modelo)}</span>
            </span>
            <span class="cmdk-item-price">${z.precio}€</span>
          </a>
        `).join("")}
      </div>
    `;
    active = 0;
  }

  $input.addEventListener("input", () => renderResults($input.value.trim()));

  // Keyboard nav within results
  $input.addEventListener("keydown", (e) => {
    const items = $results.querySelectorAll(".cmdk-item");
    if (items.length === 0) return;
    if (e.key === "ArrowDown") {
      e.preventDefault();
      active = (active + 1) % items.length;
      updateActive(items);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      active = (active - 1 + items.length) % items.length;
      updateActive(items);
    } else if (e.key === "Enter") {
      e.preventDefault();
      const item = items[active];
      if (item) location.href = item.getAttribute("href");
    }
  });

  function updateActive(items) {
    items.forEach((it, i) => it.classList.toggle("is-active", i === active));
    const item = items[active];
    if (item) item.scrollIntoView({ block: "nearest" });
  }

  // Trigger button (optional, e.g. in header)
  document.querySelectorAll("[data-cmdk-open]").forEach((btn) => {
    btn.addEventListener("click", () => open());
  });
</script>

<style is:global>
  .cmdk-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(12, 12, 12, 0.78);
    backdrop-filter: blur(6px);
    display: flex; justify-content: center; padding: 12vh 16px;
  }
  .cmdk-overlay.hidden { display: none; }
  .cmdk-card {
    width: 100%; max-width: 620px;
    background: #0f0f0f; border: 1px solid rgba(249,115,22,0.5);
    box-shadow: 0 0 0 1px rgba(249,115,22,0.18), 0 24px 60px rgba(0,0,0,0.7);
    display: flex; flex-direction: column;
    max-height: 70vh;
  }
  .cmdk-search {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(63,63,70,0.4);
  }
  .cmdk-icon { color: #f97316; font-size: 18px; }
  .cmdk-search input {
    flex: 1; background: transparent; border: none; outline: none;
    color: #fff; font-size: 16px; font-weight: 600;
    font-family: "Inter", system-ui, sans-serif;
  }
  .cmdk-search input::placeholder { color: #52525b; }
  .cmdk-esc {
    font-family: ui-monospace, monospace; font-size: 10px;
    color: #71717a; padding: 3px 7px;
    border: 1px solid #27272a; border-radius: 3px;
    background: rgba(22,22,22,0.6);
  }
  .cmdk-results {
    flex: 1; overflow-y: auto;
    padding: 8px;
  }
  .cmdk-group-label {
    font-size: 9px; font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.2em; color: #52525b;
    padding: 8px 8px 6px;
  }
  .cmdk-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 10px;
    color: #d4d4d8; text-decoration: none;
    border-radius: 2px;
    transition: background 0.1s;
  }
  .cmdk-item.is-active {
    background: rgba(249,115,22,0.12);
    color: #fff;
  }
  .cmdk-item:hover { background: rgba(249,115,22,0.08); color: #fff; }
  .cmdk-item-icon {
    width: 26px; height: 26px; border: 1px solid #27272a;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 13px; color: #f97316;
  }
  .cmdk-item.is-active .cmdk-item-icon {
    background: #f97316; color: #0c0c0c; border-color: #f97316;
  }
  .cmdk-item-thumb {
    width: 36px; height: 36px;
    background: linear-gradient(180deg, #27272a, #18181b);
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .cmdk-item-thumb img { max-width: 90%; max-height: 90%; object-fit: contain; }
  .cmdk-item-text { flex: 1; display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .cmdk-item-marca {
    font-size: 9px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.14em; color: #71717a;
  }
  .cmdk-item-modelo {
    font-family: "Barlow Condensed", sans-serif; font-weight: 900;
    font-size: 16px; line-height: 1;
    text-transform: uppercase; letter-spacing: -0.015em; color: inherit;
  }
  .cmdk-item-price {
    font-family: "Barlow Condensed", sans-serif; font-weight: 900;
    font-size: 16px; color: #f97316;
  }
  .cmdk-item-kbd {
    font-family: ui-monospace, monospace; font-size: 10px;
    color: #52525b;
    padding: 3px 7px; border: 1px solid #27272a; border-radius: 3px;
    background: rgba(22,22,22,0.4);
  }
  .cmdk-empty {
    padding: 32px 18px; text-align: center;
  }
  .cmdk-empty p { color: #a1a1aa; font-size: 14px; margin: 0 0 12px; }
  .cmdk-empty strong { color: #fff; }
  .cmdk-empty-link {
    color: #f97316; font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.14em; font-size: 11px;
    border-bottom: 2px solid #f97316; padding-bottom: 1px;
  }
  .cmdk-foot {
    display: flex; gap: 14px; align-items: center;
    padding: 8px 14px;
    border-top: 1px solid rgba(63,63,70,0.3);
    font-size: 10px; color: #52525b;
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em;
  }
  .cmdk-foot kbd {
    font-family: ui-monospace, monospace; font-size: 9px;
    color: #71717a; padding: 2px 5px;
    border: 1px solid #27272a; border-radius: 2px;
    background: rgba(22,22,22,0.4); margin-right: 2px;
  }

  /* Header trigger button */
  .cz-cmdk-trigger {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 12px;
    background: rgba(22,22,22,0.6); border: 1px solid #27272a;
    color: #71717a;
    font-size: 12px; font-weight: 600;
    cursor: pointer;
    transition: all 0.12s;
  }
  .cz-cmdk-trigger:hover { color: #fff; border-color: #f97316; }
  .cz-cmdk-trigger kbd {
    font-family: ui-monospace, monospace; font-size: 9px;
    color: #71717a; padding: 1px 5px;
    border: 1px solid #27272a; border-radius: 2px;
    background: rgba(12,12,12,0.6);
  }

  @media (max-width: 560px) {
    .cmdk-overlay { padding: 16vh 12px; }
    .cmdk-foot { font-size: 9px; gap: 8px; flex-wrap: wrap; }
    .cmdk-item-kbd { display: none; }
  }
</style>
