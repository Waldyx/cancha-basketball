---
// Componente: Analytics (Cloudflare Web Analytics — privacy-first, sin cookies)
//
// Cloudflare Web Analytics: gratis, sin cookies, sin localStorage, GDPR-compliant.
// No rastrea visitantes individuales → no requiere banner de cookies.
// Migrado de Plausible (sesión 28, 2026-06-18, al acabar el trial de Plausible).
//
// Token del beacon: Cloudflare dash → Analytics → Web Analytics → canchazapa.com.

const isDev = import.meta.env.DEV;
const CF_TOKEN = "4052ed0c20a7494895e7111141ce38b5";
---

{!isDev && (
  <>
    {/* Cloudflare Web Analytics — beacon JS, sin cookies. */}
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={`{"token": "${CF_TOKEN}"}`}
    ></script>

    {/* No-op de window.plausible: el sitio aún llama a window.plausible(...)
        para eventos custom. Lo dejamos como función vacía para no romper esas
        llamadas. Cloudflare Web Analytics no soporta eventos custom; el dato
        de clicks de afiliado ya lo dan los paneles de Amazon/Awin/TradeTracker. */}
    <script is:inline>
      {`window.plausible = window.plausible || function(){};`}
    </script>
  </>
)}

<!--
  EVENTOS PERSONALIZADOS (legado):

  El sitio sigue llamando a window.plausible("Affiliate Click", ...) en varios
  sitios. Tras la migración a Cloudflare Web Analytics esas llamadas son no-op
  (Cloudflare no tiene eventos custom). Los clicks de afiliado se miden desde
  los paneles de Amazon, Awin y TradeTracker. Si algún día se quiere recuperar
  el tracking de eventos, valorar Plausible de pago o un endpoint propio.
-->
