---
// ChatWidget.astro — asistente IA flotante de CANCHA.ZAPA
//
// Burbuja esquina inferior-derecha en todas las páginas. Inclúyelo una vez en
// Base.astro (antes de </body>):
//   import ChatWidget from "../components/ChatWidget.astro";
//   <ChatWidget />
//
// Backend: hace fetch POST a /api/chat con { messages: [{role, content}, ...] }.
// Acepta dos formatos de respuesta:
//   - JSON simple:  { reply: "texto..." }
//   - Streaming:    text/plain o text/event-stream (se concatena el body)
//
// Mini-cards: si la respuesta incluye un marcador [[shoe:<slug>]], se sustituye
// por una card con foto + score + precio + link. Los datos de zapa se inyectan
// desde zapatillas.ts en build time (SHOE_INDEX abajo) — sin llamadas extra.

import { zapatillas } from "../data/zapatillas";
import { findMejorPrecioMostrado } from "../lib/scoring";

// Índice mínimo para las mini-cards (todas las zapas, ~200)
const SHOE_INDEX = Object.fromEntries(
  zapatillas.map((z) => {
    const vals = Object.values(z.puntuaciones);
    const score = Math.round((vals.reduce((a, b) => a + b, 0) / vals.length) * 10) / 10;
    const precio = (findMejorPrecioMostrado(z.links_compra)?.precio_actual) ?? z.precio_msrp_eur;
    return [z.slug, {
      marca: z.marca,
      modelo: z.modelo,
      img: z.imagen_principal,
      score,
      precio: Math.round(precio),
      cat: z.categoria_principal,
    }];
  })
);

const SUGERENCIAS = [
  "¿Mejor zapa para base <130€?",
  "¿Curry 12 o GT Cut 3?",
  "Algo con cushion para rodillas",
  "Lo mejor para asfalto",
];
---

<div id="cz-chat" class="cz-chat" data-open="false">
  <!-- Burbuja -->
  <button id="cz-chat-bubble" class="cz-chat-bubble" aria-label="Abrir asistente CANCHA" aria-expanded="false">
    <span class="ccb-icon ccb-icon-open" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 9 9 0 0 1-4-1L3 20l1.5-5.5a8.38 8.38 0 0 1-1-4A8.5 8.5 0 0 1 12 2a8.38 8.38 0 0 1 9 9.5Z"/>
      </svg>
    </span>
    <span class="ccb-icon ccb-icon-close" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
        <path d="M6 6l12 12M18 6L6 18"/>
      </svg>
    </span>
    <span class="ccb-pulse" aria-hidden="true"></span>
  </button>

  <!-- Panel -->
  <div id="cz-chat-panel" class="cz-chat-panel" role="dialog" aria-label="Asistente CANCHA.ZAPA">
    <header class="ccp-head">
      <div class="ccp-head-id">
        <span class="ccp-avatar" aria-hidden="true">★</span>
        <div>
          <p class="ccp-title">Experto CANCHA<span class="dot">.</span></p>
          <p class="ccp-status"><span class="ccp-dot"></span>Pregúntame sin BS</p>
        </div>
      </div>
      <button id="cz-chat-min" class="ccp-min" aria-label="Cerrar">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </header>

    <div id="cz-chat-log" class="ccp-log" aria-live="polite">
      <!-- Mensaje de bienvenida -->
      <div class="cc-msg cc-msg-bot">
        <div class="cc-bubble">
          Soy el experto de CANCHA.ZAPA. Dime cómo juegas, tu presupuesto o qué dudas tienes
          entre dos modelos — te respondo recto, con datos de nuestro catálogo. Sin sesgo de marca.
        </div>
      </div>
    </div>

    <!-- Sugerencias -->
    <div id="cz-chat-suggest" class="ccp-suggest">
      {SUGERENCIAS.map((s) => (
        <button class="ccp-chip" data-suggest={s}>{s}</button>
      ))}
    </div>

    <!-- Input -->
    <form id="cz-chat-form" class="ccp-form">
      <input
        id="cz-chat-input"
        class="ccp-input"
        type="text"
        placeholder="Escribe tu pregunta…"
        autocomplete="off"
        maxlength="500"
      />
      <button type="submit" class="ccp-send" aria-label="Enviar" id="cz-chat-send">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7Z"/></svg>
      </button>
    </form>

    <p class="ccp-disclaimer">IA · puede equivocarse. Verifica precios en la ficha.</p>
  </div>
</div>

<script define:vars={{ SHOE_INDEX }}>
  const root = document.getElementById("cz-chat");
  const bubble = document.getElementById("cz-chat-bubble");
  const panel = document.getElementById("cz-chat-panel");
  const log = document.getElementById("cz-chat-log");
  const form = document.getElementById("cz-chat-form");
  const input = document.getElementById("cz-chat-input");
  const sendBtn = document.getElementById("cz-chat-send");
  const suggestWrap = document.getElementById("cz-chat-suggest");
  const minBtn = document.getElementById("cz-chat-min");

  // Historial enviado al backend (sin el saludo inicial)
  const messages = [];
  let busy = false;

  // ── Abrir / cerrar ──────────────────────────────────────────────
  function setOpen(open) {
    root.dataset.open = String(open);
    bubble.setAttribute("aria-expanded", String(open));
    if (open) {
      setTimeout(() => input.focus(), 240);
      try { localStorage.setItem("cz.chat.seen", "1"); } catch {}
      root.querySelector(".ccb-pulse")?.classList.add("hidden");
    }
  }
  bubble.addEventListener("click", () => setOpen(root.dataset.open !== "true"));
  minBtn.addEventListener("click", () => setOpen(false));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && root.dataset.open === "true") setOpen(false);
  });

  // Si ya lo vio antes, quita el pulse
  try { if (localStorage.getItem("cz.chat.seen")) root.querySelector(".ccb-pulse")?.classList.add("hidden"); } catch {}

  // ── Helpers de render ───────────────────────────────────────────
  function esc(s) {
    const d = document.createElement("div");
    d.textContent = s;
    return d.innerHTML;
  }

  // Convierte texto del bot (con [[shoe:slug]] y **negrita**) en HTML seguro.
  function renderBotContent(text) {
    const frag = document.createElement("div");
    // Partimos por el marcador de zapa
    const parts = text.split(/(\[\[shoe:[a-z0-9-]+\]\])/gi);
    for (const part of parts) {
      const m = part.match(/^\[\[shoe:([a-z0-9-]+)\]\]$/i);
      if (m) {
        const card = shoeCard(m[1]);
        if (card) { frag.appendChild(card); continue; }
        // si no existe la zapa, ignora el marcador
      } else if (part) {
        const span = document.createElement("span");
        // Mini-markdown: **bold** y saltos de línea
        span.innerHTML = esc(part)
          .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
          .replace(/\n/g, "<br>");
        frag.appendChild(span);
      }
    }
    return frag;
  }

  function shoeCard(slug) {
    const z = SHOE_INDEX[slug];
    if (!z) return null;
    const a = document.createElement("a");
    a.href = `/zapatilla/${slug}`;
    a.className = "cc-shoe";
    a.innerHTML = `
      <span class="cc-shoe-photo"><img src="${esc(z.img)}" alt="" loading="lazy" onerror="this.style.display='none'"></span>
      <span class="cc-shoe-info">
        <span class="cc-shoe-marca">${esc(z.marca)}</span>
        <span class="cc-shoe-modelo">${esc(z.modelo)}</span>
        <span class="cc-shoe-meta"><span class="cc-shoe-score">${z.score}</span><span class="cc-shoe-price">${z.precio}€</span></span>
      </span>
      <span class="cc-shoe-arrow">→</span>`;
    return a;
  }

  function addMsg(role, contentNodeOrText) {
    const wrap = document.createElement("div");
    wrap.className = `cc-msg cc-msg-${role === "user" ? "user" : "bot"}`;
    const bubbleEl = document.createElement("div");
    bubbleEl.className = "cc-bubble";
    if (typeof contentNodeOrText === "string") {
      bubbleEl.innerHTML = esc(contentNodeOrText).replace(/\n/g, "<br>");
    } else {
      bubbleEl.appendChild(contentNodeOrText);
    }
    wrap.appendChild(bubbleEl);
    log.appendChild(wrap);
    log.scrollTop = log.scrollHeight;
    return bubbleEl;
  }

  function showTyping() {
    const wrap = document.createElement("div");
    wrap.className = "cc-msg cc-msg-bot cc-typing-wrap";
    wrap.innerHTML = `<div class="cc-bubble cc-typing"><span></span><span></span><span></span></div>`;
    log.appendChild(wrap);
    log.scrollTop = log.scrollHeight;
    return wrap;
  }

  // ── Envío ───────────────────────────────────────────────────────
  async function send(text) {
    if (busy || !text.trim()) return;
    busy = true;
    sendBtn.disabled = true;
    suggestWrap.style.display = "none";

    addMsg("user", text);
    messages.push({ role: "user", content: text });
    input.value = "";

    const typing = showTyping();

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages }),
      });

      if (!res.ok) throw new Error("HTTP " + res.status);

      const ctype = res.headers.get("content-type") || "";
      let reply = "";

      if (ctype.includes("application/json")) {
        // Respuesta JSON simple: { reply: "..." }
        const data = await res.json();
        reply = data.reply ?? data.message ?? "";
        typing.remove();
        const bubbleEl = addMsg("bot", "");
        bubbleEl.innerHTML = "";
        bubbleEl.appendChild(renderBotContent(reply));
      } else if (res.body && res.body.getReader) {
        // Streaming: vamos pintando texto plano según llega.
        typing.remove();
        const bubbleEl = addMsg("bot", "");
        bubbleEl.innerHTML = "";
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          reply += decoder.decode(value, { stream: true });
          // Re-render incremental (incluye mini-cards al cerrar el marcador)
          bubbleEl.innerHTML = "";
          bubbleEl.appendChild(renderBotContent(reply));
          log.scrollTop = log.scrollHeight;
        }
      } else {
        const data = await res.text();
        reply = data;
        typing.remove();
        const bubbleEl = addMsg("bot", "");
        bubbleEl.innerHTML = "";
        bubbleEl.appendChild(renderBotContent(reply));
      }

      messages.push({ role: "assistant", content: reply });
      log.scrollTop = log.scrollHeight;
    } catch (err) {
      typing.remove();
      addMsg("bot", "Uy, no he podido responder ahora mismo. Reintenta en un momento — o usa el quiz mientras tanto.");
      console.error("[cz-chat]", err);
    } finally {
      busy = false;
      sendBtn.disabled = false;
      input.focus();
    }
  }

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    send(input.value);
  });

  suggestWrap.querySelectorAll("[data-suggest]").forEach((btn) => {
    btn.addEventListener("click", () => send(btn.dataset.suggest));
  });
</script>
