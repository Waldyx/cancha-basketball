---
// PromoBanner.astro — franjas de promos activas (afiliados).
// Renderiza un contenedor vacío; un script crea una franja por cada promo
// vigente hoy (gating por fecha en cliente, web estática). ?promo=preview
// fuerza mostrarlas todas (para previsualizar antes de su fecha).
import { PROMOS } from "../data/promos";

const promosData = PROMOS.map((p) => ({
  id: p.id,
  tiendaLabel: p.tiendaLabel,
  titulo: p.titulo,
  desde: p.desde,
  hasta: p.hasta,
  url: p.url ?? null,
  maxDesc: p.codigos?.length ? Math.max(...p.codigos.map((c) => c.descuento)) : null,
  codigo: p.codigo ?? null,
  descuentoTexto: p.descuentoTexto ?? null,
  color: p.color ?? "#f97316",
}));
---

<div id="cz-promo-banner" class="cz-promo-banner"></div>

<style>
  .cz-promo-banner { position: relative; z-index: 30; }
  .cz-promo-strip {
    position: relative;
    color: #0c0c0c;
  }
  .cz-promo-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 7px 36px 7px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .cz-promo-text {
    font-size: 12.5px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
  }
  .cz-promo-cta {
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0c0c0c;
    text-decoration: underline;
    white-space: nowrap;
  }
  .cz-promo-close {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: #0c0c0c;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    font-weight: 700;
    opacity: 0.7;
  }
  .cz-promo-close:hover { opacity: 1; }
  @media (max-width: 600px) {
    .cz-promo-inner { padding: 7px 32px 7px 14px; gap: 8px; }
    .cz-promo-text { font-size: 11px; }
  }
</style>

<script is:inline define:vars={{ promosData }}>
  (function () {
    try {
      var now = Date.now();
      var preview = (new URLSearchParams(location.search).get("promo") || "").indexOf("preview") === 0;
      var list = promosData.filter(function (p) {
        if (preview) return true;
        return now >= new Date(p.desde).getTime() && now <= new Date(p.hasta).getTime();
      });
      var cont = document.getElementById("cz-promo-banner");
      if (!cont || !list.length) return;

      list.forEach(function (p) {
        if (!preview && localStorage.getItem("cz.promo.dismissed." + p.id)) return;
        var fin = new Date(p.hasta).toLocaleDateString("es-ES", { day: "numeric", month: "short" });
        var resumen;
        if (p.maxDesc) resumen = "hasta −" + p.maxDesc + "€ con código";
        else if (p.codigo) resumen = (p.descuentoTexto || "descuento") + " · código " + p.codigo;
        else resumen = p.descuentoTexto || "oferta activa";

        var strip = document.createElement("div");
        strip.className = "cz-promo-strip";
        strip.style.background = p.color;
        var inner = document.createElement("div");
        inner.className = "cz-promo-inner";
        var txt = document.createElement("span");
        txt.className = "cz-promo-text";
        txt.textContent = "🔥 " + p.tiendaLabel + " · " + p.titulo + ": " + resumen + " · hasta " + fin;
        inner.appendChild(txt);
        if (p.url) {
          var a = document.createElement("a");
          a.className = "cz-promo-cta";
          a.href = p.url; a.target = "_blank"; a.rel = "sponsored noopener";
          a.textContent = "Ver en tienda →";
          inner.appendChild(a);
        }
        var close = document.createElement("button");
        close.className = "cz-promo-close";
        close.setAttribute("aria-label", "Cerrar aviso");
        close.textContent = "×";
        close.addEventListener("click", function () {
          strip.remove();
          try { localStorage.setItem("cz.promo.dismissed." + p.id, "1"); } catch (e) {}
        });
        strip.appendChild(inner);
        strip.appendChild(close);
        cont.appendChild(strip);
      });
    } catch (e) {}
  })();
</script>
